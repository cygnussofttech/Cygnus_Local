        //    var laneid = $("#lane_id").val() || 0;
        //    var strurl = domainname + '/Fleet/CheckDuplicateMapping?ConsignorCode=' +  + '&laneid=' + laneid;
        //    $.ajax({
        //        url: strurl,
        //        cache: false,
        //        data: {},
        //        type: 'post',
        //        success: function (data) {
        //            if (data > "0") {
        //                tosternotification("error", 'lane <b>"' + lanename + '"</b> already exists!!!', "oops..!!");
        //                $("#lane_name").val("").focus();
