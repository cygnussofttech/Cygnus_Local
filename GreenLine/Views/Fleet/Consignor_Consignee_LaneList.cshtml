        return {
            init: function (DomainName) {
             

                $(document).on('click', '#btnDownloadStateMasterReport', function (e) {
                    e.preventDefault();
                    DownloadMasterReport(DomainName, "Lane", "Lane_Master_List");
                });

                handleSave(DomainName);

                $(document).on('click', ".btnEditLane", function () {
                    var id = $(this).data('id');
                    GetLaneDetails(id, DomainName);
                });

                GlDataTable.init('LaneList', {
                    columnDefs: [
                        { orderable: false, targets: [3] }
                    ]
                });

                $(document).on("click", ".btnApproveLane", function (e) {
                    e.preventDefault();
                    var btn = $(this);
                    var id = btn.data("id");
                    var LaneId = btn.data("laneid");
                    var ConsigneeCode = btn.data("consigneecode");
                    var ConsignorCode = btn.data("consignorcode");

                    showConfirm({
                        title: "Approve Mapping",
                        message: "Are you sure you want to <strong>Approve</strong> this mapping?",
                        type: "success",
                        onConfirm: function () {
                            App.blockUI({ boxed: true });
                            $.get(DomainName + '/Fleet/ApproveConsignorConsigneeMapping',
                                { ConsignorCode: ConsignorCode, ConsigneeCode: ConsigneeCode, LaneId: LaneId, id: id },
                                function (res) {
                                    App.unblockUI();
                                    if (res) {
                                        TosterNotification("success", "Mapping approved successfully!", "Success");
                                        window.location.reload();
                                    } else {
                                        TosterNotification("error", "Failed to approve mapping.", "Error");
                                    }
                                }
                            ).fail(function () {
                                App.unblockUI();
                                TosterNotification("error", "An error occurred while approving.", "Error");
