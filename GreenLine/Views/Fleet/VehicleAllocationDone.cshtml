@{
    ViewBag.Title = "Vehicle Allocation Done";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6">
        @if (ViewBag.Status == "1")
        {
            <div class="card shadow-lg border-0">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="avatar-lg mx-auto">
                            <div class="avatar-title bg-soft-success text-success display-3 rounded-circle" style="width: 100px; height: 100px; line-height: 100px; margin: 0 auto;">
                                <i class="ri-checkbox-circle-fill"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="fw-bold mb-2">Success!</h3>
                    <p class="text-muted fs-15">Vehicle Allocation done with @ViewBag.VehicleNo.</p>

                    <div class="bg-light p-3 rounded-3 mb-4 mt-4">
                        <p class="text-uppercase fw-semibold text-muted mb-1 fs-12">@ViewBag.Title </p>
                        <h4 class="mb-0 text-primary"></h4>
                    </div>

                </div>
            </div>
        }
        else
        {
            <div class="card shadow-lg border-0 border-top border-top-danger border-4">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="avatar-lg mx-auto">
                            <div class="avatar-title bg-soft-danger text-danger display-3 rounded-circle" style="width: 100px; height: 100px; line-height: 100px; margin: 0 auto;">
                                <i class="ri-error-warning-fill"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="fw-bold text-danger mb-2">Transaction Failed</h3>
                    <p class="text-muted fs-15">Something went wrong during the save process. Please check the details below or contact support.</p>

                    <div class="alert alert-danger border-0 mt-4 mb-4" role="alert">
                        <strong>Opps!</strong> There was an issue processing your request. Please check your internet connection and try again.
                    </div>

                    <div class="hstack gap-2 justify-content-center mt-4">
                        <button onclick="window.history.back()" class="btn btn-danger d-flex align-items-center">
                            <i class="ri-arrow-left-line me-1"></i> Try Again
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
