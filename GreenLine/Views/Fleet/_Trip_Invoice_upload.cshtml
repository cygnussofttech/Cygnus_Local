<script>
    function initInvoiceUploadTab() {
        var isScanned = false;
        var initialEwayBill = ($('#eway_bill_no').val() || '').trim().toLowerCase();
        var isEwbDataFetched = (/^\d{12}$/.test(initialEwayBill));
        var lastProcessedEwayBill = initialEwayBill;

        function parseCustomDate(dateStr) {
            if (!dateStr) return null;
            dateStr = dateStr.trim();
            if (dateStr === "NA" || dateStr === "na") return null;

            var d = new Date(dateStr);
            if (!isNaN(d.getTime())) {
                return d;
            }

            var parts = dateStr.split(/[\s\-\/]+/);
            if (parts.length >= 3) {
                var day = parseInt(parts[0], 10);
                var year = parseInt(parts[2], 10);
                var monthStr = parts[1];
                
                var month = -1;
                var months = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
                var monthIdx = months.indexOf(monthStr.toLowerCase());
                if (monthIdx !== -1) {
                    month = monthIdx;
                } else {
                    var mNum = parseInt(monthStr, 10);
                    if (!isNaN(mNum) && mNum >= 1 && mNum <= 12) {
                        month = mNum - 1;
                    }
                }

                if (day > 0 && month >= 0 && year > 0) {
                    if (year < 100) year += 2000;
                    return new Date(year, month, day);
                }
            }
            return null;
        }

        function checkEwayBillValidity(validityDateStr) {
            if (!validityDateStr || validityDateStr === "NA" || validityDateStr === "na") return true;
            
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            
            var validityDate = parseCustomDate(validityDateStr);
            if (validityDate) {
                validityDate.setHours(0, 0, 0, 0);
                if (validityDate < today) {
                    clearEWBData();
                    TosterNotification("error", "E-Way Bill has expired.", "Expired");
                    $("#eway_bill_no").val("");
                    toggleClsHide();
                    return false;
                }
            }
            return true;
        }
        window.checkEwayBillValidity = checkEwayBillValidity;

        function toggleClsHide() {
            var ewayBillVal = ($('#eway_bill_no').val() || '').trim().toLowerCase();
            var isEwayBillValid = (/^\d{12}$/.test(ewayBillVal) && isEwbDataFetched);
            var fileInput = document.getElementById('UploadFile');
            var fileUploaded = fileInput && fileInput.files && fileInput.files.length > 0;
            if (isEwayBillValid || (fileUploaded && isScanned)) {
                $('.clshide').show();
            } else {
                $('.clshide').hide();
            }
        }
        $(document).on('input change', '#eway_bill_no', function () {
            var ewayBillNo = ($(this).val() || '').trim();
            var ewayBillVal = ewayBillNo.toLowerCase();

            if (ewayBillVal === lastProcessedEwayBill) {
                return;
            }
            lastProcessedEwayBill = ewayBillVal;

            if (ewayBillVal === "na") {
                $("#eway_bill_no").val(ewayBillNo).prop('disabled', true).addClass('bg-light');
                $("#eway_bill_date").val('NA').prop('disabled', true).addClass('bg-light');
                $("#eway_bill_validity").val('NA').prop('disabled', true).addClass('bg-light');
                isEwbDataFetched = false;
                clearEWBData();
                $(".clshide").hide();
            } else if (/^\d{12}$/.test(ewayBillVal)) {
                isEwbDataFetched = false;
                clearEWBData();
                fetchEWBData(ewayBillNo);
            } else {
                isEwbDataFetched = false;
                clearEWBData();
            }
        });
        $('#lrEntryForm').on('change', '#UploadFile', function () {
            isScanned = false;
            toggleClsHide();
            var file = this.files[0];
            if (file) {
                validateImageFile(file, this);
            }
        });
        $(document).on('change changeDate', '#eway_bill_validity', function () {
            var val = $(this).val();
            if (val) {
                checkEwayBillValidity(val);
            }
        });
        setTimeout(toggleClsHide, 100);

        // Clear default C# DateTime values (0001-01-01 or 1900) on load so inputs show clean placeholders
        // Clear 'NA' dates ONLY if the eway_bill_no is NOT 'na'
        var ewayBillVal = ($('#eway_bill_no').val() || '').trim().toLowerCase();
        $('input.date-picker').each(function () {
            var val = $(this).val();
            if (val) {
                if (val.indexOf('0001') > -1 || val.indexOf('1900') > -1) {
                    $(this).val('');
                } else if (val.toLowerCase() === 'na' && ewayBillVal !== 'na') {
                    $(this).val('');
                }
            }
        });

        // If eway_bill_no is 'na', ensure date fields are 'NA' and styled correctly
        if (ewayBillVal === 'na') {
            $('#eway_bill_date').val('NA').prop('disabled', true).addClass('bg-light');
            $('#eway_bill_validity').val('NA').prop('disabled', true).addClass('bg-light');
            $('#eway_bill_no').prop('disabled', true).addClass('bg-light');
        }

        // Make Ship To (Consignee_Name) read-only on page load by disabling it
        $('#Consignee_Name').addClass('disabled-field').prop('disabled', true);

        // Check validity of initial date on load
        var validityVal = $('#eway_bill_validity').val();
        if (validityVal) {
            checkEwayBillValidity(validityVal);
        }

        // Handle selection change on Ship To dropdown to populate hidden fields
        $(document).on('change', '#Consignee_Name', function () {
            var $opt = $(this).find('option:selected');
            if ($opt.length && $opt.val() !== "") {
                $('#Consignee_GST').val($opt.attr('data-gst') || "");
                $('#Consignee_PANNo').val($opt.attr('data-pan') || "");
                $('#Consignee_Address').val($opt.attr('data-address') || "");
                $('#consignee_city').val($opt.attr('data-city') || "");
                $('#consignee_pincode').val($opt.attr('data-pincode') || "");
                $('#Consignee_Code').val($opt.attr('data-code') || "");
            } else {
                $('#Consignee_GST').val("");
                $('#Consignee_PANNo').val("");
                $('#Consignee_Address').val("");
                $('#consignee_city').val("");
                $('#consignee_pincode').val("");
                $('#Consignee_Code').val("");
            }
        });

        // Trigger change on load if a value is selected to ensure synchronization
        if ($('#Consignee_Name').val()) {
            $('#Consignee_Name').trigger('change');
        }

        // E-Way Bill auto-fetch is handled by input/change event listener above

        function clearEWBData() {
            $('#invoice_no').val('');
            $('#invoice_date').val('');
            $('#userGstin').val('');
            $('#consignor_name').val('');
            $('#consignor_address').val('');
            $('#consignor_State').val('');
            //$('#eway_bill_date').val('');

            $('#Consignee_Name').prop('disabled', false).val('').trigger('change').prop('disabled', true);

            $('#consignee_city').val('');
            $('#consignee_pincode').val('');
            $('#Consignee_GST').val('');
            $('#Consignee_Address').val('');
            $('#Consignee_PANNo').val('');
            $('#Consignee_Code').val('');

            $('#net_weight').val('');
            $('#actualDist').val('');
            $('#noValidDays').val('');
            $('#EwayBillJson').val('');

            //$('#eway_bill_no').val('');
            //$('#eway_bill_validity').val('');
            //$('#eway_bill_date').val('');

            isScanned = false;
            isEwbDataFetched = false;
            _ewbConsigneeData = {};
            toggleClsHide();
        }

        $('#btnScanInvoice').on('click', function () {
            var fileInput = document.getElementById('UploadFile');
            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                isScanned = true;
                // Immediately show the form details container on Scan click
                $('.clshide').show();

                var formData = new FormData();
                formData.append("UploadFile", fileInput.files[0]);

                // Use Project's Custom Loader
                App.blockUI({ target: 'body', boxed: true, message: 'Scanning Invoice...' });

                $.ajax({
                    url: '@Url.Action("ProcessInvoiceOCR", "Fleet")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    headers: { "X-Skip-ContentType-Override": "true" },
                    success: function (res) {
                        App.unblockUI();
                        if (res.success) {
                            var d = res.data;
                            var isValid = fillMissingFieldsFromOCR(d);
                            if (isValid !== false) {
                                ConsigneeValidation();
                                TosterNotification("success", "Invoice Scanned Successfully!", "Success");
                            }
                        } else {
                            TosterNotification("error", res.message, "Error");
                        }
                        toggleClsHide();
                    },
                    error: function () {
                        App.unblockUI();
                        TosterNotification("error", "Failed to connect to the server", "Error");
                    }
                });
            } else {
                $('#UploadFile').trigger('click');
            }
        });

        $('#btnSaveLR').on('click', function (e) {
            //// Clear NA sentinels so disabled fields are submitted properly
            //['#eway_bill_no', '#eway_bill_date', '#eway_bill_validity'].forEach(function (id) {
            //    if ($(id).val() === 'NA') $(id).val('');
            //    $(id).prop('disabled', false);
            //});
            //if ($('#lrEntryForm').valid()) {
            //    App.blockUI({ boxed: true, message: 'Saving LR Entry...' });
