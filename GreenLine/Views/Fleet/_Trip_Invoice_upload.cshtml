        if (Contract_Id != "" && From_Lane_id != "" && To_Lane_id != "" && Rate_Type != "" && UOM != "" && Content != "" && gross_weight > 0 && net_weight > 0) {
            var Parameters = {
                "Contract_Id": Contract_Id,
                "From_Lane_id": From_Lane_id,
                "To_Lane_id": To_Lane_id,
                "Rate_Type": Rate_Type,
                "UOM": UOM,
                "Product": Content,
                "GrossWeight": gross_weight,
                "NetWeight": net_weight
            }
            var strUrl = DomainName + "/Account/GetDataWithoutAlias";
            $.ajax({
                url: strUrl,
                type: 'POST',
                dataType: "json",
                async: false,
                data: {
                    Method: "USP_GetContractFor_LR",
                    parameters: Parameters
                },
                success: function (data) {
                    //console.log(Parameters);
                    //console.log('s', data[0]);

                    if (data && data.length > 0) {
                        var rate = data[0].rate;
                        $("#Rate").val(data[0].rate);
                        var Km = data[0].ContractualDistance;
                        var minqty = data[0].MinimumGuarantee;

                        var Calculatedrate = 0;
                        if (Rate_Type == "N1") {
                            $("#Freight").val(rate);
                            $("#Total").val(rate);
                            $("#Sub_Total").val(rate);
                        }
                        else if (Rate_Type == "N2") {
                            Calculatedrate = rate * Km;
                            $("#Freight").val(Calculatedrate);
                            $("#Total").val(Calculatedrate);
                            $("#Sub_Total").val(Calculatedrate);
                        }
                        else if (Rate_Type == "N3") {
                            if (data[0].ChargeableOn == 2) {
                                if (minqty > net_weight) {
                                    Calculatedrate = rate * minqty;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                                else {
                                    Calculatedrate = rate * net_weight;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                            }
                            else {
                                if (minqty > gross_weight) {
                                    Calculatedrate = rate * minqty;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                                else {
                                    Calculatedrate = rate * gross_weight;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                            }
                        }
                        else if (Rate_Type == "N4") {
                            if (data[0].ChargeableOn == 2) {
                                if (minqty > net_weight) {
                                    Calculatedrate = rate * minqty * Km;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                                else {
                                    Calculatedrate = rate * net_weight * Km;
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                            }
                            else {
                                if (minqty > gross_weight) {
                                    Calculatedrate = rate * minqty * Km;
                                    //console.log('m', Calculatedrate);
                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                                else {
                                    Calculatedrate = rate * gross_weight * Km;
                                    //console.log(Calculatedrate);

                                    $("#Freight").val(Calculatedrate);
                                    $("#Total").val(Calculatedrate);
                                    $("#Sub_Total").val(Calculatedrate);
                                }
                            }
                        }
                        //TosterNotification("success", "Invoice Scanned Successfully!", "Success");
                    } else {
                        TosterNotification("error", "There is no Rate for Rate Type : " + $("#Rate_Type option:selected").text() + " Product : " + $("#Content option:selected").text() + " UOM : " + $("#UOM option:selected").text() + " ", "Error");
                    }

                },
                error: function (jqXHR, exception) {
                    TosterNotification("error", errorResult(jqXHR, exception), "Oppps..!!");
                    return false;
                }
            });
        }
