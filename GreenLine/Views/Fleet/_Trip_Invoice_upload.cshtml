                            _ewbConsigneeData.Consignee_GST = Consignee_GST;
                        }
                        if (!_ewbConsigneeData.Consignee_Name) {
                            _ewbConsigneeData.Consignee_Name = $("#Consignee_Name").val() || "";
                        }
                        if (!_ewbConsigneeData.Consignee_Address) {
                            _ewbConsigneeData.Consignee_Address = $("#Consignee_Address").val() || "";
                        }
                        if (!_ewbConsigneeData.Consignee_Pincode) {
                            _ewbConsigneeData.Consignee_Pincode = $("#consignee_pincode").val() || "";
                        }

                        var modalGst = Consignee_GST || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_GST : "") || "";
                        var modalName = ($("#Consignee_Name").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Name : "") || "";
                        var modalAddress = ($("#Consignee_Address").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Address : "") || "";
                        var modalPincode = ($("#consignee_pincode").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Pincode : "") || "";

                        var qs = "?gst=" + encodeURIComponent(modalGst) +
                                 "&name=" + encodeURIComponent(modalName) +
                                 "&address=" + encodeURIComponent(modalAddress) +
                                 "&pincode=" + encodeURIComponent(modalPincode);

                        GLModal.showForm({
                            title: "Add Consignee (GST Not Registered)",
                            icon: "ri-truck-line",
                            url: DomainName + '/Master/ConsigneeMaster' + qs
                        });
                        // Disable modal close controls for this particular modal
                        disableModalClose();
                        // Pre-fill the consignee modal form once the partial view has loaded
                        prefillConsigneeModal();
                    }
                }
            },
            error: function (jqXHR, exception) {
                TosterNotification("error", errorResult(jqXHR, exception), "Oppps..!!");
                return false;
            }
        });
    }
    function disableModalClose() {
        var modalEl = document.getElementById('glFormModal');
        if (modalEl) {
            modalEl.setAttribute('data-bs-keyboard', 'false');
            var bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
            if (bsModal && bsModal._config) {
                bsModal._config.keyboard = false;
            }
        }
        $('#glFormModalClose').hide();
        $('#glFormModal').find('.modal-footer button[data-bs-dismiss="modal"]').hide();

        $('#glFormModal').off('hidden.bs.modal.restoreButtons').on('hidden.bs.modal.restoreButtons', function () {
            var mEl = document.getElementById('glFormModal');
            if (mEl) {
                mEl.setAttribute('data-bs-keyboard', 'true');
                var bsM = bootstrap.Modal.getOrCreateInstance(mEl);
                if (bsM && bsM._config) {
                    bsM._config.keyboard = true;
                }
            }
            $('#glFormModalClose').show();
            $('#glFormModal').find('.modal-footer button[data-bs-dismiss="modal"]').show();
        });
    }
    var _ewbConsigneeData = {};
    function prefillConsigneeModal() {
        var maxAttempts = 40;   // 40 × 150ms = 6 seconds max wait
        var attempts = 0;

        var timer = setInterval(function () {
            attempts++;

            // The consignee partial renders inside #glFormModal
            var $gstField = $('#glFormModal').find('#Consignee_GST');

            if ($gstField.length > 0) {
                clearInterval(timer);

                var d = _ewbConsigneeData;

                // ── GST ──────────────────────────────────────────────────
                if (d.Consignee_GST) {
                    $gstField.val(d.Consignee_GST).trigger('input');
                    // Trigger the GST lookup that the form uses (CheckDuplicateGST → GetGSTDetails)
                    // but only fire the duplicate check; do NOT trigger the full 'change' to avoid
                    // overwriting the pre-filled name/address from EWayBill.
                }

                // ── Name ─────────────────────────────────────────────────
                if (d.Consignee_Name) {
                    $('#glFormModal').find('#Consignee_Name').val(d.Consignee_Name);
                }

                // ── Address ──────────────────────────────────────────────
                if (d.Consignee_Address) {
                    $('#glFormModal').find('#Consignee_Address').val(d.Consignee_Address);
                }

                // ── Pincode (Select2) ────────────────────────────────────
                if (d.Consignee_Pincode) {
                    var pin = $('#glFormModal').find('#Consignee_Pincode');
                    if (pin.data('select2')) {
                        pin.select2('data', { id: d.Consignee_Pincode, text: d.Consignee_Pincode });
                    } else {
                        pin.val(d.Consignee_Pincode);
                    }
                    // Trigger the pincode change handler to auto-fill state/city/country
                    pin.trigger('change');
                }

                // Show a friendly banner inside the modal so the user knows data was pre-filled
                var fieldsContainer = $('#glFormModal').find('#fieldsContainer');
                if (fieldsContainer.length && !fieldsContainer.find('#ewb-prefill-banner').length) {
                    fieldsContainer.prepend(
                        '<div id="ewb-prefill-banner" class="alert alert-info alert-dismissible py-2 mb-3" role="alert" style="font-size:13px;">'
                        + '<i class="ri-magic-line me-1"></i>'
                        + '<strong>Auto-filled from Invoice / E-Way Bill data.</strong> Please verify and complete any missing fields.'
                        + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>'
                        + '</div>'
                    );
                }

            } else if (attempts >= maxAttempts) {
                clearInterval(timer);
                console.warn('prefillConsigneeModal: form not found within timeout.');
            }
        }, 150);

        $("#Consignee_Pincode").change();
    }

    var GetContractOnGrossWeight = function (DomainName) {
        var Contract_Id = $("#Contract_Id").val();
