    function fillMissingFieldsFromOCR(d) {
        // Helper to check if a field is considered empty or holding a default/placeholder value
        function isFieldEmptyOrDefault(val) {
            if (val === undefined || val === null) return true;
            var s = String(val).trim();
            return s === "" || s === "0001-01-01T00:00:00";
        }

        var validityDateStr = "";
        if (isFieldEmptyOrDefault($("#eway_bill_validity").val())) {
            validityDateStr = isValidDateValue(d.eway_bill_validity) ? fmtEWBDate(d.eway_bill_validity) : "";
        } else {
            validityDateStr = $("#eway_bill_validity").val();
        }

        if (validityDateStr && !checkEwayBillValidity(validityDateStr)) {
            $(".clshide").hide();
            return false;
        }

        // Secondary Priority: Only fill if field is empty (Never overwrite existing valid EWB values)
        if (isFieldEmptyOrDefault($("#eway_bill_no").val())) $("#eway_bill_no").val(d.eway_bill_no);
        if (isFieldEmptyOrDefault($("#invoice_no").val())) $("#invoice_no").val(d.invoice_no);
        if (isFieldEmptyOrDefault($("#gross_weight").val())) $("#gross_weight").val(d.gross_weight);
        if (isFieldEmptyOrDefault($("#net_weight").val())) $("#net_weight").val(d.net_weight);
        if (isFieldEmptyOrDefault($("#CustLRNo").val())) $("#CustLRNo").val(d.lr_no);
        if (isFieldEmptyOrDefault($("#reference_no").val())) $("#reference_no").val(d.reference_no);
        if (isFieldEmptyOrDefault($("#UOM").val())) $("#UOM").val(d.UOM);

        // Hidden fields on parent page
        if (isFieldEmptyOrDefault($("#consignor_name").val())) $("#consignor_name").val(d.consignor_name);
        if (isFieldEmptyOrDefault($("#consignor_address").val())) $("#consignor_address").val(d.consignor_address);
        if (isFieldEmptyOrDefault($("#Consignee_Name").val())) $("#Consignee_Name").prop('disabled', false).val(d.consignee_name || d.ship_to_name).trigger('change').prop('disabled', true);
        if (isFieldEmptyOrDefault($("#Consignee_Address").val())) $("#Consignee_Address").val(d.consignee_address || d.ship_to_address);
        if (isFieldEmptyOrDefault($("#consignee_city").val())) $("#consignee_city").val(d.consignee_city || d.ship_to_city);
        if (isFieldEmptyOrDefault($("#consignee_pincode").val())) $("#consignee_pincode").val(d.consignee_pincode || d.ship_to_pincode);
        if (isFieldEmptyOrDefault($("#Consignee_GST").val())) $("#Consignee_GST").val(d.ship_to_gst || d.consignee_gst);
        if (isFieldEmptyOrDefault($("#so_number").val())) $("#so_number").val(d.so_number);
        if (isFieldEmptyOrDefault($("#do_number").val())) $("#do_number").val(d.do_number);

        // Always store remaining OCR fields in hidden fields if they are currently empty
        if (isFieldEmptyOrDefault($("#detected_document_type").val())) $("#detected_document_type").val(d.detected_document_type || "");
        if (isFieldEmptyOrDefault($("#wrong_document").val())) $("#wrong_document").val(d.wrong_document !== undefined ? d.wrong_document : "");
        if (isFieldEmptyOrDefault($("#is_blurry").val())) $("#is_blurry").val(d.is_blurry !== undefined ? d.is_blurry : "");
        if (isFieldEmptyOrDefault($("#ship_to_state_code").val())) $("#ship_to_state_code").val(d.ship_to_state_code || "");
        if (isFieldEmptyOrDefault($("#transporter_name").val())) $("#transporter_name").val(d.transporter_name || "");
        if (isFieldEmptyOrDefault($("#vehicle_number").val())) $("#vehicle_number").val(d.vehicle_number || "");
        if (isFieldEmptyOrDefault($("#delivery_no").val())) $("#delivery_no").val(d.delivery_no || "");
        if (isFieldEmptyOrDefault($("#di_no").val())) $("#di_no").val(d.di_no || "");
        if (isFieldEmptyOrDefault($("#shipment_no").val())) $("#shipment_no").val(d.shipment_no || "");
        if (isFieldEmptyOrDefault($("#pieces_count").val())) $("#pieces_count").val(d.pieces_count !== undefined ? d.pieces_count : "");
        if (isFieldEmptyOrDefault($("#flipkart_order_id").val())) $("#flipkart_order_id").val(d.flipkart_order_id || "");
        if (isFieldEmptyOrDefault($("#tata_document_type").val())) $("#tata_document_type").val(d.tata_document_type || "");

        // Populate the modal prefill cache with Invoice OCR details
        if (!_ewbConsigneeData) {
            _ewbConsigneeData = {};
        }
        if (!_ewbConsigneeData.Consignee_GST) {
            _ewbConsigneeData.Consignee_GST = d.ship_to_gst || d.consignee_gst || "";
        }
        if (!_ewbConsigneeData.Consignee_Name) {
            _ewbConsigneeData.Consignee_Name = d.consignee_name || d.ship_to_name || "";
        }
        if (!_ewbConsigneeData.Consignee_Address) {
            _ewbConsigneeData.Consignee_Address = d.consignee_address || d.ship_to_address || "";
        }
        if (!_ewbConsigneeData.Consignee_Pincode) {
            _ewbConsigneeData.Consignee_Pincode = d.consignee_pincode || d.ship_to_pincode || "";
        }

        // Handle dates
        if (isFieldEmptyOrDefault($("#invoice_date").val())) {
            $("#invoice_date").val(isValidDateValue(d.invoice_date) ? fmtEWBDate(d.invoice_date) : "");
        }

        var ewbNoVal = ($("#eway_bill_no").val() || "").trim().toLowerCase();
        if (ewbNoVal === "na") {
            $("#eway_bill_date").val("NA");
            $("#eway_bill_validity").val("NA");
        } else {
            if (isFieldEmptyOrDefault($("#eway_bill_date").val())) {
                $("#eway_bill_date").val(isValidDateValue(d.eway_bill_date) ? fmtEWBDate(d.eway_bill_date) : "");
            }
            if (isFieldEmptyOrDefault($("#eway_bill_validity").val())) {
                $("#eway_bill_validity").val(isValidDateValue(d.eway_bill_validity) ? fmtEWBDate(d.eway_bill_validity) : "");
            }
        }

        if (isFieldEmptyOrDefault($("#lr_date").val())) {
            $("#lr_date").val(isValidDateValue(d.lr_date) ? fmtEWBDate(d.lr_date) : "");
        }

        if (isFieldEmptyOrDefault($("#delivery_date").val())) {
            $("#delivery_date").val(isValidDateValue(d.delivery_date) ? fmtEWBDate(d.delivery_date) : "");
        }
        if (isFieldEmptyOrDefault($("#odn_date").val())) {
            $("#odn_date").val(isValidDateValue(d.odn_date) ? fmtEWBDate(d.odn_date) : "");
        }
        if (isFieldEmptyOrDefault($("#obd_date").val())) {
            $("#obd_date").val(isValidDateValue(d.obd_date) ? fmtEWBDate(d.obd_date) : "");
        }
        if (isFieldEmptyOrDefault($("#eta_date").val())) {
            $("#eta_date").val(isValidDateValue(d.eta_date) ? fmtEWBDate(d.eta_date) : "");
        }

        if (isFieldEmptyOrDefault($("#odn_no").val())) $("#odn_no").val(d.odn_no || "");
        if (isFieldEmptyOrDefault($("#obd_no").val())) $("#obd_no").val(d.obd_no || "");

        var currentEwbVal = ($("#eway_bill_no").val() || '').trim().toLowerCase();
        if (/^\d{12}$/.test(currentEwbVal)) {
            isEwbDataFetched = true;
            lastProcessedEwayBill = currentEwbVal;
        }
    }
