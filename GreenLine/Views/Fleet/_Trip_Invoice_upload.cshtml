    function loadContractAdditionalFields(contractId) {
        if (!contractId) {
            $('#dynamicAdditionalFieldsContainer').empty();
            return;
        }
        $.ajax({
            url: DomainName + '/Fleet/GetContractAdditionalFields',
            type: 'GET',
            data: { contractId: contractId },
            success: function (res) {
                var $container = $('#dynamicAdditionalFieldsContainer');
                $container.empty();
                if (res && res.success && res.fields && res.fields.length > 0) {
                    $.each(res.fields, function (i, field) {
                        var reqClass = field.Required === 'Y' ? 'required-label' : '';
                        var reqAttr = field.Required === 'Y' ? 'required' : '';
                        var minLengthAttr = field.MinLength > 0 ? 'minlength="' + field.MinLength + '"' : '';
                        var maxLengthAttr = field.MaxLength > 0 ? 'maxlength="' + field.MaxLength + '"' : '';
                        var onKeyPress = '';
                        var inputClass = 'form-control';

                        if (field.DataType === 'int') {
                            onKeyPress = 'onkeypress="javascript:return event.charCode >= 48 && event.charCode <= 57"';
                            inputClass += ' number-only';
                        } else if (field.DataType === 'decimal') {
                            onKeyPress = 'onkeypress="javascript:return validDigits(event, this)"';
                            inputClass += ' decimal-only';
                        } else if (field.DataType === 'Date') {
                            inputClass += ' date-picker';
                        }

                        if (field.Required === 'Y') {
                            inputClass += ' required';
                        }

                        var html =
                            '<div class="col-lg-3 col-md-6">' +
                            '    <div class="form-group">' +
                            '        <label class="form-label ' + reqClass + '">' + field.Label + '</label>' +
                            '        <input type="text" name="' + field.Name + '" id="' + field.Name + '" class="' + inputClass + '" placeholder="Enter ' + field.Label + '" ' + reqAttr + ' ' + minLengthAttr + ' ' + maxLengthAttr + ' ' + onKeyPress + ' />' +
                            '    </div>' +
                            '</div>';

                        $container.append(html);
                    });

                    // Initialize date-picker on newly added dynamic date fields
                    $container.find('.date-picker').datepicker({ format: "dd M yyyy", autoclose: true, todayBtn: true });

                    // Re-parse validation rules for dynamic elements
                    if ($.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse("#dynamicAdditionalFieldsContainer");
                    }
                }
            },
            error: function () {
                console.error('Failed to load contract additional fields.');
            }
        });
    }

    function loadContractStandardCharges(contractId) {
        if (!contractId) {
            $('#dynamicChargesContainer').empty();
            return;
        }
        $.ajax({
            url: DomainName + '/Contract/GetContractStandardCharges',
            type: 'GET',
            data: { contractId: contractId },
            success: function (res) {
                var container = $('#dynamicChargesContainer');
                container.empty();
                //console.log(res);
                if (res && res.success && res.charges && res.charges.length > 0) {
                    $.each(res.charges, function (i, charge) {
                        var reqClass = charge.IsRequired ? 'required-label' : '';
                        var reqAttr = charge.IsRequired ? 'required' : '';
                        var inputClass = 'form-control charge-input';
                        if (charge.IsRequired) {
                            inputClass += ' required';
                        }

                        var html =
                            '<div class="col-lg-3 col-md-6">' +
                            '    <div class="form-group">' +
                            '        <label class="form-label ' + reqClass + '">' + charge.chargename + '</label>' +
                            '        <input type="text" name="charge_' + charge.chargecode + '" id="charge_' + charge.chargecode + '" class="' + inputClass + '" value="0" placeholder="Enter ' + charge.chargename + '" ' + reqAttr + ' onkeypress="javascript:return validDigits(event, this)" />' +
                            '    </div>' +
                            '</div>';

                      container.append(html);
                    });

                    // Re-parse validation rules for dynamic elements
                    if ($.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse("#dynamicChargesContainer");
                    }

                    // Dynamically fetch rates for the loaded charges
                    fetchStandardChargeRates();
                }
            },
            error: function () {
                console.error('Failed to load contract standard charges.');
            }
        });
    }

    function fetchStandardChargeRates() {
        var contractId = $("#Contract_Id").val();
        var fromLaneId = $("#From_Lane_id").val();
        var toLaneId = $("#To_Lane_id").val();
        var rateType = $("#Rate_Type").val();

        if (!contractId || !fromLaneId || !toLaneId || !rateType) {
            $(".charge-input").val('0');
            return;
        }

        $.ajax({
            url: DomainName + '/Account/GetDataWithoutAlias',
            type: 'POST',
            dataType: 'json',
            data: {
                Method: 'GetStandaradChargeRate',
                parameters: {
                    ContractId: contractId,
                    From_Lane_id: fromLaneId,
                    To_Lane_id: toLaneId,
                    Rate_Type: rateType
                }
            },
            success: function (res) {
                // Initialize all charge inputs to 0
                $(".charge-input").val('0');

                var data = res;
                if (res && res.Table) {
                    data = res.Table;
                }

                if (data && data.length > 0) {
                    $.each(data, function (i, row) {
                        var code = row.chargecode;
                        var rate = 0;
                        if (row.FTL1_TRIP_RATE !== undefined && row.FTL1_TRIP_RATE !== null) {
                            rate = row.FTL1_TRIP_RATE;
                        } else if (row.rate !== undefined && row.rate !== null) {
                            rate = row.rate;
                        }

                        if (code) {
                            var $input = $("#charge_" + code);
                            if ($input.length > 0) {
                                $input.val(rate);
                                $input.valid();
                            }
                        }
                    });
                }
            },
            error: function () {
                console.error('Failed to fetch standard charge rates.');
            }
        });
    }

    function ConsigneeValidation() {
        var Consignor_GST = $("#CustomerGST").val();
        var Consigor_GST_API = $("#userGstin").val();
        var Consignee_GST = $("#Consignee_GST").val();
        if (!Consignee_GST || Consignee_GST.trim() === "") {
            if (!_ewbConsigneeData) {
                _ewbConsigneeData = {};
            }
            if (!_ewbConsigneeData.Consignee_GST && Consignee_GST) {
                _ewbConsigneeData.Consignee_GST = Consignee_GST;
            }
            if (!_ewbConsigneeData.Consignee_Name) {
                _ewbConsigneeData.Consignee_Name = $("#Consignee_Name").val() || "";
            }
            if (!_ewbConsigneeData.Consignee_Address) {
                _ewbConsigneeData.Consignee_Address = $("#Consignee_Address").val() || "";
            }
            if (!_ewbConsigneeData.Consignee_Pincode) {
                _ewbConsigneeData.Consignee_Pincode = $("#consignee_pincode").val() || "";
            }

            var modalGst = Consignee_GST || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_GST : "") || "";
            var modalName = ($("#Consignee_Name").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Name : "") || "";
            var modalAddress = ($("#Consignee_Address").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Address : "") || "";
            var modalPincode = ($("#consignee_pincode").val()) || (_ewbConsigneeData ? _ewbConsigneeData.Consignee_Pincode : "") || "";

            var qs = "?gst=" + encodeURIComponent(modalGst) +
                     "&name=" + encodeURIComponent(modalName) +
                     "&address=" + encodeURIComponent(modalAddress) +
                     "&pincode=" + encodeURIComponent(modalPincode);

            $('#glFormModal .modal-dialog').removeClass('modal-lg').addClass('modal-xl');

            GLModal.showForm({
                title: "Add Consignee (GST Not Registered)",
                icon: "ri-truck-line",
                url: DomainName + '/Master/ConsigneeMaster' + qs
            });
            // Disable modal close controls for this particular modal
            disableModalClose();
            // Pre-fill the consignee modal form once the partial view has loaded
            prefillConsigneeModal();
            return;
        }
        var Parameters = {
            "Consignee_GST": Consignee_GST,
        }

        var strUrl = DomainName + "/Account/GetDataWithoutAlias";
        $.ajax({
            url: strUrl,
            type: 'POST',
            dataType: "json",
            async: false,
            data: {
                Method: "USP_CheckConsigneeGST",
                parameters: Parameters
            },
            success: function (data) {
                //console.log('dt', data);
                if (data && data.length > 0) {
                    if (data[0].Status == 1) {
                        // Consignee is registered successfully. Select that shipto in the dropdown.
                        var found = false;
                        $('#Consignee_Name option').each(function () {
                            if ($(this).attr('data-gst') === Consignee_GST) {
                                $('#Consignee_Name').prop('disabled', false).val($(this).val()).trigger('change').prop('disabled', true);
                                found = true;
                                return false; // break loop
                            }
                        });
                        if (!found) {
                            // If status is 1 but not found in dropdown options, add it dynamically
                            var displayName = _ewbConsigneeData.Consignee_Name || "Registered Consignee";
                            var newOpt = $('<option>', {
                                value: displayName,
                                text: displayName
                            });
                            newOpt.attr('data-gst', Consignee_GST);
                            newOpt.attr('data-address', _ewbConsigneeData.Consignee_Address || "");
                            newOpt.attr('data-city', _ewbConsigneeData.Consignee_City || "");
                            newOpt.attr('data-pincode', _ewbConsigneeData.Consignee_Pincode || "");
                            newOpt.attr('data-pan', "");
                            newOpt.attr('data-code', "");
                            $('#Consignee_Name').append(newOpt);
                            $('#Consignee_Name').prop('disabled', false).val(displayName).trigger('change').prop('disabled', true);
                        }
                    } else {
                        // Status 0: Show popup modal for adding consignee
                        // Set modal to extra large for layout side-by-side
                        $('#glFormModal .modal-dialog').removeClass('modal-lg').addClass('modal-xl');

                        // Ensure the GST from the EWayBill is always in the cache
                        if (!_ewbConsigneeData) {
                            _ewbConsigneeData = {};
                        }
