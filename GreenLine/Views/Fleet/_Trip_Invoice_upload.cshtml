    function fetchEWBData(ewbNo) {
        App.blockUI({ target: 'body', boxed: true, message: 'Fetching E-Way Bill...' });
        $.ajax({
            url: DomainName + '/Fleet/FetchEWayBillData',
            type: 'GET', data: { ewayBillNo: ewbNo },
            success: function (res) {
                App.unblockUI();
                var isSuccess = false;
                var ewbData = null;
                var errorCode = "";
                var errorMsg = "";

                // Check Shape A (results wrapper)
                var status = res.status || (res.results ? res.results.status : null);
                if (status === "Success" && res.results && typeof res.results.message === 'object') {
                    isSuccess = true;
                    ewbData = res.results.message;
                } 
                // Check Shape B (data wrapper)
                else if (res && res.data) {
                    if (res.data.status_cd === "0" || res.data.error) {
                        isSuccess = false;
                        if (res.data.error) {
                            errorCode = res.data.error.error_cd || "";
                            errorMsg = res.data.error.message || "";
                        }
                    } else {
                        isSuccess = true;
                        ewbData = res.data;
                    }
                }

                if (isSuccess && ewbData) {
                    $('#EwayBillJson').val(JSON.stringify(ewbData));
                    isEwbDataFetched = true;
                    var isValid = populateEWB(ewbData);
                    if (isValid !== false) {
                        ConsigneeValidation();
                        TosterNotification("success", "E-Way Bill Data Fetched!", "Success");
                    }
                    toggleClsHide();
                } else {
                    isEwbDataFetched = false;
                    // Extract error details from whichever shape is available
                    if (!errorCode) {
                        errorCode = res.nic_code || (res.results ? res.results.nic_code : "") || (res.data && res.data.error ? res.data.error.error_cd : "");
                    }
                    if (!errorMsg) {
                        errorMsg = (res.results && typeof res.results.message === 'string' ? res.results.message : res.message) || (res.data && res.data.error ? res.data.error.message : "") || "Failed to fetch data";
                    }

                    if (errorCode == "325") {
                        errorMsg = "E-Way Bill Number is invalid or does not exist (Error 325)";
                        $("#eway_bill_no").val("");
                    }
                    TosterNotification("error", errorMsg, "Error");
                    clearEWBData();
                }
            },
            error: function () { 
                App.unblockUI(); 
                TosterNotification('error', 'Request failed', 'Error'); 
                isEwbDataFetched = false;
                clearEWBData();
            }
        });
    }

    function populateEWB(d) {
        // Helper to check if a field is considered empty or holding a default/placeholder value
        function isFieldEmptyOrDefault(val) {
            if (val === undefined || val === null) return true;
            var s = String(val).trim();
            return s === "" || s === "0001-01-01T00:00:00";
        }

        var validityDateStr = "";
        if (isValidDateValue(d.validUpto)) {
            validityDateStr = fmtEWBDate(d.validUpto);
        } else if (isFieldEmptyOrDefault($('#eway_bill_validity').val())) {
            validityDateStr = "";
        } else {
            validityDateStr = $('#eway_bill_validity').val();
        }

        if (validityDateStr && !checkEwayBillValidity(validityDateStr)) {
            $(".clshide").hide();
            return false;
        }

        if (d.ewbNo) $('#eway_bill_no').val(d.ewbNo);

        if (isValidDateValue(d.ewayBillDate)) {
            $('#eway_bill_date').val(fmtEWBDate(d.ewayBillDate));
        } else if (isFieldEmptyOrDefault($('#eway_bill_date').val())) {
            $('#eway_bill_date').val("");
        }

        if (d.docNo) $('#invoice_no').val(d.docNo);

        if (isValidDateValue(d.docDate)) {
            $('#invoice_date').val(fmtEWBDate(d.docDate));
        } else if (isFieldEmptyOrDefault($('#invoice_date').val())) {
            $('#invoice_date').val("");
        }

        if (d.userGstin) $('#userGstin').val(d.userGstin);

        if (d.fromTrdName) {
            $('#consignor_name').val(d.fromTrdName);
        }
        if (d.fromAddr1) $('#consignor_address').val(d.fromAddr1 + (d.fromAddr2 ? ", " + d.fromAddr2 : ""));

        if (d.toTrdName) $('#Consignee_Name').prop('disabled', false).val(d.toTrdName).trigger('change').prop('disabled', true);
        if (d.toPlace) {
            $('#consignee_city').val(d.toPlace);
        }
        if (d.toPincode) {
            $('#consignee_pincode').val(d.toPincode);
        }
        if (d.toGstin) {
            $('#Consignee_GST').val(d.toGstin);
        }
        if (d.toAddr1) {
            var fullAddr = d.toAddr1 + (d.toAddr2 ? ", " + d.toAddr2 : "");
            $('#Consignee_Address').val(fullAddr);
        }
        if (d.totInvValue) $('#totInvValue').val(d.totInvValue);
        if (d.totalValue) $('#totalValue').val(d.totalValue);
        if (d.actualDist) $('#actualDist').val(d.actualDist);
        if (d.noValidDays) $('#noValidDays').val(d.noValidDays);
        if (d.fromStateCode) $('#consignor_State').val(d.fromStateCode);

        if (isValidDateValue(d.validUpto)) {
            $('#eway_bill_validity').val(fmtEWBDate(d.validUpto));
        } else if (isFieldEmptyOrDefault($('#eway_bill_validity').val())) {
            $('#eway_bill_validity').val("");
        }

        // Fields not present in EWay Bill API (Dates like lr_date, delivery_date, odn_date, obd_date, eta_date)
        // If they are currently empty or default, we assign them the default date.
        // If they already have a value (e.g. from invoice), we preserve it.
        var nonEwbDates = ["#lr_date", "#delivery_date", "#odn_date", "#obd_date", "#eta_date"];
        nonEwbDates.forEach(function (id) {
            if (isFieldEmptyOrDefault($(id).val())) {
                $(id).val("");
            }
        });

        _ewbConsigneeData = {
            Consignee_GST: d.toGstin || _ewbConsigneeData.Consignee_GST || "",
            Consignee_Name: d.toTrdName || _ewbConsigneeData.Consignee_Name || "",
            Consignee_Address: (d.toAddr1 ? (d.toAddr1 + (d.toAddr2 ? ", " + d.toAddr2 : "")) : "") || _ewbConsigneeData.Consignee_Address || "",
            Consignee_Pincode: d.toPincode || _ewbConsigneeData.Consignee_Pincode || ""
        };
    }

    function isValidDateValue(val) {
        if (val === undefined || val === null) return false;
        var s = String(val).trim().toLowerCase();
        if (s === "" || s === "null" || s === "undefined" || s === "na") return false;
        return true;
    }

    function fmtEWBDate(s) {
        if (!s) return '';
        var p = s.split(' ')[0].split('/');
        if (p.length === 3) {
            var mo = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            return p[0] + ' ' + mo[parseInt(p[1]) - 1] + ' ' + p[2];
        }
        return s;
    }

    function scanInvoiceOCR(file) {
        var fd = new FormData();
        fd.append('UploadFile', file);
        App.blockUI({ target: 'body', boxed: true, message: 'Scanning Invoice...' });
        $.ajax({
            url: DomainName + '/Fleet/ProcessInvoiceOCR',
            type: 'POST', data: fd, processData: false, contentType: false,
            success: function (res) {
                App.unblockUI();
                if (res && res.success) {
                    TosterNotification('success', 'Invoice scanned successfully', 'OCR');
                }
            },
            error: function () { App.unblockUI(); }
        });
    }

    window.onConsigneeAdded = function (response) {
        // Get city name from the modal city dropdown before it is hidden/closed
        var cityName = $('#form_consignee_modal').find('#Consignee_City option:selected').text();

        // Close the modal
        var modalEl = document.getElementById('glFormModal');
        if (modalEl) {
            var bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
            bsModal.hide();
        }

        // Add the new option to the Consignee_Name select dropdown
        var displayName = response.Consignee_Name;
        if (response.ConsigneeCode) {
            displayName += " (" + response.ConsigneeCode + ")";
        }

        var select = $('#Consignee_Name');
        var optExists = select.find('option[value="' + response.Consignee_Name + '"]').length > 0;

        if (!optExists) {
            var newOpt = $('<option>', {
                value: response.Consignee_Name,
                text: displayName
            });
            newOpt.attr('data-gst', response.Consignee_GST || "");
            newOpt.attr('data-address', response.Consignee_Address || "");
            newOpt.attr('data-city', cityName || "");
            newOpt.attr('data-pincode', response.Consignee_Pincode || "");
            newOpt.attr('data-pan', response.Consignee_PANNo || "");
            newOpt.attr('data-code', response.ConsigneeCode || "");

            select.append(newOpt);
        }

        // Select the new option and trigger change to populate hidden fields
        select.prop('disabled', false).val(response.Consignee_Name).trigger('change').prop('disabled', true);

        TosterNotification("success", "Consignee registered successfully!", "Success");
    };
