@model GreenLineDataService.ViewModel.CYGNUS_TripViewModel
@{
    var trip = Model.CTM;
}<style>
    .kpi-stat-card {
        background: var(--vz-card-bg, #fff);
        border: 1px solid var(--vz-border-color, #e9ebec);
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    .kpi-stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .kpi-icon-wrap {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }
    .bg-soft-primary { background-color: rgba(64, 81, 137, 0.1) !important; }
    .bg-soft-success { background-color: rgba(10, 179, 156, 0.1) !important; }
    .bg-soft-warning { background-color: rgba(247, 184, 75, 0.1) !important; }
    .bg-soft-danger { background-color: rgba(240, 101, 72, 0.1) !important; }
    .bg-soft-info { background-color: rgba(41, 156, 219, 0.1) !important; }

    .crew-driver-card {
        border: 1px solid var(--vz-border-color, #e9ebec);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
    }
    .crew-driver-card:hover {
        background-color: var(--vz-light, #f3f6f9);
    }

    .asset-detail-card {
        border: 1px solid var(--vz-border-color, #e9ebec);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        background-color: var(--vz-light, #f3f6f9);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        height: 100%;
        transition: all 0.2s ease;
    }
    .asset-detail-card:hover {
        border-color: var(--vz-link-color, #405189);
        background-color: var(--vz-card-bg, #fff);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
    }
    .asset-icon-wrap {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }
</style>

<!-- KPI Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card kpi-stat-card shadow-sm mb-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon-wrap bg-soft-primary text-primary">
                        <i class="ri-road-map-line"></i>
                    </div>
                    <div>
                        <h4 class="fs-18 fw-bold text-primary mb-0">@(trip.CityRouteKM) <span class="fs-12 text-muted fw-normal">KM</span></h4>
                        <p class="text-muted fs-12 mb-0">Total Distance</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card kpi-stat-card shadow-sm mb-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon-wrap bg-soft-success text-success">
                        <i class="ri-speed-up-line"></i>
                    </div>
                    <div>
                        <h4 class="fs-18 fw-bold text-success mb-0">@(trip.End_Km) <span class="fs-12 text-muted fw-normal">KM</span></h4>
                        <p class="text-muted fs-12 mb-0">Distance Covered</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card kpi-stat-card shadow-sm mb-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon-wrap bg-soft-warning text-warning">
                        <i class="ri-navigation-line"></i>
                    </div>
                    <div>
                        <h4 class="fs-18 fw-bold text-warning mb-0">0 <span class="fs-12 text-muted fw-normal">KM</span></h4>
                        <p class="text-muted fs-12 mb-0">Pending Trail</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card kpi-stat-card shadow-sm mb-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon-wrap bg-soft-danger text-danger">
                        <i class="ri-map-pin-user-line"></i>
                    </div>
                    <div class="min-w-0">
                        <h4 class="fs-15 fw-bold text-danger mb-0 text-truncate" title="@(string.IsNullOrEmpty(trip.Current_Location) ? "0" : trip.Current_Location)">
                            @(string.IsNullOrEmpty(trip.Current_Location) ? "0" : trip.Current_Location)
                        </h4>
                        <p class="text-muted fs-12 mb-0 text-truncate">Reporting ETA</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Current Operating Stage -->
<div class="row g-3">
    <div class="col-12">
        <div class="card border shadow-sm">
            <div class="card-body p-3">
                <p class="fw-semibold text-muted fs-11 mb-3">Current Operating Stage</p>
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon-wrap bg-soft-primary text-primary rounded-circle" style="width: 48px; height: 48px; font-size: 22px;">
                        <i class="ri-route-line"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark fs-16">@(string.IsNullOrEmpty(trip.EventName) ? "In Progress" : trip.EventName)</div>
                        <span class="badge bg-soft-success text-success fs-10 mt-1"><i class="ri-checkbox-circle-line align-middle"></i> Active Status</span>
                    </div>
                    <div class="ms-auto text-end">
                        <p class="text-muted fs-11 mb-1">Trip Date</p>
                        <h6 class="fw-bold text-dark mb-0">@trip.TripDate.ToString("dd MMM yyyy")</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Operations Crew + Asset Details -->
<div class="row g-3">
    <!-- Operations Crew -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header border-bottom-dashed">
                <h6 class="card-title mb-0">
                    <i class="ri-team-line text-primary me-1 align-middle fs-16"></i> Operations Crew
                </h6>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-2">
                    @if (trip.Driver1 > 0)
                    {
                        <div class="d-flex align-items-center gap-3 crew-driver-card">
                            <div class="avatar-xs bg-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px; height:32px;">
                                <i class="ri-steering-2-line text-white fs-14"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-dark fs-12 text-truncate">@trip.Driver1Name</div>
                                <div class="text-muted fs-10">Primary Driver</div>
                            </div>
                            <span class="badge bg-soft-success text-success fs-10"><i class="ri-checkbox-circle-line align-middle"></i> Verified</span>
                        </div>
                    }
                    @if (trip.Driver2 > 0)
                    {
                        <div class="d-flex align-items-center gap-3 crew-driver-card">
                            <div class="avatar-xs bg-secondary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px; height:32px;">
                                <i class="ri-steering-line text-white fs-14"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-dark fs-12 text-truncate">@trip.Driver2Name</div>
                                <div class="text-muted fs-10">Co-Driver</div>
                            </div>
                        </div>
                    }
                    @if (trip.Driver1 == 0 && trip.Driver2 == 0)
                    {
                        <div class="text-center text-muted py-4 fs-13">
                            <i class="ri-user-unfollow-line fs-28 d-block mb-2 opacity-50 text-warning"></i> No crew assigned to this trip
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Asset Details -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header border-bottom-dashed">
                <h6 class="card-title mb-0">
                    <i class="ri-truck-line text-primary me-1 align-middle fs-16"></i> Asset Details
                </h6>
            </div>
            <div class="card-body p-3">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="asset-detail-card">
                            <div class="asset-icon-wrap bg-soft-primary text-primary">
                                <i class="ri-caravan-line"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fs-10 text-muted fw-semibold mb-0">Trailer Ref.</div>
                                <div class="fw-bold text-dark fs-12 text-truncate" title="@(string.IsNullOrEmpty(trip.TrailerNo) ? "-" : trip.TrailerNo)">
                                    @(string.IsNullOrEmpty(trip.TrailerNo) ? "-" : trip.TrailerNo)
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="asset-detail-card">
                            <div class="asset-icon-wrap bg-soft-success text-success">
                                <i class="ri-dashboard-3-line"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fs-10 text-muted fw-semibold mb-0">Start KM</div>
                                <div class="fw-bold text-dark fs-12 text-truncate">
                                    @(trip.Start_Km.ToString("F2"))
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="asset-detail-card">
                            <div class="asset-icon-wrap bg-soft-warning text-warning">
                                <i class="ri-shield-user-line"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fs-10 text-muted fw-semibold mb-0">Market / Own</div>
                                <div class="fw-bold text-dark fs-12 text-truncate">
                                    @(string.IsNullOrEmpty(trip.Market_Own) ? "-" : trip.Market_Own)
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="asset-detail-card">
                            <div class="asset-icon-wrap bg-soft-danger text-danger">
                                <i class="ri-price-tag-3-line"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fs-10 text-muted fw-semibold mb-0">Category</div>
                                <div class="fw-bold text-dark fs-12 text-truncate" title="@(string.IsNullOrEmpty(trip.Category) ? "-" : trip.Category)">
                                    @(string.IsNullOrEmpty(trip.Category) ? "-" : trip.Category)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
