@model GreenLineDataService.ViewModel.CYGNUS_TripViewModel
@using GreenLineDataService.Models
@{
    ViewBag.Title = "Trip Operations";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var trip = Model.CTM;
    string activeTab = ViewBag.ActiveTab ?? "overview";
}
<script type="text/javascript">
    sessionStorage.setItem('data-sidebar-size', 'sm');
    document.documentElement.setAttribute('data-sidebar-size', 'sm');

    window.addEventListener('beforeunload', function () {
        sessionStorage.setItem('data-sidebar-size', 'lg');
    });
</script>

<style>
    /* ── Layout ─────────────────────────────────────────── */
    .trip-op-layout { display: flex; gap: 0; min-height: calc(100vh - 160px); }

    /* ── Sidebar ─────────────────────────────────────────── */
    .trip-op-sidebar-wrap {
        width: 244px;
        flex-shrink: 0;
        background: var(--vz-card-bg, #fff);
        border-right: 1px solid var(--vz-border-color, #e9ebec);
        border-radius: 10px 0 0 10px;
        box-shadow: 2px 0 10px rgba(var(--vz-primary-rgb, 64 81 137) / .07);
        position: sticky;
        top: 70px;
        align-self: flex-start;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    /* Header gradient uses theme primary → success */
    .sidebar-trip-header {
        background: linear-gradient(135deg, var(--vz-primary, #405189) 0%, var(--vz-success, #0ab39c) 100%);
        color: #fff;
        border-radius: 10px 0 0 0;
    }
    .sidebar-trip-header .fw-bold { color: #fff; }
    .sidebar-trip-header .text-muted { color: rgba(255,255,255,.75) !important; }
    .sidebar-trip-header .badge { font-size: 0.68rem; background: rgba(255,255,255,.18) !important; color: #fff !important; }

    /* ── Nav Links ──────────────────────────────────────── */
    .trip-tab-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 8px;
        color: var(--vz-body-color, #495057);
        font-size: 0.84rem;
        font-weight: 500;
        text-decoration: none;
        transition: background .15s, color .15s;
        width: 100%;
    }
    .trip-tab-link i { font-size: 16px; flex-shrink: 0; width: 18px; color: var(--vz-text-muted, #878a99); }
    .trip-tab-link:hover { background: var(--vz-light, #f3f6f9); color: var(--vz-primary, #405189); }
    .trip-tab-link:hover i { color: var(--vz-primary, #405189); }
    .trip-tab-link.active { background: var(--vz-primary, #405189); color: #fff; font-weight: 600; }
    .trip-tab-link.active i { color: rgba(255,255,255,.9); }
    .trip-tab-link.active .tab-badge { background: rgba(255,255,255,.22); color: #fff; }

    .tab-badge {
        background: var(--vz-light, #f3f6f9);
        color: var(--vz-text-muted, #878a99);
        font-size: 0.68rem;
        font-weight: 700;
        border-radius: 10px;
        padding: 1px 7px;
        min-width: 20px;
        text-align: center;
        border: 1px solid var(--vz-border-color, #e9ebec);
    }
    .sidebar-section-label { padding: 10px 14px 2px; }
    .sidebar-section-label span { font-size: 0.67rem; letter-spacing: 0.09em; color: var(--vz-text-muted, #878a99); font-weight: 700; }

    /* ── Content Area ───────────────────────────────────── */
    .trip-op-content {
        flex: 1;
        background: var(--vz-body-bg, #f3f6f9);
        border-radius: 0 10px 10px 0;
        min-width: 0;
    }
    .trip-op-content-inner { padding: 20px; }

    /* ── Header Bar ─────────────────────────────────────── */
    .trip-op-topbar {
        background: var(--vz-card-bg, #fff);
        border-bottom: 1px solid var(--vz-border-color, #e9ebec);
        padding: 12px 20px;
        border-radius: 0 10px 0 0;
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .trip-status-badge { font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; }

    /* ── Tab Panes ──────────────────────────────────────── */
    .trip-tab-pane { display: none; }
    .trip-tab-pane.active { display: block; }

    /* ── Overview KPI Cards ──────────────────────────────── */
    .overview-stat-card {
        background: var(--vz-card-bg, #fff);
        border-radius: 12px;
        border: 1px solid var(--vz-border-color, #e9ebec);
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        transition: box-shadow .2s, transform .15s;
    }
    .overview-stat-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.08); transform: translateY(-2px); }
    .stat-icon-wrap {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 10px;
    }
    .stat-icon-wrap i { font-size: 22px; }

    /* ── LR / Consignment Cards ─────────────────────────── */
    .lr-card { border-radius: 10px; transition: box-shadow .2s; }
    .lr-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.1) !important; }

    /* ── Crew card ──────────────────────────────────────── */
    .crew-card { transition: box-shadow .2s; }

    /* ── Incident btn active ────────────────────────────── */
    .incident-btn.active { background-color: var(--vz-danger, #f06548) !important; color: #fff !important; border-color: var(--vz-danger, #f06548) !important; }

    /* ── Asset dark card ────────────────────────────────── */
    .asset-dark-card {
        background: linear-gradient(135deg, var(--vz-primary, #405189) 0%, #2c3a6e 100%);
        border-radius: 10px;
    }
    .asset-dark-card .card-header { border-bottom: 1px solid rgba(255,255,255,.12) !important; }
    .asset-dark-card .card-title { color: rgba(255,255,255,.85) !important; }
    .asset-dark-card .fs-10 { color: rgba(255,255,255,.5) !important; }
    .asset-dark-card .fw-semibold { color: rgba(255,255,255,.92) !important; }

    /* Scrollbar */
    .trip-op-sidebar-wrap::-webkit-scrollbar { width: 4px; }
    .trip-op-sidebar-wrap::-webkit-scrollbar-thumb { background: var(--vz-border-color, #dee2e6); border-radius: 4px; }
</style>

<!-- Page Title -->
<div class="page-title-box d-sm-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-sm-0">Trip Operations</h4>
    <div class="page-title-right">
        <ol class="breadcrumb m-0 shadow-none bg-transparent">
            <li class="breadcrumb-item"><a href="@Url.Action("TripList","Fleet")">Fleet</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("TripList","Fleet")">Trip List</a></li>
            <li class="breadcrumb-item active">@trip.TripNo</li>
        </ol>
    </div>
</div>

<!-- Main Layout -->
<div class="trip-op-layout">

    <!-- ── Sidebar ── -->
    <div class="trip-op-sidebar-wrap">
        @Html.Partial("_TripOperationMenu", Model)
    </div>

    <!-- ── Content ── -->
    <div class="trip-op-content">
        <!-- Top Bar -->
        <div class="trip-op-topbar">
            <div class="d-flex align-items-center gap-2">
                <span class="trip-status-badge @(trip.TType == "I" ? "bg-soft-secondary text-secondary" : "bg-soft-success text-success")">
                    @(trip.TType == "I" ? "Not Started" : "Active")
                </span>
                <span class="fw-bold text-dark fs-15">@trip.TripNo</span>
                <span >-</span>
                <span class="text-muted fs-13">@trip.VehicleNo</span>
            </div>
            <div class="d-flex align-items-center gap-2 ms-3">
                @if (!string.IsNullOrEmpty(trip.Start_City_name))
                {
                    <span class="badge bg-soft-success text-success rounded-pill fs-11">
                        <i class="ri-map-pin-line me-1"></i>@trip.Start_City_name
                    </span>
                }
                @if (!string.IsNullOrEmpty(trip.Start_City_name) && !string.IsNullOrEmpty(trip.End_City_name))
                {
                    <i class="ri-arrow-right-line text-muted"></i>
                }
                @if (!string.IsNullOrEmpty(trip.End_City_name))
                {
                    <span class="badge bg-soft-danger text-danger rounded-pill fs-11">
                        <i class="ri-map-pin-2-line me-1"></i>@trip.End_City_name
                    </span>
                }
            </div>
            <div class="ms-auto d-flex align-items-center gap-2">
                <small class="text-muted fs-12">
                    <i class="ri-calendar-event-line me-1"></i>@trip.TripDate.ToString("dd MMM yyyy")
                </small>
                @if (!string.IsNullOrEmpty(trip.PRNo))
                {
                    <span class="badge bg-soft-primary text-primary fs-11">PR: @trip.PRNo</span>
                }
            </div>
        </div>

        <!-- Tab Panes -->
        <div class="trip-op-content-inner">
            <div id="pane-overview" class="trip-tab-pane @(activeTab == "overview" ? "active" : "")">
                @Html.Partial("_Trip_Operation_overview", Model)
            </div>

            <div id="pane-dispatch" class="trip-tab-pane @(activeTab == "dispatch" ? "active" : "")">
                @Html.Partial("_Trip_InvoiceList", Model)
            </div>

            <div id="pane-expenses" class="trip-tab-pane @(activeTab == "expenses" ? "active" : "")">
                @Html.Partial("_Trip_Operation_Expence", Model)
            </div>

            <div id="pane-driverchange" class="trip-tab-pane @(activeTab == "driverchange" ? "active" : "")">
                @Html.Partial("_Trip_Operation_Driverchange", Model)
            </div>

            <div id="pane-contactPage" class="trip-tab-pane @(activeTab == "contactPage" ? "active" : "")">
                @Html.Partial("_Trip_Contact", Model)
            </div>

            <div id="pane-tripevents" class="trip-tab-pane @(activeTab == "tripevents" ? "active" : "")">
                @Html.Partial("_Trip_Events", Model)
            </div>

            <div id="pane-vehicleevents" class="trip-tab-pane @(activeTab == "vehicleevents" ? "active" : "")">
                @Html.Partial("_Trip_VehicleEvents", Model)
            </div>

            <div id="pane-notes" class="trip-tab-pane @(activeTab == "notes" ? "active" : "")">
                @Html.Partial("_Trip_Notes", Model)
            </div>

            <div id="pane-timeline" class="trip-tab-pane @(activeTab == "timeline" ? "active" : "")">
                @Html.Partial("_Trip_Timeline", Model)
            </div>

        </div>
    </div>
</div>

@section scripts {
<script type="text/javascript">
    var FormComponents = function () {

        // ── Inner: lazy tab script initializer ────────────────
        var _initializedTabs = {};
        var InitTabScripts = function (tab) {
            if (_initializedTabs[tab]) return;
            _initializedTabs[tab] = true;
            switch (tab) {
                case 'dispatch':
                    if (typeof initInvoiceListTab   === 'function') initInvoiceListTab();
                    if (typeof initInvoiceUploadTab === 'function') initInvoiceUploadTab();
                    break;
                case 'expenses':
                    if (typeof initExpenseTab       === 'function') initExpenseTab();      break;
                case 'driverchange':
                    if (typeof initDriverChangeTab  === 'function') initDriverChangeTab(); break;
                case 'contactPage':
                    if (typeof initContactListTab === 'function') initContactListTab(); break;
                case 'tripevents':
                    if (typeof initEventsTab        === 'function') initEventsTab();       break;
                case 'vehicleevents':
                    if (typeof initVehicleEventsTab === 'function') initVehicleEventsTab();break;
                case 'notes':
                    if (typeof initNotesTab         === 'function') initNotesTab();        break;
                case 'timeline':
                    if (typeof initTimelineTab === 'function') initTimelineTab(); break;
            }
        };

        // ── Inner: wire up sidebar tab switching ──────────────
        var SetupTabSwitch = function (DomainName) {
            $(document).on('click', '.trip-tab-link', function () {
                var tab = $(this).data('tab');
                if (!tab) return;
                $('.trip-tab-link').removeClass('active');
                $(this).addClass('active');
                $('.trip-tab-pane').removeClass('active');
                $('#pane-' + tab).addClass('active');
                $('.trip-op-content-inner').scrollTop(0);
                InitTabScripts(tab);
            });
        };

        return {
            init: function (DomainName) {
                SetupTabSwitch(DomainName);

                // Boot the default active tab on page load
                var activeTab = '@activeTab';
                InitTabScripts(activeTab);

                // Always initialize tripevents to register global upload modal handlers
                InitTabScripts('tripevents');
                

                // ── TempData toasts ────────────────────────────
                @if (TempData["SuccessMessage"] != null) {
                    <text>TosterNotification('success', '@Html.Raw(TempData["SuccessMessage"].ToString().Replace("'","\\\'"))', 'Success');</text>
                }
                @if (TempData["ErrorMessage"] != null) {
                    <text>TosterNotification('error', '@Html.Raw(TempData["ErrorMessage"].ToString().Replace("'","\\\'"))', 'Error');</text>
                }
            }
        };
    }();

    $(document).ready(function () {
        FormComponents.init(DomainName);
    });
</script>
}
