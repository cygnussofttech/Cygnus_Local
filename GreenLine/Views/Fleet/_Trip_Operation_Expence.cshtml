    function loadTripExpLedger() {
        $.ajax({
            url: DomainName + '/Fleet/GetTripExpenses',
            type: 'GET', dataType: 'json',
            data: { TripNo: '@trip.TripNo' },
            success: function (res) {
                var data = (res && res.Status) ? res.Data : [];
                if (!data || !data.length) {
                    var emptyRow = '<tr><td colspan="5" class="text-center text-muted py-3">No data available</td></tr>';
                    $('#tripExpLedger').html(emptyRow);
                    $('#tripExpTotal').text('INR 0.00');
                    $('#tripExpCount').text('0 entries');
                    return;
                }
                var paymentMap = { 'O': 'Online', 'C': 'Cash', 'P': 'To Be Paid' };
                var total = 0, rows = '';
                $.each(data, function (i, e) {
                    total += parseFloat(e.Amount_Spent || 0);
                    var docCell = e.DocPath
                        ? '<a href="' + DomainName + e.DocPath + '" target="_blank" class="btn-doc-view">View</a>'
                        : '-';
                    var billedText = e.IsBilled ? 'Yes' : 'No';
                    var payLabel = paymentMap[e.PymentType] || e.PymentType || '-';
                    rows += '<tr>'
                        + '<td class="fw-semibold">' + (e.ExpenseName || e.id || '-') + '</td>'
                        + '<td class="text-end fw-bold">' + parseFloat(e.Amount_Spent || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) + '</td>'
                        + '<td class="text-center">' + billedText + '</td>'
                        + '<td class="text-center">' + payLabel + '</td>'
                        + '<td class="text-center">' + docCell + '</td>'
                        + '</tr>';
                });
                $('#tripExpLedger').html(rows);
                $('#tripExpTotal').text('INR ' + total.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
                var countText = data.length + ' ' + (data.length === 1 ? 'entry' : 'entries');
                $('#tripExpCount').text(countText);
            },
            error: function () {}
        });
    }

    function loadLRExpList(force) {
        if (!force && $('#lrExpList .lr-exp-card').length) return;
        $.ajax({
            url: DomainName + '/Account/GetDataWithoutAlias',
            type: 'POST', dataType: 'json',
            data: { Method: 'USP_GetLRListByTrip', parameters: { TripNo: '@trip.TripNo', PRNo: '@trip.PRNo' } },
            success: function (data) {
                if (!data || !data.length) {
                    $('#lrExpList').html('<div class="text-center text-muted py-5 fs-13"><i class="ri-file-list-3-line fs-1 opacity-50 d-block mb-2"></i> No LR entries found for this trip.</div>');
                    return;
                }
                var html = '';
                $.each(data, function (i, lr) {
                    var lrNo   = lr.LR_No || ('LR-' + (i + 1));
                    var custLR = lr.CustLRNo || '';
                    html += '<div class="lr-exp-card border rounded p-2 mb-2 d-flex align-items-center gap-2" data-lr="' + lrNo + '" style="cursor:pointer;">'
                        + '<i class="ri-file-paper-line text-primary fs-16 flex-shrink-0"></i>'
                        + '<div class="flex-grow-1">'
                        + '<div class="fw-semibold fs-13 text-dark">' + lrNo + '</div>'
                        + (custLR ? '<div class="fs-11 text-muted">' + custLR + '</div>' : '')
                        + '<div class="fs-11 text-muted">' + (lr.Consignee_Name || lr.consignee_name || '') + (lr.Consignee_City ? ' &bull; ' + lr.Consignee_City : '') + '</div>'
                        + '<div class="fs-11 text-muted">Wt: ' + (lr.net_weight || 0) + ' | &#x20B9;' + parseFloat(lr.Total || 0).toLocaleString('en-IN') + '</div>'
                        + '</div>'
                        + '<button type="button" class="btn btn-soft-primary btn-sm btnSelectLRExp flex-shrink-0" data-lr="' + lrNo + '" data-custlr="' + custLR + '" style="width:30px;height:30px;padding:0;"><i class="ri-add-line fs-14"></i></button>'
                        + '</div>';
                });
                $('#lrExpList').html(html);
                $('#lrExpCount').text(data.length);
            },
            error: function () {
                $('#lrExpList').html('<div class="text-center text-muted py-4 fs-13">Failed to load LR list.</div>');
            }
        });
    }

    function loadLRExpLedger(lrNo) {
        if (!lrNo) return;
        var tbody = $('#lrExpLedgerBody');
        tbody.html('<tr><td colspan="7" class="text-center text-muted py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Loading...</td></tr>');
        $.ajax({
            url: DomainName + '/Account/GetDataWithoutAlias',
            type: 'POST',
            dataType: 'json',
            data: { Method: 'USP_Get_Docket_Expense', parameters: { DockNo: lrNo } },
            success: function (data) {
                tbody.empty();
                if (!data || !data.length) {
                    tbody.html('<tr><td colspan="7" class="text-center text-muted py-3">No expenses logged yet.</td></tr>');
                    return;
                }
                var paymentMap = { 'O': 'Online', 'C': 'Cash', 'P': 'To Be Paid' };
                $.each(data, function (i, val) {
                    var id = val.ChargeCode || val.chargecode || '';
                    var amount = val.Amount || val.amount || 0;
                    var payment = val.PaymentType || val.paymenttype || '';
                    var billed = val.IsBillable || val.isbillable || 'N';
                    var recordId = val.Id || val.id || '0';
                    var docPath = val.Attachment || val.attachment || '';
                    
                    var expenseItem = (lrExpList || []).find(function(item) {
                        return item.CodeId == id;
                    });
                    var catName = expenseItem ? expenseItem.CodeDesc : id;

                    var isBilled = (billed === 'Y' || billed === 'true' || billed === true || billed === '1' || billed === 1);
                    var billedText = isBilled 
                        ? '<span class="badge bg-soft-success text-success fs-11">Yes</span>' 
                        : '<span class="badge bg-soft-danger text-danger fs-11">No</span>';

                    var docCell = docPath
                        ? '<a href="' + DomainName + docPath + '" target="_blank" class="btn btn-sm btn-soft-info py-0 px-2 fs-11"><i class="ri-attachment-2"></i> View</a>'
                        : '-';

                    var actionCell = '<button type="button" class="btn btn-soft-warning btn-sm btnEditLRExp py-0 px-2 fs-11" '
                        + 'data-id="' + id + '" '
                        + 'data-amount="' + amount + '" '
                        + 'data-payment="' + payment + '" '
                        + 'data-billed="' + (isBilled ? 'true' : 'false') + '" '
                        + 'data-recordid="' + recordId + '" '
                        + 'data-docpath="' + docPath + '">'
                        + '<i class="ri-pencil-fill me-1"></i>Edit</button>';

                    var payLabel = paymentMap[payment] || payment || '-';

                    tbody.append('<tr>'
                        + '<td class="fs-12">' + lrNo + '</td>'
                        + '<td class="fs-12">' + catName + '</td>'
                        + '<td class="fs-12 text-end fw-semibold">&#x20B9;' + parseFloat(amount).toFixed(2) + '</td>'
                        + '<td class="fs-12 text-center">' + billedText + '</td>'
                        + '<td class="fs-12 text-center">' + payLabel + '</td>'
                        + '<td class="fs-12 text-center">' + docCell + '</td>'
                        + '<td class="fs-12 text-center">' + actionCell + '</td>'
                        + '</tr>');
                });
            },
            error: function () {
                tbody.html('<tr><td colspan="7" class="text-center text-danger py-3">Failed to load expenses.</td></tr>');
            }
        });
    }

    function appendLRExpLedger(lrNo, catName, amt, payName, isBilled, docPath, catId, payVal, recordId) {
        var tbody = $('#lrExpLedgerBody');
        if (tbody.find('td[colspan]').length) tbody.empty();
        var billedText = isBilled 
            ? '<span class="badge bg-soft-success text-success fs-11">Yes</span>' 
            : '<span class="badge bg-soft-danger text-danger fs-11">No</span>';
        var docCell = docPath
            ? '<a href="' + DomainName + docPath + '" target="_blank" class="btn btn-sm btn-soft-info py-0 px-2 fs-11"><i class="ri-attachment-2"></i> View</a>'
            : '-';
        var actionCell = '<button type="button" class="btn btn-soft-warning btn-sm btnEditLRExp py-0 px-2 fs-11" '
            + 'data-id="' + (catId || '') + '" '
            + 'data-amount="' + (amt || '') + '" '
            + 'data-payment="' + (payVal || '') + '" '
            + 'data-billed="' + (isBilled ? 'true' : 'false') + '" '
            + 'data-recordid="' + (recordId || '0') + '" '
            + 'data-docpath="' + (docPath || '') + '">'
            + '<i class="ri-pencil-fill me-1"></i>Edit</button>';

        tbody.append('<tr>'
            + '<td class="fs-12">' + lrNo + '</td>'
            + '<td class="fs-12">' + catName + '</td>'
            + '<td class="fs-12 text-end fw-semibold">&#x20B9;' + parseFloat(amt).toFixed(2) + '</td>'
            + '<td class="fs-12 text-center">' + billedText + '</td>'
            + '<td class="fs-12 text-center">' + payName + '</td>'
            + '<td class="fs-12 text-center">' + docCell + '</td>'
            + '<td class="fs-12 text-center">' + actionCell + '</td>'
            + '</tr>');
    }
</script>
