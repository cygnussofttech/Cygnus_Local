<form id="frmCommonUpload" onsubmit="return false;" class="form-modern-ui">
    <div class="p-1">
        <div class="row">
            <div class="col-md-6" id="modalFileUploadWrapper">
                <div class="form-group mb-3">
                    <label class="form-label required-label" id="modalFileLabel">File Upload</label>
                    <input type="file" id="modalEvtFile" name="evtFile" class="form-control required" accept="image/*,application/pdf" />
                </div>
            </div>
            <div class="col-md-6" id="modalFileBackUploadWrapper" style="display: none;">
                <div class="form-group mb-3">
                    <label class="form-label" id="modalFileBackLabel">Back POD Upload</label>
                    <input type="file" id="modalEvtFileBack" name="evtFileBack" class="form-control" accept="image/*,application/pdf" />
                </div>
            </div>
            <div class="col-md-3" id="modalPiecesWrapper">
                <div class="form-group mb-3">
                    <label class="form-label required-label" id="modalPiecesLabel">Pieces</label>
                    <input type="number" id="modalEvtPieces" name="Pieces" class="form-control required" placeholder="Pieces" min="0" step="1" />
                </div>
            </div>
            <div class="col-md-3" id="modalQtyWrapper">
                <div class="form-group mb-3">
                    <label class="form-label required-label" id="modalQtyLabel">Qty</label>
                    <input type="number" id="modalEvtQty" name="Qty" class="form-control required" placeholder="Qty" min="0" step="0.01" />
                </div>
            </div>
            <div class="col-md-12">
                <div class="form-group mb-0">
                    <label class="form-label required-label" id="modalRemarksLabel">Remarks / Notes</label>
                    <textarea id="modalEvtRemarks" name="evtRemarks" class="form-control required" rows="3" placeholder="Enter Remark/Notes..."></textarea>
                </div>
            </div>
        </div>
    </div>
</form>

<script type="text/javascript">
    function setupUploadModalForm(isDO, isPOD) {
        var formUpload = $('#glFormContent #frmCommonUpload');
        if (formUpload.length === 0) return;

        if (isDO) {
            // DO Mode:
            // 1. File Upload not required, reset label
            $('#glFormContent #modalFileLabel').text('File Upload').removeClass('required-label');
            $('#glFormContent #modalEvtFile').removeClass('required');
            
            // Hide Back Upload
            $('#glFormContent #modalFileBackUploadWrapper').hide();
            $('#glFormContent #modalEvtFileBack').removeClass('required');

            // 2. Remarks are required
            $('#glFormContent #modalRemarksLabel').addClass('required-label');
            $('#glFormContent #modalEvtRemarks').addClass('required');

            // 3. Hide Pieces and Qty
            $('#glFormContent #modalPiecesWrapper').hide();
            $('#glFormContent #modalQtyWrapper').hide();
            $('#glFormContent #modalEvtPieces').removeClass('required');
            $('#glFormContent #modalEvtQty').removeClass('required');            
        }
        else if (isPOD) {
            // POD Mode:
            // 1. Front File Upload is required, change label
            $('#glFormContent #modalFileLabel').text('Front POD Upload').addClass('required-label');
            $('#glFormContent #modalEvtFile').addClass('required');

            // 2. Show Back File Upload (optional)
            $('#glFormContent #modalFileBackUploadWrapper').show();
            $('#glFormContent #modalFileBackLabel').text('Back POD Upload').removeClass('required-label');
            $('#glFormContent #modalEvtFileBack').removeClass('required');

            // 3. Remarks are not required
            $('#glFormContent #modalRemarksLabel').removeClass('required-label');
            $('#glFormContent #modalEvtRemarks').removeClass('required');

            // 4. Show Pieces and Qty and make them required
            $('#glFormContent #modalPiecesWrapper').show();
            $('#glFormContent #modalQtyWrapper').show();
            $('#glFormContent #modalEvtPieces').addClass('required');
            $('#glFormContent #modalEvtQty').addClass('required');            
        }

        // Initialize Validation after DOM structure/classes are updated
        formUpload.validate({
            doNotHideMessage: true,
            errorElement: 'span',
            errorClass: 'help-block',
            focusInvalid: false,
            ignore: ":hidden", // Ignores hidden elements
            rules: {},
            messages: {},
            errorPlacement: function (error, element) {
                if (element.parent(".input-group").length > 0) {
                    error.insertAfter(element.parent(".input-group"));
                } else {
                    error.insertAfter(element);
                }
            },
            highlight: function (element) {
                $(element).closest('.form-group').addClass('has-error');
            },
            unhighlight: function (element) {
                $(element).closest('.form-group').removeClass('has-error');
            },
            success: function (label) {
                label.closest('.form-group').removeClass('has-error');
            }
        });

        // Trigger instant validation updates on input change or typing to clear error styling immediately
        $('#glFormContent #modalEvtFile').off('change').on('change', function () {
            var file = this.files[0];
            if (file) {
                if (!validateImageFile(file, this)) return;
            }
            formUpload.validate().element($(this));
        });

        $('#glFormContent #modalEvtFileBack').off('change').on('change', function () {
            formUpload.validate().element($(this));
        });

        $('#glFormContent #modalEvtRemarks').off('keyup change').on('keyup change', function () {
            formUpload.validate().element($(this));
        });

        $('#glFormContent #modalEvtPieces').off('keyup change').on('keyup change', function () {
            formUpload.validate().element($(this));
        });

        $('#glFormContent #modalEvtQty').off('keyup change').on('keyup change', function () {
            formUpload.validate().element($(this));
        });
    }
</script>
