@model GreenLineDataService.Models.CYGNUS_PickUp_Request

@{
    ViewBag.Title = "PR Approve/Reject";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .pr-card-item {
        border: 1px solid #e9ebec !important;
        border-radius: 8px;
        transition: all 0.2s ease-in-out;
        background-color: #ffffff;
    }
    .pr-card-item:hover {
        border-color: #adb5bd !important;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.04) !important;
        transform: translateY(-1px);
    }
    .pr-card-item.active-card {
        border-color: #405189 !important;
        border-width: 1.5px !important;
        background-color: rgba(64, 81, 137, 0.03) !important;
        box-shadow: 0 4px 12px rgba(64, 81, 137, 0.08) !important;
    }
    .pr-list-pipeline {
        max-height: 650px;
        overflow-y: auto;
        padding: 10px 5px 10px 10px;
    }
    /* Style scrollbar for modern feel */
    .pr-list-pipeline::-webkit-scrollbar {
        width: 5px;
    }
    .pr-list-pipeline::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    .pr-list-pipeline::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
    .pr-list-pipeline::-webkit-scrollbar-thumb:hover {
        background: #999;
    }
    
    .font-size-11 { font-size: 11px !important; }
    .font-size-12 { font-size: 12px !important; }
    .font-size-13 { font-size: 13px !important; }
    .font-size-14 { font-size: 14px !important; }
    .font-size-18 { font-size: 18px !important; }
    
    .bg-soft-primary { background-color: rgba(64, 81, 137, 0.1) !important; }
    .bg-soft-warning { background-color: rgba(247, 184, 75, 0.1) !important; }
    .bg-success-subtle { background-color: rgba(10, 179, 156, 0.1) !important; }
    .bg-secondary-subtle { background-color: rgba(140, 150, 160, 0.1) !important; }
    
    .text-wrap {
        white-space: normal !important;
    }
</style>

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">PR Approve / Reject</h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0 shadow-none bg-transparent">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Fleet</a></li>
                    <li class="breadcrumb-item active">Approve / Reject Spot PR</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<!-- end page title -->

<div class="row pt-2 pb-3" id="mainContainer">
    <!-- Left Pane: Spot PickUp Request Pipeline Cards -->
    <div class="col-xl-4 col-lg-12">
        <div class="card shadow-sm border-0 mb-4 mb-xl-0">
            <div class="card-header border-bottom-dashed py-3 d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0 flex-grow-1">
                    <i class="ri-list-check me-1 align-bottom text-primary" style="color: #405189 !important;"></i> Spot PickupRequest
                </h5>
                <span class="badge bg-soft-primary text-primary rounded-pill px-2 py-1 font-size-11">@Model.listCPR.Count Pending</span>
            </div>
            <div class="card-body p-0">
                <div class="pr-list-pipeline">
                    @foreach (var item in Model.listCPR)
                    {
                        string CardId = "CARD_" + item.PRNo.ToString();
                        <div id="@CardId" class="card pr-card-item border mb-3 cursor-pointer shadow-none" data-prno="@item.PRNo" style="cursor: pointer; border-radius: 8px; transition: all 0.2s ease;">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="text-primary fw-bold font-size-13 text-uppercase">@item.PRNo</span>
                                    <span class="rounded-circle" style="width: 8px; height: 8px; background-color: #f7b84b;"></span> <!-- Yellow Dot -->
                                </div>
                                <h6 class="fw-bold text-dark text-uppercase mb-2 font-size-13">@item.Customer</h6>
                                <div class="d-flex align-items-center justify-content-between font-size-12 text-muted">
                                    <span>
                                        <i class="ri-map-pin-line me-1"></i> @item.From_Lane - @item.To_Lane
                                    </span>
                                    @*<span class="fw-bold text-dark font-size-13">
                                        &#8377; @(item.Freight.ToString("N2"))
                                    </span>*@
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Right Pane: Premium Detail View Card -->
    <div class="col-xl-8 col-lg-12">
        <div class="card shadow-sm border-0" id="detailsPaneContainer" style="min-height: 480px;">
            <!-- Placeholder -->
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-5" id="detailsPlaceholder" style="min-height: 480px;">
                <div class="avatar-lg bg-soft-primary text-primary rounded-circle mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="ri-article-line display-4 text-primary" style="font-size: 2.5rem; color: #405189 !important;"></i>
                </div>
                <h5 class="fw-bold">No Request Selected</h5>
                <p class="text-muted" style="max-width: 350px;">Select a Spot Pickup Request from the left pipeline to audit route details, trip margins, and enroute expenses.</p>
            </div>

            <!-- Loader (Hidden by default) -->
            <div class="card-body d-none flex-column align-items-center justify-content-center text-center p-5" id="detailsLoader" style="min-height: 480px;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: #405189 !important;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h5 class="mt-4 fw-bold">Fetching Commercial Data...</h5>
                <p class="text-muted">Analyzing route compliance and loading enroute expense audits.</p>
            </div>

            <!-- Content Area (Hidden by default) -->
            <div id="detailsContent" class="d-none">
                <input type="hidden" id="hdnAdvancedInstance" />
                <input type="hidden" id="hdnAdvancedPercentage" />
                <input type="hidden" id="hdnFreight" />
                <!-- Header (Themed Light Layout) -->
                <div class="card-header border-bottom-dashed p-3 d-flex align-items-center justify-content-between rounded-top bg-white">
                    <div>
                        <h4 class="mb-0 fw-bold mt-1" style="color: #405189;" id="detCustomerName">CUSTOMER NAME</h4>
                        <div class="text-muted mt-1 font-size-13">
                            <span class="me-3"><i class="ri-file-text-line me-1"></i> <strong id="detPRNo">PR2026...</strong></span>
                            <span><i class="ri-user-shared-line me-1"></i> Group: <strong id="detCustomerGroup">greenline</strong></span>
                        </div>
                    </div>
                    <div>
                        <span class="badge bg-warning-subtle text-warning fs-13 py-2 px-3 fw-bold rounded-pill text-uppercase">Pending Approval</span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <!-- Operational Route Card -->
                    <div class="mb-4">
                        <h6 class="text-uppercase fw-bold text-muted mb-3 font-size-12" style="letter-spacing: 0.5px;">Operational Route</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 rounded bg-light border border-dashed h-100">
                                    <div class="text-muted font-size-12 mb-1"><i class="ri-map-pin-user-line text-success me-1"></i> Pickup Location & Lane</div>
                                    <h6 class="fw-bold mb-1" id="detFromLane">From Lane</h6>
                                    <p class="text-muted font-size-13 mb-0" id="detPickupAddress">Pickup Address Description</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 rounded bg-light border border-dashed h-100">
                                    <div class="text-muted font-size-12 mb-1"><i class="ri-map-pin-5-line text-danger me-1"></i> Destination & Drop Location</div>
                                    <h6 class="fw-bold mb-1" id="detToLane">To Lane</h6>
                                    <p class="text-muted font-size-13 mb-0" id="detDropLocation">Drop Location Description</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Metrics Row -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 rounded text-center" style="background-color: #f3f6f9; border: 1px solid #e9ebec;">
                                <div class="text-muted font-size-12 mb-1">TOTAL DISTANCE</div>
                                <h4 class="fw-bold mb-0 text-primary" style="color: #405189 !important;"><span id="detTotalKMs">0.00</span> <span class="font-size-12 text-muted">KM</span></h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded text-center" style="background-color: #f3f6f9; border: 1px solid #e9ebec;">
                                <div class="text-muted font-size-12 mb-1">WEIGHT CLASS</div>
                                <h4 class="fw-bold mb-0 text-dark"><span id="detWeight">0.00</span> <span class="font-size-12 text-muted">TONNE</span></h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 rounded text-center" style="background-color: #f3f6f9; border: 1px solid #e9ebec;">
                                <div class="text-muted font-size-12 mb-1">MATERIAL TYPE</div>
                                <h4 class="fw-bold mb-0 text-info font-size-14 text-uppercase" id="detMaterial">-</h4>
                            </div>
                        </div>
                    </div>

                    <!-- Yield Panel (Light Theme) -->
                    <div class="mb-4">
                        <div class="p-4 rounded border" style="background-color: #f8f9fa; border: 1px solid #e9ebec;">
                            <div class="row align-items-center">
                                <div class="col-md-4 border-end" style="border-color: #dee2e6 !important;">
                                    <span class="text-muted font-size-12 text-uppercase d-block mb-1">Yield</span>
                                    <h3 class="text-info fw-bold mb-1">&#8377; <span id="detCalculatedYield">0.00</span> <span class="font-size-12 text-muted">/KM</span></h3>
                                    <span class="text-muted font-size-11"></span>
                                </div>
                                <div class="col-md-4 border-end ps-md-4 mt-3 mt-md-0" style="border-color: #dee2e6 !important;">
                                    <span class="text-muted font-size-12 text-uppercase d-block mb-1">Rate</span>
                                    <h3 class="fw-bold mb-1" style="color: #405189;">&#8377; <span id="detRate">0.00</span></h3>
                                    <span class="badge bg-soft-primary text-primary font-size-11 px-2 py-1 rounded" id="detRateType">Rate Type</span>
                                </div>
                                <div class="col-md-4 ps-md-4 mt-3 mt-md-0">
                                    <span class="text-muted font-size-12 text-uppercase d-block mb-1">Total Freight</span>
                                    <h3 class="text-success fw-bold mb-1">&#8377; <span id="detFreight">0.00</span></h3>
                                    <span class="text-muted font-size-11">Commission: <strong><span id="detCommission">0</span>% / &#8377; <span id="detCommissionVal">0.00</span></strong></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Remarks Card -->
                    <div class="mb-4 d-none" id="detRemarksWrapper">
                        <div class="p-3 rounded bg-soft-warning text-warning border border-warning border-opacity-25">
                            <h6 class="fw-bold mb-1 font-size-13"><i class="ri-edit-2-line align-middle me-1"></i> Incidental / Booking Notes</h6>
                            <p class="mb-0 font-size-13 text-dark" id="detRemarks" style="font-style: italic;"></p>
                        </div>
                    </div>

                    <!-- Payment Links Card -->
                    <div class="mb-4 d-none" id="detPaymentLinksWrapper">
                        <div class="p-3 rounded border" style="background-color: #ffffff; border: 1px solid #e9ebec; border-radius: 12px !important;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-uppercase fw-bold text-muted mb-0 font-size-11" style="letter-spacing: 0.8px; color: #878a99 !important;">Payment Links</h6>
                                <button type="button" class="btn btn-sm btn-light font-size-11 btnRefreshPaymentLinks" style="padding: 2px 8px;">
                                    <i class="ri-refresh-line align-middle me-1"></i> Refresh Status
                                </button>
                            </div>
                            <div id="detPaymentLinksContainer">
                                <!-- Populated via Javascript -->
                            </div>
                        </div>
                    </div>

                    <!-- Expense Card -->
                    <div class="mb-4">
                        <div class="p-3 rounded border" style="background-color: #ffffff; border: 1px solid #e9ebec; border-radius: 12px !important;">
                            <h6 class="text-uppercase fw-bold text-muted mb-3 font-size-11" style="letter-spacing: 0.8px; color: #878a99 !important;">Expense Audit</h6>
                            <div id="detExpensesContainer">
                                <!-- Populated via Javascript -->
                            </div>
                        </div>
                    </div>

                <!-- Footer buttons (Themed layout) -->
                <div class="card-footer bg-light p-3 d-flex gap-3 justify-content-end rounded-bottom border-top">
                    <button type="button" class="@ViewBag.UI.Buttons.Reject.CssClass px-4 py-2 btnDetReject" data-id="">
                        <i class="@ViewBag.UI.Buttons.Reject.Icon align-bottom me-1"></i> @ViewBag.UI.Buttons.Reject.Label
                    </button>
                    <button type="button" class="@ViewBag.UI.Buttons.Approve.CssClass px-4 py-2 btnDetApprove" data-id="">
                        <i class="@ViewBag.UI.Buttons.Approve.Icon align-bottom me-1"></i> @ViewBag.UI.Buttons.Approve.Label
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var FormComponents = function (DomainName) {

        var ApproveORRejectPR = function (DomainName, PRNo, Flag, Reason) {
            App.blockUI();
            var Parameters = {
                "PRNO": PRNo,
                "CompanyCode": "@ViewBag.BaseCompanyCode",
                "BaseUserName": "@ViewBag.BaseUserName",
                "Flag": Flag,
                "RejectReason": Reason || ""
            };

            $.ajax({
                url: DomainName + "/Account/GetDataWithoutAlias",
                type: 'POST',
                dataType: "json",
                data: {
                    Method: "USP_ApproveSpot_PR",
                    parameters: Parameters
                },
                success: function (data) {
                    App.unblockUI();
                    if (data && data.length > 0 && data[0].Status == 1) {
                        if (Flag == 'A') {
                            TosterNotification("success", "PR Approved Successfully.", "Success");
                        } else if (Flag == 'R') {
                            TosterNotification("success", "PR Rejected Successfully.", "Success");
                        }

                        setTimeout(function () {
                            window.location.href = DomainName + "/Fleet/ApproveRejectSpotPR";
                        }, 2000);
                    } else {
                        TosterNotification("error", data[0].Message || "Something went wrong.", "Error");
                    }
                },
                error: function (jqXHR, exception) {
                    App.unblockUI();
                    TosterNotification("error", "Failed to Approve/Reject request.", "Error");
                }
            });
        };

        var loadPaymentLinks = function (DomainName, PRNo) {
            var container = $("#detPaymentLinksContainer");
            container.empty();
            $("#detPaymentLinksWrapper").addClass("d-none");

            $.ajax({
                url: DomainName + '/Fleet/GetPaymentLinks',
                type: 'GET',
                data: { PRNo: PRNo },
                success: function (res) {
                    var hasPaid = false;
                    if (res && res.Status && res.Data && res.Data.length > 0) {
                        $("#detPaymentLinksWrapper").removeClass("d-none");
                        res.Data.forEach(function (link, index) {
                            var statusBadge = '';
                            var statusLower = (link.Status || "").toUpperCase();
                            if (statusLower === 'SUCCESS' || statusLower === 'PAID' || statusLower === 'COMPLETED') {
                                statusBadge = '<span class="badge bg-success-subtle text-success rounded-pill px-2 py-1 font-size-11">Paid</span>';
                                hasPaid = true;
                            } else if (statusLower === 'CREATED' || statusLower === 'ACTIVE') {
                                statusBadge = '<span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1 font-size-11">Pending</span>';
                            } else if (statusLower === 'EXPIRED') {
                                statusBadge = '<span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1 font-size-11">Expired</span>';
                            } else {
                                statusBadge = '<span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-1 font-size-11">' + link.Status + '</span>';
                            }

                            var copyButton = '';
                            if ((statusLower === 'CREATED' || statusLower === 'ACTIVE') && link.PaymentLink) {
                                copyButton = '<button type="button" class="btn btn-sm btn-soft-primary ms-2 btnCopyLink" data-link="' + link.PaymentLink + '" style="padding: 2px 6px; font-size: 11px;"><i class="ri-file-copy-line align-middle"></i> Copy Link</button>';
                            }

                            var isLast = index === (res.Data.length - 1);
                            var borderClass = isLast ? "" : "border-bottom";
                            var paddingClass = isLast ? "pt-2 pb-0" : "py-2";

                            container.append(
                                '<div class="d-flex justify-content-between align-items-center ' + paddingClass + ' ' + borderClass + '" style="border-color: #f3f6f9 !important;">' +
                                '    <div>' +
                                '        <span class="fw-semibold text-dark font-size-13">Amount: &#8377;' + parseFloat(link.Amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) + '</span>' +
                                '        <div class="text-muted font-size-11 mt-1">Order ID: ' + link.MerchantOrderId + '</div>' +
                                '    </div>' +
                                '    <div class="d-flex align-items-center">' +
                                '        ' + statusBadge +
                                '        ' + copyButton +
                                '    </div>' +
                                '</div>'
                            );
                        });
                    } else if ($("#hdnAdvancedInstance").val() == "1") {
                        $("#detPaymentLinksWrapper").removeClass("d-none");
                        container.append('<div class="text-center text-muted py-2 font-size-13">No payment link generated yet. Click "Approve" to generate one.</div>');
                    }

                    if (hasPaid) {
                        $(".btnDetApprove").hide();
                        $(".btnDetReject").hide();
                        ApproveORRejectPR(DomainName, PRNo, "A");
                    } else {
                        $(".btnDetApprove").show();
                        $(".btnDetReject").show();
                    }
                }
            });
        };

        return {
            init: function (DomainName) {
                // Card selection event
                $(document).on("click", ".pr-card-item", function () {
                    var prno = $(this).data("prno");
                    $(".pr-card-item").removeClass("active-card");
                    $(this).addClass("active-card");

                    $("#detailsPlaceholder").addClass("d-none");
                    $("#detailsContent").addClass("d-none");
                    $("#detailsLoader").removeClass("d-none").addClass("d-flex");

                    $.ajax({
                        url: DomainName + '/Fleet/GetPickupRequestDetails',
                        type: 'GET',
                        data: { PRNo: prno },
                        success: function (res) {
                            $("#detailsLoader").removeClass("d-flex").addClass("d-none");
                            if (res && res.Status && res.Data) {
                                var data = res.Data;

                                // Header Info
                                $("#hdnAdvancedInstance").val(data.AdvancedInstance !== null && data.AdvancedInstance !== undefined ? data.AdvancedInstance : "");
                                $("#hdnAdvancedPercentage").val(data.AdvancedPercentage !== null && data.AdvancedPercentage !== undefined ? data.AdvancedPercentage : "");
                                $("#detCustomerName").text(data.Customer || "-");
                                $("#detPRNo").text(data.PRNo || "-");
                                $("#detCustomerGroup").text(data.CustomerGroup || "-");

                                // Route Info
                                $("#detFromLane").text(data.From_Lane);
                                $("#detPickupAddress").text(data.Pickup_Address || "No detailed address description");
                                $("#detToLane").text(data.To_Lane);
                                $("#detDropLocation").text(data.DropLocation || "No drop location details");

                                // Metrics
                                $("#detTotalKMs").text(data.TotalKMs ? parseFloat(data.TotalKMs).toFixed(2) : "0.00");
                                $("#detWeight").text(data.Weight ? parseFloat(data.Weight).toFixed(2) : "0.00");
                                $("#detMaterial").text(data.Material || "-");

                                // Financials
                                $("#detRate").text(data.Rate ? parseFloat(data.Rate).toLocaleString('en-IN', { minimumFractionDigits: 2 }) : "0.00");
                                $("#detRateType").text(data.RateType || "-");
                                $("#detFreight").text(data.Freight ? parseFloat(data.Freight).toLocaleString('en-IN', { minimumFractionDigits: 2 }) : "0.00");
                                $("#detCommission").text(data.Commission || "0");
                                
                                // Calculate commission value
                                var rateVal = parseFloat(data.Rate);
                                var commPct = parseFloat(data.Commission);
                                var rateVals = parseFloat(data.Freight);
                                var commVal = (rateVals * commPct) / 100;
                                $("#detCommissionVal").text(commVal.toLocaleString('en-IN', { minimumFractionDigits: 2 }));

                                // Remarks
                                if (data.Remarks && data.Remarks.trim() !== "") {
                                    $("#detRemarks").text(data.Remarks);
                                    $("#detRemarksWrapper").removeClass("d-none");
                                } else {
                                    $("#detRemarksWrapper").addClass("d-none");
                                }

                                // Expenses
                                var totalExpense = 0;
                                var expensesContainer = $("#detExpensesContainer");
                                expensesContainer.empty();
                                if (data.EnrtExpList && data.EnrtExpList.length > 0) {
                                    data.EnrtExpList.forEach(function (exp, index) {
                                        var expAmt = parseFloat(exp.Amount_Spent) || 0;
                                        var isBilled = exp.IsBilled === true || String(exp.IsBilled).toLowerCase() === 'true';
                                        if (!isBilled) {
                                            totalExpense += expAmt;
                                        }
                                        var polarityHtml = exp.Polarity ? ' <span class="text-muted font-size-11">(' + exp.Polarity + ')</span>' : '';
                                        var billedHtml = isBilled ? ' <span class="badge bg-soft-info text-info font-size-10 ms-1">Billed</span>' : '';
                                      
                                        var amount = expAmt.toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
                                        var isLast = index === (data.EnrtExpList.length - 1);
                                        var borderClass = isLast ? "" : "border-bottom";
                                        var paddingClass = isLast ? "pt-2 pb-0" : "py-2";
                                        expensesContainer.append(
                                            '<div class="d-flex justify-content-between align-items-center ' + paddingClass + ' ' + borderClass + '" style="border-color: #f3f6f9 !important;">' +
                                            '    <span class="fw-semibold text-uppercase font-size-13" style="color: #495057;">' + (exp.Trip_Exp_Header || "-") + polarityHtml + billedHtml + '</span>' +
                                            '    <span class="fw-bold font-size-14 text-dark">&#8377;' + amount + '</span>' +
                                            '</div>'
                                        );
                                    });
                                } else {
                                    expensesContainer.append('<div class="text-center text-muted py-2 font-size-13">No enroute expenses added for this request.</div>');
                                }

                                // Calculate Yield
                                var distance = parseFloat(data.TotalKMs) || 0;
                                var freightVal = parseFloat(data.Freight) || 0;
                                var calculatedYield = distance > 0 ? (freightVal - commVal - totalExpense) / distance : 0;
                                $("#detCalculatedYield").text(calculatedYield.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));

                                // Update action button data-ids
                                $(".btnDetReject").attr("data-id", data.PRNo);
                                $(".btnDetApprove").attr("data-id", data.PRNo);

                                // Load Payment Links
                                loadPaymentLinks(DomainName, data.PRNo);

                                $("#detailsContent").removeClass("d-none");
                            } else {
                                TosterNotification("error", res.Message || "Failed to load PR details.", "Error");
                                $("#detailsPlaceholder").removeClass("d-none");
                            }
                        },
                        error: function () {
                            $("#detailsLoader").removeClass("d-flex").addClass("d-none");
                            TosterNotification("error", "Failed to fetch request details.", "Error");
                            $("#detailsPlaceholder").removeClass("d-none");
                        }
                    });
                });

                // Refresh payment links status
                $(document).on("click", ".btnRefreshPaymentLinks", function () {
                    var PRNo = $(".btnDetApprove").attr("data-id");
                    if (PRNo) {
                        loadPaymentLinks(DomainName, PRNo);
                    }
                });

                // Copy payment link to clipboard
                $(document).on("click", ".btnCopyLink", function () {
                    var link = $(this).attr("data-link");
                    if (link) {
                        var tempInput = document.createElement("input");
                        tempInput.value = link;
                        document.body.appendChild(tempInput);
                        tempInput.select();
                        document.execCommand("copy");
                        document.body.removeChild(tempInput);
                        TosterNotification("success", "Payment Link copied to clipboard.", "Success");
                    }
                });

                // Detail Pane Approve Action
                $(document).on("click", ".btnDetApprove", function () {
                    var PRNo = $(this).attr('data-id');
                    if (!PRNo) return;

                    var isAdvanced = $("#hdnAdvancedInstance").val() == "1";
                    if (isAdvanced) {
                        App.blockUI();
                        $.ajax({
                            url: DomainName + '/Fleet/GetPaymentLinks',
                            type: 'GET',
                            data: { PRNo: PRNo },
                            success: function (res) {
                                App.unblockUI();
                                var hasPaid = false;
                                if (res && res.Status && res.Data && res.Data.length > 0) {
                                    hasPaid = res.Data.some(function(link) {
                                        var statusLower = (link.Status || "").toUpperCase();
                                        return statusLower === 'SUCCESS' || statusLower === 'PAID' || statusLower === 'COMPLETED';
                                    });
                                }
                                
                                if (!hasPaid) {
                                    showConfirm({
                                        title: "Payment Pending",
                                        message: "Advanced payment is not yet completed for this request. Would you like to generate/regenerate the payment link?",
                                        type: "warning",
                                        confirmText: "Generate Link",
                                        cancelText: "Cancel",
                                        onConfirm: function () {
                                            var freight = parseFloat($("#detFreight").text().replace(/,/g, '')) || 0;
                                            var advPct = parseFloat($("#hdnAdvancedPercentage").val()) || 0;
                                            var amount = (freight * advPct) / 100;
                                            App.blockUI();
                                            $.ajax({
                                                url: DomainName + '/Fleet/CreatePaymentLink',
                                                type: 'POST',
                                                data: { PRNo: PRNo, Amount: amount },
                                                success: function (res) {
                                                    App.unblockUI();
                                                    if (res && res.Status) {
                                                        TosterNotification("success", "Payment Link created successfully.", "Success");
                                                        loadPaymentLinks(DomainName, PRNo);
                                                    } else {
                                                        TosterNotification("error", res.Message || "Failed to create payment link.", "Error");
                                                    }
                                                },
                                                error: function () {
                                                    App.unblockUI();
                                                    TosterNotification("error", "Failed to communicate with the server to create payment link.", "Error");
                                                }
                                            });
                                        }
                                    });
                                } else {
                                    showConfirm({
                                        title: "Approve Request",
                                        message: 'Payment completed successfully. Are you sure you want to <strong>Approve</strong> request <strong style="color:#405189">"' + PRNo + '"</strong>?',
                                        type: "success",
                                        confirmText: "Yes",
                                        cancelText: "No",
                                        onConfirm: function () {
                                            ApproveORRejectPR(DomainName, PRNo, "A");
                                        }
                                    });
                                }
                            },
                            error: function () {
                                App.unblockUI();
                                TosterNotification("error", "Failed to verify payment status.", "Error");
                            }
                        });
                    } else {
                        showConfirm({
                            title: "Approve Request",
                            message: 'Are you sure you want to <strong>Approve</strong> request <strong style="color:#405189">"' + PRNo + '"</strong>?',
                            type: "success",
                            confirmText: "Yes",
                            cancelText: "No",
                            onConfirm: function () {
                                ApproveORRejectPR(DomainName, PRNo, "A");
                            }
                        });
                    }
                });
                
                // Detail Pane Reject Action
                $(document).on("click", ".btnDetReject", function () {
                    var PRNo = $(this).attr('data-id');
                    if (!PRNo) return;

                    // Set modal title & icon
                    $('#glFormModalLabel').html(
                        '<i class="ri-close-circle-line me-2 text-danger"></i>Reject Request'
                    );

                    // Build reason form content
                    var formHtml = [
                        '<p class="fs-13 mb-3">Are you sure you want to <strong class="text-danger">Reject</strong> request <strong style="color:#405189">"' + PRNo + '"</strong>?</p>',
                        '<div class="mb-1">',
                        '    <label for="txtRejectReason" class="form-label fw-semibold fs-13 mb-1">',
                        '        Reason for Rejection <span class="text-danger">*</span>',
                        '    </label>',
                        '    <textarea id="txtRejectReason" class="form-control" rows="3" maxlength="500"',
                        '              placeholder="Please enter the reason for rejecting this request..."',
                        '              style="resize:none;font-size:13px;"></textarea>',
                        '    <div class="invalid-feedback" id="rejectReasonError">Please enter a reason before proceeding.</div>',
                        '</div>'
                    ].join('\n');

                    $('#glFormLoader').hide();
                    $('#glFormContent').html(formHtml);

                    // Validation feedback
                    $(document).off('input.reject').on('input.reject', '#txtRejectReason', function () {
                        if ($(this).val().trim().length > 0) {
                            $(this).removeClass('is-invalid');
                            $('#rejectReasonError').hide();
                        }
                    });

                    // Handle Save/Proceed
                    $('#glFormSaveBtn').off('click.reject').on('click.reject', function () {
                        var reason = $.trim($('#txtRejectReason').val());

                        if (!reason) {
                            $('#txtRejectReason').addClass('is-invalid');
                            $('#rejectReasonError').show();
                            $('#txtRejectReason').focus();
                            return;
                        }

                        // Close modal and submit
                        bootstrap.Modal.getInstance(document.getElementById('glFormModal')).hide();
                        ApproveORRejectPR(DomainName, PRNo, "R", reason);
                    });

                    // Open the common glFormModal
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('glFormModal')).show();

                    // Focus the textarea after modal is shown
                    document.getElementById('glFormModal').addEventListener('shown.bs.modal', function onShown() {
                        $('#txtRejectReason').focus();
                        this.removeEventListener('shown.bs.modal', onShown);
                    });
                });

                // Auto-select first card on page load
                setTimeout(function () {
                    var firstCard = $('.pr-card-item').first();
                    if (firstCard.length > 0) {
                        firstCard.trigger('click');
                    }
                }, 150);
            }
        }
    }();
</script>