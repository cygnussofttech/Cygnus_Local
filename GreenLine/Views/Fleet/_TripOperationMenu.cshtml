@model GreenLineDataService.ViewModel.CYGNUS_TripViewModel
@{
    var trip = Model.CTM;
    string activeTab = ViewBag.ActiveTab ?? "overview";
}

<div class="trip-op-sidebar d-flex flex-column h-100">
    <!-- Trip Identity Header -->
    <div class="sidebar-trip-header p-3 border-bottom">
        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="avatar-sm rounded d-flex align-items-center justify-content-center flex-shrink-0" style="background:rgba(255,255,255,.22);">
                <i class="ri-truck-line fs-18" style="color:#fff;"></i>
            </span>
            <div>
                <div class="fw-bold fs-15" style="color:#fff;">@trip.TripNo</div>
                <div class="fs-11" style="color:rgba(255,255,255,.7);">@trip.VehicleNo</div>
            </div>
        </div>
        <div class="mt-2">
            <span class="badge rounded-pill fs-10 px-2" style="background:rgba(255,255,255,.2);color:#fff;">
                <i class="ri-map-pin-line me-1"></i>@(string.IsNullOrEmpty(trip.Start_City_name) ? "Origin" : trip.Start_City_name)
            </span>
            <i class="ri-arrow-right-line mx-1 fs-11" style="color:rgba(255,255,255,.6);"></i>
            <span class="badge rounded-pill fs-10 px-2" style="background:rgba(255,255,255,.12);color:rgba(255,255,255,.9);">
                <i class="ri-map-pin-2-line me-1"></i>@(string.IsNullOrEmpty(trip.End_City_name) ? "Destination" : trip.End_City_name)
            </span>
        </div>
    </div>

    <!-- Nav Menu -->
    <nav class="trip-op-nav flex-grow-1 py-2">
        <ul class="nav flex-column gap-1 px-2">
            @if (trip == null || trip.Event_id >= 5)
            {
                <li class="nav-item">
                    <a class="trip-tab-link @(activeTab == "overview" ? "active" : "")" href="javascript:void(0);" data-tab="overview">
                        <i class="ri-eye-line"></i>
                        <span>Overview</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="trip-tab-link @(activeTab == "dispatch" ? "active" : "")" href="javascript:void(0);" data-tab="dispatch">
                        <i class="ri-file-list-3-line"></i>
                        <span>Dispatch (LR)</span>
                        <span class="tab-badge ms-auto" id="lrCount">@trip.DispatchLRCount</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="trip-tab-link @(activeTab == "expenses" ? "active" : "")" href="javascript:void(0);" data-tab="expenses">
                        <i class="ri-money-dollar-circle-line"></i>
                        <span>Expenses</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="trip-tab-link @(activeTab == "driverchange" ? "active" : "")" href="javascript:void(0);" data-tab="driverchange">
                        <i class="ri-user-follow-line"></i>
                        <span>Change Driver</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="trip-tab-link @(activeTab == "contactPage" ? "active" : "")" href="javascript:void(0);" data-tab="contactPage">
                        <i class="ri-contacts-line"></i>
                        <span>Trip Contact</span>
                    </a>
                </li>
            }
        </ul>

        <!-- Divider: Trip Ledger / Events -->
        <div class="sidebar-section-label px-3 mt-3 mb-1">
            <span class="text-uppercase fs-10 fw-bold text-muted letter-spacing-1">Trip Ledger &bull; Events</span>
        </div>

        <ul class="nav flex-column gap-1 px-2">
            <li class="nav-item">
                <a class="trip-tab-link @(activeTab == "tripevents" ? "active" : "")" href="javascript:void(0);" data-tab="tripevents">
                    <i class="ri-map-pin-time-line"></i>
                    <span>Trip Events</span>
                    <span class="tab-badge ms-auto">0</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="trip-tab-link @(activeTab == "vehicleevents" ? "active" : "")" href="javascript:void(0);" data-tab="vehicleevents">
                    <i class="ri-car-washing-line"></i>
                    <span>Vehicle Events</span>
                    <span class="tab-badge ms-auto" id="vehicleEventCount">@trip.VehicleEventCount</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="trip-tab-link @(activeTab == "notes" ? "active" : "")" href="javascript:void(0);" data-tab="notes">
                    <i class="ri-sticky-note-line"></i>
                    <span>Notes</span>
                    <span class="tab-badge ms-auto" id="noteCount">@trip.TripNotesCount</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="trip-tab-link @(activeTab == "timeline" ? "active" : "")" href="javascript:void(0);" data-tab="timeline">
                    <i class="ri-history-line"></i>
                    <span>View Timeline</span>
                    <span class="tab-badge ms-auto" id="timeLineCount">@trip.TimeLineCount</span>
                </a>
            </li>
        </ul>
    </nav>

    <!-- Back to Trip List -->
    <div class="p-3 border-top mt-auto">
        <a href="@Url.Action("TripList", "Fleet")" class="btn btn-soft-secondary btn-sm w-100">
            <i class="ri-arrow-left-line me-1"></i> Back to Trip List
        </a>
    </div>
</div>