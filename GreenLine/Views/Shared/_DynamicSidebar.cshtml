@using GreenLine.Models
@model IEnumerable<MenuViewModel>

<!-- ========== App Menu ========== -->
<div class="app-menu navbar-menu">
    <!-- LOGO -->
    <div class="navbar-brand-box">
        <!-- Dark Logo-->
        <a href="@Url.Action("Index", "Home")" class="logo logo-dark">
            <span class="logo-sm">
                <img src="@Url.Content("~/assets/img/logos/favicon.png")" alt="" height="50">
            </span>
            <span class="logo-lg">
                <img src="@Url.Content("~/assets/img/logos/logo-dark.png")" alt="" height="50">
            </span>
        </a>
        <!-- Light Logo-->
        <a href="@Url.Action("Index", "Home")" class="logo logo-light">
            <span class="logo-sm">
                <img src="@Url.Content("~/assets/img/logos/favicon.png")" alt="" height="50">
            </span>
            <span class="logo-lg">
                <img src="@Url.Content("~/assets/img/logos/logo-light.png")" alt="" height="50">
            </span>
        </a>
        <button type="button" class="btn btn-sm p-0 fs-20 header-item float-end btn-vertical-sm-hover" id="vertical-hover">
            <i class="ri-record-circle-line"></i>
        </button>
    </div>

    <div id="scrollbar">
        <div class="container-fluid">

            <div id="two-column-menu">
            </div>
            <ul class="navbar-nav" id="navbar-nav">
                <li class="menu-title"><span data-key="t-menu">Menu</span></li>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        @Html.Partial("_MenuItem", item, new ViewDataDictionary { { "IsTopLevel", true } })
                    }
                }
            </ul>
        </div>
    </div>
    <div class="sidebar-background"></div>
</div>
<div class="vertical-overlay"></div>
