<!-- ===== Global Bootstrap 5 Tooltip Initializer =====
     Activates Bootstrap 5 tooltips on all ui-btn-* elements.
     - If the element has a 'title' attribute, that text is used.
     - Otherwise, the text is looked up from UIBtnTooltips (sourced from UITheme.json).
     - Runs on DOMContentLoaded and after every $.ajax call (for DataTable rows).
====================================================== -->
<script type="text/javascript">
    function initUIButtonTooltips() {
        // Select all elements whose class contains 'ui-btn-'
        var els = document.querySelectorAll('[class*="ui-btn-"]');
        els.forEach(function (el) {
            // Avoid double-init
            if (el._bsTooltipInit) return;

            // Determine tooltip text: explicit title attr first, then UIBtnTooltips map
            var tipText = el.getAttribute('title') || '';
            if (!tipText) {
                // Match which ui-btn-* class the element has
                var classes = el.className ? el.className.split(' ') : [];
                for (var i = 0; i < classes.length; i++) {
                    var cls = classes[i].trim();
                    if (cls && UIBtnTooltips[cls]) {
                        tipText = UIBtnTooltips[cls];
                        break;
                    }
                }
            }

            if (!tipText) return; // nothing to show

            // Set title so Bootstrap can read it
            el.setAttribute('title', tipText);
            el._bsTooltipInit = true;

            if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
                new bootstrap.Tooltip(el, { trigger: 'hover', placement: 'top' });
            }
        });
    }

    // Run after the page is fully ready (scripts are defer-loaded)
    document.addEventListener('DOMContentLoaded', function () {
        initUIButtonTooltips();
    });

    // Re-run after every jQuery AJAX call (DataTable row rendering)
    $(document).ajaxComplete(function () {
        initUIButtonTooltips();
    });
</script>
