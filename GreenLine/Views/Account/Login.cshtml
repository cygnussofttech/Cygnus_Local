
@{
    ViewBag.Title = "Login | GreenLine TMS";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";

    // Dynamic Greeting Logic
    var hour = DateTime.Now.Hour;
    string greeting = hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Good Evening";
}

<link href="@Url.Content("~/assets/css/login.css")" rel="stylesheet" />

<div class="modern-login-container">
    <!-- Hero Section -->
    <div class="login-hero">
        <div class="hero-content">
            <h1>GreenLine</h1>
            <p>The next generation of Transformation Management Systems. Streamlining logistics with precision and sustainability.</p>
        </div>
    </div>

    <!-- Form Section -->
    <div class="login-form-side">
        <div class="login-card">
            <div class="brand-section">
                <img src="~/assets/img/logos/logo-dark.png" class="brand-logo" alt="GreenLine Logo" />
                <p class="greeting">@greeting</p>
                <h2 class="welcome-msg">Welcome Back</h2>
            </div>

            <!-- ============================================ -->
            <!-- STEP 1: Enter Mobile + Send OTP              -->
            <!-- ============================================ -->
            <div id="step_send_otp" class="otp-step active">
                <div class="form-body">
                    <p class="step-instruction">Enter your registered mobile number to receive a One-Time Password.</p>

                    <div class="form-group-modern">
                        <div class="input-icon-box">
                            <i class="fas fa-mobile-alt"></i>
                            <input type="tel" id="mobile_number" class="form-control"
                                   placeholder="Enter 10-digit Mobile Number" autocomplete="off" required
                                   maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                        </div>
                        <span id="send_otp_error" class="validation-error"></span>
                    </div>

                    <!-- Hidden Fields for Location/IP -->
                    <input type="hidden" id="lat_field" value="" />
                    <input type="hidden" id="lng_field" value="" />
                    <input type="hidden" id="city_field" value="" />
                    <input type="hidden" id="country_field" value="" />
                    <input type="hidden" id="code_field" value="" />
                    <input type="hidden" id="ip_field" value="" />
                    <input type="hidden" id="return_url" value="@ViewBag.ReturnUrl" />

                    <button type="button" class="btn-login" id="btn_send_otp">
                        <i class="fas fa-paper-plane"></i>
                        <span>Send OTP</span>
                    </button>
                </div>
            </div>

            <!-- ============================================ -->
            <!-- STEP 2: Enter OTP + Verify / Login            -->
            <!-- ============================================ -->
            <div id="step_verify_otp" class="otp-step">
                <div class="form-body">
                    <p class="step-instruction">
                        Enter the 6-digit OTP sent to
                        <strong id="display_contact"></strong>
                    </p>

                    <div class="otp-input-container" id="otp_container">
                        <input type="text" maxlength="1" class="otp-digit" data-index="0" inputmode="numeric" autocomplete="one-time-code" />
                        <input type="text" maxlength="1" class="otp-digit" data-index="1" inputmode="numeric" />
                        <input type="text" maxlength="1" class="otp-digit" data-index="2" inputmode="numeric" />
                        <span class="otp-separator">&mdash;</span>
                        <input type="text" maxlength="1" class="otp-digit" data-index="3" inputmode="numeric" />
                        <input type="text" maxlength="1" class="otp-digit" data-index="4" inputmode="numeric" />
                        <input type="text" maxlength="1" class="otp-digit" data-index="5" inputmode="numeric" />
                    </div>

                    <span id="verify_otp_error" class="validation-error" style="text-align:center;display:block;"></span>

                    <!-- Countdown Timer / Resend Section (Commented out timer) -->
                    <div class="otp-timer-section">
                        @* <span id="otp_timer" class="otp-timer">Please wait <strong id="timer_display">05:00</strong> to resend...</span> *@
                        <div id="resend_container" class="resend-text-wrap" style="text-align: center; margin-top: 10px;">
                            <span class="resend-prompt">Didn't receive a code ?</span> 
                            <button type="button" id="btn_resend_otp" class="resend-link">Resend</button>
                            <div class="resend-desc" style="font-size: 11px; color: #888; margin-top: 4px;">
                                (Clicking Resend will generate a new OTP and expire the previous one)
                            </div>
                        </div>
                    </div>

                    <button type="button" class="btn-login btn-verify" id="btn_verify_otp">
                        <i class="fas fa-shield-alt"></i>
                        <span>Verify OTP & Login</span>
                    </button>

                    <button type="button" class="btn-back" id="btn_back_step1">
                        <i class="fas fa-arrow-left"></i> Change Mobile
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="toast_container" class="toast-container"></div>

@Html.AntiForgeryToken()

<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
        // ======================================================
        // DOM Elements
        // ======================================================
        const stepSendOtp = document.getElementById('step_send_otp');
        const stepVerifyOtp = document.getElementById('step_verify_otp');
        const mobileInput = document.getElementById('mobile_number');
        const btnSendOtp = document.getElementById('btn_send_otp');
        const btnVerifyOtp = document.getElementById('btn_verify_otp');
        const btnResendOtp = document.getElementById('btn_resend_otp');
        const btnBackStep1 = document.getElementById('btn_back_step1');
        const displayContact = document.getElementById('display_contact');
        const sendOtpError = document.getElementById('send_otp_error');
        const verifyOtpError = document.getElementById('verify_otp_error');
        const otpDigits = document.querySelectorAll('.otp-digit');
        const toastContainer = document.getElementById('toast_container');
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        let countdownInterval = null;

        // ======================================================
        // Event Listeners
        // ======================================================
        btnSendOtp.addEventListener('click', function() { sendOtp(false); });
        btnVerifyOtp.addEventListener('click', verifyOtp);
        btnResendOtp.addEventListener('click', function() {
            clearOtpInputs();
            verifyOtpError.textContent = '';
            sendOtp(true);
        });
        btnBackStep1.addEventListener('click', showStep1);

        mobileInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') sendOtp();
        });

        // ======================================================
        // Geolocation & IP Capture (Background)
        // ======================================================
        const captureLocation = () => {
            if ("geolocation" in navigator) {
                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        document.getElementById('lat_field').value = pos.coords.latitude;
                        document.getElementById('lng_field').value = pos.coords.longitude;
                    },
                    (err) => console.warn("Geolocation denied or unavailable."),
                    { timeout: 5000 }
                );
            }
        };

        const fetchIPDetails = async () => {
            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                document.getElementById('ip_field').value = data.ip || '';
                document.getElementById('city_field').value = data.city || '';
                document.getElementById('country_field').value = data.country_name || '';
                document.getElementById('code_field').value = data.country_code || '';
            } catch (error) {
                console.error("Failed to fetch IP details:", error);
            }
        };

        captureLocation();
        fetchIPDetails();
        mobileInput.focus();

        // ======================================================
        // Toast Notification
        // ======================================================
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = 'toast-item toast-' + type;

            const icons = { 
                success: 'fas fa-check-circle', 
                error: 'fas fa-exclamation-circle', 
                info: 'fas fa-info-circle', 
                otp: 'fas fa-key' 
            };
            
            const iconClass = icons[type] || icons.info;
            toast.innerHTML = '<i class="' + iconClass + '"></i><span>' + message + '</span>';

            toastContainer.appendChild(toast);

            // Trigger animation
            requestAnimationFrame(() => toast.classList.add('show'));

            setTimeout(() => {
                toast.classList.remove('show');
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            }, type === 'otp' ? 15000 : 5000); // OTP toast stays 15 seconds
        }

        // ======================================================
        // OTP Input Handling (Auto-focus, paste, backspace)
        // ======================================================
        otpDigits.forEach((input, index) => {
            input.addEventListener('input', function (e) {
                this.value = this.value.replace(/[^0-9]/g, '');
                if (this.value && index < otpDigits.length - 1) {
                    otpDigits[index + 1].focus();
                }
                // Auto-verify when all 6 digits entered
                if (getOtpValue().length === 6) {
                    btnVerifyOtp.click();
                }
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Backspace' && !this.value && index > 0) {
                    otpDigits[index - 1].focus();
                    otpDigits[index - 1].value = '';
                }
            });

            input.addEventListener('paste', function (e) {
                e.preventDefault();
                const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '').substring(0, 6);
                pasted.split('').forEach((char, i) => {
                    if (otpDigits[i]) otpDigits[i].value = char;
                });
                if (pasted.length === 6) {
                    otpDigits[5].focus();
                    setTimeout(() => btnVerifyOtp.click(), 150);
                }
            });
        });

        function getOtpValue() {
            return Array.from(otpDigits).map(d => d.value).join('');
        }

        function clearOtpInputs() {
            otpDigits.forEach(d => { d.value = ''; });
            otpDigits[0].focus();
        }

        // ======================================================
        // Build hidden-fields payload
        // ======================================================
        function getLocationPayload() {
            return {
                Latitude: document.getElementById('lat_field').value,
                Longitude: document.getElementById('lng_field').value,
                LoginCity: document.getElementById('city_field').value,
                LoginCountry: document.getElementById('country_field').value,
                LoginCountryCode: document.getElementById('code_field').value,
                LoginIP: document.getElementById('ip_field').value
            };
        }

        // ======================================================
        // UI Step Transitions
        // ======================================================
        function showStep2() {
            stepSendOtp.classList.remove('active');
            stepSendOtp.classList.add('slide-out-left');
            setTimeout(() => {
                stepSendOtp.style.display = 'none';
                stepVerifyOtp.style.display = 'block';
                requestAnimationFrame(() => stepVerifyOtp.classList.add('active'));
                otpDigits[0].focus();
            }, 350);
        }

        function showStep1() {
            stepVerifyOtp.classList.remove('active');
            stepVerifyOtp.style.display = 'none';
            stepSendOtp.style.display = 'block';
            stepSendOtp.classList.remove('slide-out-left');
            requestAnimationFrame(() => stepSendOtp.classList.add('active'));
            mobileInput.focus();
        }

        // ======================================================
        // SEND OTP (AJAX)
        // ======================================================
        function sendOtp(forceNew = false) {
            const mobileNo = mobileInput.value.trim();

            if (!mobileNo) {
                sendOtpError.textContent = 'Please enter your mobile number.';
                mobileInput.focus();
                return;
            }

            if (mobileNo.length !== 10) {
                sendOtpError.textContent = 'Please enter a valid 10-digit mobile number.';
                mobileInput.focus();
                return;
            }

            sendOtpError.textContent = '';

            // Show loading state
            btnSendOtp.disabled = true;
            btnSendOtp.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Sending OTP...</span>';

            const loc = getLocationPayload();

            $.ajax({
                url: '@Url.Action("SendOTP", "Account")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    MobileNo: mobileNo,
                    Latitude: loc.Latitude,
                    Longitude: loc.Longitude,
                    LoginCity: loc.LoginCity,
                    LoginCountry: loc.LoginCountry,
                    LoginCountryCode: loc.LoginCountryCode,
                    LoginIP: loc.LoginIP,
                    ForceNewOTP: forceNew
                },
                success: function (result) {
                    btnSendOtp.disabled = false;
                    btnSendOtp.innerHTML = '<i class="fas fa-paper-plane"></i> <span>Send OTP</span>';

                    if (result.success) {
                        showToast('OTP sent successfully!', 'success');

                        // Show OTP in toast for TESTING ONLY
                        if (result.otpCode) {
                            showToast('Your OTP (Testing): ' + result.otpCode, 'otp');
                        }

                        displayContact.textContent = maskIdentifier(mobileNo);
                        showStep2();
                        // startCountdown(300); // 5 minutes
                    } else {
                        sendOtpError.textContent = result.message;
                        showToast(result.message, 'error');
                    }
                },
                error: function () {
                    btnSendOtp.disabled = false;
                    btnSendOtp.innerHTML = '<i class="fas fa-paper-plane"></i> <span>Send OTP</span>';
                    showToast('Network error. Please check your connection.', 'error');
                }
            });
        }

        // ======================================================
        // VERIFY OTP (AJAX)
        // ======================================================
        function verifyOtp() {
            const otpCode = getOtpValue();

            if (otpCode.length !== 6) {
                verifyOtpError.textContent = 'Please enter the complete 6-digit OTP.';
                return;
            }
            verifyOtpError.textContent = '';

            btnVerifyOtp.disabled = true;
            btnVerifyOtp.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Verifying...</span>';

            const loc = getLocationPayload();
            const returnUrl = document.getElementById('return_url').value;

            $.ajax({
                url: '@Url.Action("VerifyOTP", "Account")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    MobileNo: mobileInput.value.trim(),
                    OTPCode: otpCode,
                    Latitude: loc.Latitude,
                    Longitude: loc.Longitude,
                    LoginCity: loc.LoginCity,
                    LoginCountry: loc.LoginCountry,
                    LoginCountryCode: loc.LoginCountryCode,
                    LoginIP: loc.LoginIP,
                    returnUrl: returnUrl
                },
                success: function (result) {
                    if (result.success) {
                        showToast('Login successful! Redirecting...', 'success');
                        // clearInterval(countdownInterval);

                        // Add success animation
                        btnVerifyOtp.innerHTML = '<i class="fas fa-check"></i> <span>Authenticated!</span>';
                        btnVerifyOtp.classList.add('btn-success-state');

                        setTimeout(function () {
                            window.location.href = result.redirectUrl;
                        }, 800);
                    } else {
                        btnVerifyOtp.disabled = false;
                        btnVerifyOtp.innerHTML = '<i class="fas fa-shield-alt"></i> <span>Verify OTP & Login</span>';
                        verifyOtpError.textContent = result.message;
                        showToast(result.message, 'error');

                        // Shake animation on error
                        const container = document.getElementById('otp_container');
                        container.classList.add('shake');
                        setTimeout(() => container.classList.remove('shake'), 600);

                        clearOtpInputs();
                    }
                },
                error: function () {
                    btnVerifyOtp.disabled = false;
                    btnVerifyOtp.innerHTML = '<i class="fas fa-shield-alt"></i> <span>Verify OTP & Login</span>';
                    showToast('Network error. Please check your connection.', 'error');
                }
            });
        }

        // ======================================================
        // Mask mobile for display
        // ======================================================
        function maskIdentifier(value) {
            if (value.includes('@@')) {
                const parts = value.split('@@');
                return parts[0].substring(0, 2) + '****@@' + parts[1];
            }
            if (value.length > 4) {
                return value.substring(0, 2) + '****' + value.substring(value.length - 2);
            }
            return value;
        }
    });
</script>
