    var FormComponents = function (DomainName) {

        // Common Validation Helpers
        function isValidGST(gst) {
            if (!gst) return true;
            return /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/.test(gst.toUpperCase());
        }

        function isValidPAN(pan) {
            if (!pan) return true;
            return /^[A-Z]{5}[0-9]{4}[A-Z]{1}$/.test(pan.toUpperCase());
        }

        function getGSTDetailsApi(DomainName, gstNo) {
            var result = null;
            $.ajax({
                url: DomainName + '/Master/GetGSTDetails?GSTNO=' + gstNo,
                type: 'POST',
                dataType: "json",
                async: false,
                success: function (response) {
                    result = response;
                },
                error: function (jqXHR, exception) {
                    result = { Status: false, Message: "Error occurred while contacting database or API." };
                }
            });
            return result;
        }

        function fetchGSTDetails(DomainName, gstNo) {
            var result = null;
            var response = getGSTDetailsApi(DomainName, gstNo);
            if (response && response.Status && response.Data && response.Data.length > 0) {
                var gst = response.Data[0];
                // Map standard fields to the legacy schema expected by the callers
                var mappedDetails = {
                    Address: gst.CSGEAddress || gst.Address || "",
                    pncd: gst.PinCode || gst.pncd || gst.pincode || "",
                    cityname: gst.City || gst.cityname || gst.city_code || "",
                    tradeNam: gst.TradeName || gst.tradeNam || gst.legalName || gst.lgnm || "",
                    lgnm: gst.legalName || gst.lgnm || gst.TradeName || gst.tradeNam || "",
                    dty: gst.dty || (function() {
                        try {
                            if (gst.APIResponse) {
                                var parsed = JSON.parse(gst.APIResponse);
                                if (parsed && parsed.response && parsed.response.data) {
                                    return parsed.response.data.dty || "";
                                }
                            }
                        } catch(e) {}
                        return "";
                    })() || "",
                    Panno: gst.PanNo || gst.Panno || "",
                    dst: gst.City || gst.dst || "",
                    stcd: gst.statePrefix || gst.stcd || "",
                    rgdt: gst.registrationDate || gst.rgdt || "",
                    CountryCode: gst.CountryCode || "IN",
                    CountryName: gst.CountryName || "India",
                    StateCode: gst.StateCode || gst.statePrefix || "",
                    CityCode: gst.CityCode || gst.city_code || "",
                    pincodeArea: gst.pincodeArea || gst.PinCode || "",
                    ActiveStatus: (gst.isActive === true || gst.isActive === "true" || gst.ActiveStatus === "Active" || gst.Status === "Active") ? "Active" : "Inactive"
                };
                result = {
                    Table: [{ Error: "false", ErrorMessage: "" }],
                    Table1: [mappedDetails]
                };
            } else {
                var errorMsg = (response && response.Message) ? response.Message : "Invalid GST Number.";
                result = {
                    Table: [{ Error: "true", ErrorMessage: errorMsg }],
                    Table1: []
                };
            }
            return result;
        }

