        var latlongdata = function () {
            var geocoder = new google.maps.Geocoder();
            var address = $("#CCPA_PickUp_Address").val();
            var newLat = $("#CCPA_Latitude").val(); // Assuming you have input fields for NewLat and NewLong
            var newLong = $("#CCPA_Longitude").val();

            if (newLat == '' && newLong == '') {
                // Address is provided, use it for geocoding
                if (address != '') {
                    geocodeAddress(geocoder, address);
                }
                else {
                    loadmapOnCreate();
                }
            } else {
                // No address, but valid latitude and longitude are provided
                var lat = parseFloat(newLat);
                var long = parseFloat(newLong);
                $("#CCPA_Latitude").val(lat);
                $("#CCPA_Longitude").val(long);
                myMap(lat, long);
            }
        };

        function geocodeAddress(geocoder, address) {
            geocoder.geocode({ 'address': address }, function (results, status) {
                if (status == google.maps.GeocoderStatus.OK) {
                    var lat = results[0].geometry.location.lat().toFixed(6);
                    var long = results[0].geometry.location.lng().toFixed(6);
                    $("#CCPA_Latitude").val(lat).trigger("change");
                    $("#CCPA_Longitude").val(long).trigger("change");
                    myMap(lat, long);
                } else {
                    console.warn("Google Geocoding failed for address: '" + address + "' (Status: " + status + ")");
                    loadmapOnCreate();
                }
            });
        }

        function loadmapOnCreate() {
            var defaultLat = 21.1458; // Geographical center of India
            var defaultLong = 79.0882; // Geographical center of India

            var myCenter = new google.maps.LatLng(defaultLat, defaultLong);
            var mapProp = {
                center: myCenter,
                zoom: 5
            };
            var map = new google.maps.Map(document.getElementById("googleMap"), mapProp);
        }
        var myMap = function (lat, long) {
            var myCenter = new google.maps.LatLng(lat, long);
            var mapProp = {
                center: myCenter,
                zoom: 20
            };
            var map = new google.maps.Map(document.getElementById("googleMap"), mapProp);
            var marker = new google.maps.Marker({
                position: myCenter,
                draggable: false,
                map: map
            });

            google.maps.event.addListener(marker, 'dragend', function () {
                var newPosition = marker.getPosition();
                $("#CCPA_Latitude").val(newPosition.lat().toFixed(6)).trigger("change");
                $("#CCPA_Longitude").val(newPosition.lng().toFixed(6)).trigger("change");
            });

            var polygon = null;
            var circle = null;

            function validateAndProcessCircle(circ) {
                if (!circ) return true;

                var radius = circ.getRadius();
                var latVal = $("#CCPA_Latitude").val();
                var lngVal = $("#CCPA_Longitude").val();

                if (!latVal || !lngVal) {
                    return true;
                }

                var pLat = parseFloat(latVal);
                var pLng = parseFloat(lngVal);
                if (isNaN(pLat) || isNaN(pLng)) {
                    return true;
                }

                var center = circ.getCenter();
                var distance = 0;
                if (google.maps.geometry && google.maps.geometry.spherical) {
                    distance = google.maps.geometry.spherical.computeDistanceBetween(center, new google.maps.LatLng(pLat, pLng));
                } else {
                    var R = 6371000;
                    var dLat = (pLat - center.lat()) * Math.PI / 180;
                    var dLon = (pLng - center.lng()) * Math.PI / 180;
                    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                        Math.cos(center.lat() * Math.PI / 180) * Math.cos(pLat * Math.PI / 180) *
                        Math.sin(dLon / 2) * Math.sin(dLon / 2);
                    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                    distance = R * c;
                }

                var isOutside = (distance > radius);
                var exceedsLimit = (radius > 5000);

                if (exceedsLimit || isOutside) {
                    circ.setMap(null);
                    if (circle === circ) {
                        circle = null;
                    }
                    $("#CCPA_Radius").val("");
                    $("#CCPA_GeoFenceLatitude").val("");
                    $("#CCPA_GeoFenceLongitude").val("");

                    if (exceedsLimit) {
                        TosterNotification("error", "Geofence radius cannot exceed 5000 meters.", "Limit Exceeded");
                    } else {
                        TosterNotification("error", "The drawn Geofence shape must cover the selected pinpoint coordinates.", "Validation Warning");
                    }

                    drawingManager.setMap(map);
                    drawingManager.setOptions({ drawingControl: true });
                    return false;
                }

                return true;
            }

            function validateAndProcessPolygon(poly) {
                if (!poly) return true;

                var latVal = $("#CCPA_Latitude").val();
                var lngVal = $("#CCPA_Longitude").val();

                if (!latVal || !lngVal) {
                    return true;
                }

                var pLat = parseFloat(latVal);
                var pLng = parseFloat(lngVal);
                if (isNaN(pLat) || isNaN(pLng)) {
                    return true;
                }

                var pinpoint = new google.maps.LatLng(pLat, pLng);
                var isInside = false;

                if (google.maps.geometry && google.maps.geometry.poly) {
                    isInside = google.maps.geometry.poly.containsLocation(pinpoint, poly);
                } else {
                    isInside = true;
                }

                if (!isInside) {
                    poly.setMap(null);
                    if (polygon === poly) {
                        polygon = null;
                    }
                    $("#CCPA_Radius").val("");
                    $("#CCPA_GeoFenceLatitude").val("");
                    $("#CCPA_GeoFenceLongitude").val("");
                    $("#hdnGeofenceData").val("");

                    TosterNotification("error", "The drawn Geofence shape must cover the selected pinpoint coordinates.", "Validation Warning");

                    drawingManager.setMap(map);
                    drawingManager.setOptions({ drawingControl: true });
                    return false;
                }

                return true;
            }

            function updateCircleCoordinates(circ) {
                if (!circ) return;
                var center = circ.getCenter();
                var radius = circ.getRadius();

                var topPoint, rightPoint, bottomPoint, leftPoint;
                if (google.maps.geometry && google.maps.geometry.spherical) {
                    topPoint = google.maps.geometry.spherical.computeOffset(center, radius, 0);
                    rightPoint = google.maps.geometry.spherical.computeOffset(center, radius, 90);
                    bottomPoint = google.maps.geometry.spherical.computeOffset(center, radius, 180);
                    leftPoint = google.maps.geometry.spherical.computeOffset(center, radius, 270);
                } else {
                    var latOffset = radius / 111111;
                    var lngOffset = radius / (111111 * Math.cos(center.lat() * Math.PI / 180));
                    topPoint = new google.maps.LatLng(center.lat() + latOffset, center.lng());
                    rightPoint = new google.maps.LatLng(center.lat(), center.lng() + lngOffset);
                    bottomPoint = new google.maps.LatLng(center.lat() - latOffset, center.lng());
                    leftPoint = new google.maps.LatLng(center.lat(), center.lng() - lngOffset);
                }

                var latitudes = [
                    center.lat().toFixed(6),
                    topPoint.lat().toFixed(6),
                    rightPoint.lat().toFixed(6),
                    bottomPoint.lat().toFixed(6),
                    leftPoint.lat().toFixed(6)
                ];

                var longitudes = [
                    center.lng().toFixed(6),
                    topPoint.lng().toFixed(6),
                    rightPoint.lng().toFixed(6),
                    bottomPoint.lng().toFixed(6),
                    leftPoint.lng().toFixed(6)
                ];

                var geofencePoints = [];
                for (var i = 0; i < latitudes.length; i++) {
                    geofencePoints.push({
                        Latitude: latitudes[i],
                        Longitude: longitudes[i],
                        srno: i + 1
                    });
                }

                $("#CCPA_GeoFenceLatitude").val(center.lat().toFixed(6));
                $("#CCPA_GeoFenceLongitude").val(center.lng().toFixed(6));
                $("#hdnGeofenceData").val(JSON.stringify(geofencePoints));
            }

            debugger

            function drawGeofence(latitudeString, longitudeString) {
                var coordinates = parseCoordinates(latitudeString, longitudeString);
                if (polygon) {
                    polygon.setPath(coordinates);
                } else {
                    polygon = new google.maps.Polygon({
                        paths: coordinates,
                        editable: true,
                        draggable: true,
                        fillColor: '#FF0000',
                        fillOpacity: 0.3,
                        strokeColor: '#FF0000',
                        strokeOpacity: 0.8,
                        strokeWeight: 2,
                        map: map
                    });

                    if (!validateAndProcessPolygon(polygon)) {
                        return;
                    }

                    attachPathListeners(polygon.getPath());
                    google.maps.event.addListener(polygon, 'dragend', function () {
                        if (!validateAndProcessPolygon(polygon)) return;
                        updateCoordinates();
                    });
                    updateCoordinates();
                }
            }

            function parseCoordinates(latitudeString, longitudeString) {
                var latitudes = latitudeString.split(',');
                var longitudes = longitudeString.split(',');
                var coordinates = [];
                for (var i = 0; i < latitudes.length; i++) {
                    coordinates.push(new google.maps.LatLng(parseFloat(latitudes[i]), parseFloat(longitudes[i])));
                }
                return coordinates;
            }

            function attachPathListeners(path) {
                google.maps.event.addListener(path, 'set_at', function () {
                    if (!validateAndProcessPolygon(polygon)) return;
                    updateCoordinates();
                });
                google.maps.event.addListener(path, 'insert_at', function () {
                    if (!validateAndProcessPolygon(polygon)) return;
                    updateCoordinates();
                });
                google.maps.event.addListener(path, 'remove_at', function () {
                    if (!validateAndProcessPolygon(polygon)) return;
                    updateCoordinates();
                });
            }

            function updateCoordinates() {
                var path = polygon.getPath();
                var latitudes = [];
                var longitudes = [];
                var geofencePoints = [];

                path.forEach(function (vertex, index) {
                    var lat = vertex.lat().toFixed(6);
                    var lng = vertex.lng().toFixed(6);
                    latitudes.push(lat);
                    longitudes.push(lng);

                    geofencePoints.push({
                        Latitude: lat,
                        Longitude: lng,
                        srno: index + 1
                    });
                });

                $("#CCPA_GeoFenceLatitude").val(latitudes.join(','));
                $("#CCPA_GeoFenceLongitude").val(longitudes.join(','));
                $("#hdnGeofenceData").val(JSON.stringify(geofencePoints));

                // Calculate Area for Polygons
                if (google.maps.geometry) {
                    var areaSqM = google.maps.geometry.spherical.computeArea(path);
                    $("#CCPA_Radius").val(areaSqM.toFixed(2) + " SqM");
                }

                checkAndClearGeofenceError();
            }

            var latitudeString = $("#CCPA_GeoFenceLatitude").val();
            var longitudeString = $("#CCPA_GeoFenceLongitude").val();
            var radiusValue = $("#CCPA_Radius").val();

            if (latitudeString && longitudeString) {
                if (latitudeString.indexOf(',') > -1) {
                    drawGeofence(latitudeString, longitudeString);
                } else if (radiusValue && parseFloat(radiusValue) > 0) {
                    drawCircleGeofence(latitudeString, longitudeString, radiusValue);
                }
            }

            function drawCircleGeofence(lat, lng, radius) {

                debugger
                if (circle) circle.setMap(null);

                var rVal = parseFloat(radius);
                circle = new google.maps.Circle({
                    strokeColor: '#FF0000',
                    strokeOpacity: 0.8,
                    strokeWeight: 2,
                    fillColor: '#FF0000',
                    fillOpacity: 0.3,
                    map: map,
                    center: { lat: parseFloat(lat), lng: parseFloat(lng) },
                    radius: rVal,
                    editable: true,
                    draggable: true
                });

                if (!validateAndProcessCircle(circle)) {
                    return;
                }

                updateCircleCoordinates(circle);

                google.maps.event.addListener(circle, 'radius_changed', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    $("#CCPA_Radius").val(circle.getRadius().toFixed(2) + " Mtrs");
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });
                google.maps.event.addListener(circle, 'center_changed', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });
                google.maps.event.addListener(circle, 'dragend', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });
            }

            var drawingManager = new google.maps.drawing.DrawingManager({
                drawingMode: null,
                drawingControl: true,
                drawingControlOptions: {
                    position: google.maps.ControlPosition.TOP_CENTER,
                    drawingModes: ['polygon', 'circle']
                },
                polygonOptions: {
                    editable: true,
                    draggable: true,
                    fillColor: '#FF0000',
                    fillOpacity: 0.3,
                    strokeColor: '#FF0000',
                    strokeOpacity: 0.8,
                    strokeWeight: 2
                },
                circleOptions: {
                    editable: true,
                    draggable: true,
                    fillColor: '#FF0000',
                    fillOpacity: 0.3,
                    strokeColor: '#FF0000',
                    strokeOpacity: 0.8,
                    strokeWeight: 2
                }
            });

            if (!latitudeString && !longitudeString) {
                drawingManager.setMap(map);
            }

            google.maps.event.addListener(drawingManager, 'polygoncomplete', function (newPolygon) {
                if (polygon) polygon.setMap(null);
                if (circle) circle.setMap(null);

                polygon = newPolygon;
                if (!validateAndProcessPolygon(polygon)) {
                    return;
                }

                $("#CCPA_Radius").val(''); // Clear radius for polygons
                attachPathListeners(polygon.getPath());
                google.maps.event.addListener(polygon, 'dragend', function () {
                    if (!validateAndProcessPolygon(polygon)) return;
                    updateCoordinates();
                });
                updateCoordinates();
                drawingManager.setDrawingMode(null);
                drawingManager.setOptions({ drawingControl: false });
            });

            google.maps.event.addListener(drawingManager, 'circlecomplete', function (newCircle) {
                if (polygon) polygon.setMap(null);
                if (circle) circle.setMap(null);

                circle = newCircle;
                if (!validateAndProcessCircle(circle)) {
                    return;
                }

                var radius = circle.getRadius();
                $("#CCPA_Radius").val(radius.toFixed(2) + " Mtrs");

                updateCircleCoordinates(circle);

                google.maps.event.addListener(circle, 'radius_changed', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    $("#CCPA_Radius").val(circle.getRadius().toFixed(2) + " Mtrs");
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });
                google.maps.event.addListener(circle, 'center_changed', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });
                google.maps.event.addListener(circle, 'dragend', function () {
                    if (!validateAndProcessCircle(circle)) return;
                    updateCircleCoordinates(circle);
                    checkAndClearGeofenceError();
                });

                checkAndClearGeofenceError();

                drawingManager.setDrawingMode(null);
                drawingManager.setOptions({ drawingControl: false });
            });

            // Adding a button to remove the geofence
            var controlUI = document.createElement('div');
            controlUI.style.backgroundColor = '#fff';
            controlUI.style.border = '2px solid #fff';
            controlUI.style.borderRadius = '2px';
            controlUI.style.boxShadow = '0 2px 6px rgba(0,0,0,.3)';
            controlUI.style.cursor = 'pointer';
            controlUI.style.marginRight = '10px'; // Adjust spacing to align with the map type controls
            controlUI.style.marginTop = '10px';
            controlUI.style.left = '178px';
            controlUI.style.padding = '8px';
            controlUI.innerHTML = 'Remove Geofence';
            controlUI.style.fontSize = '16px';
            controlUI.onclick = function () {
                if (polygon) {
                    polygon.setMap(null);
                    polygon = null;
                }
                if (circle) {
                    circle.setMap(null);
                    circle = null;
                }
                $("#CCPA_GeoFenceLatitude").val('');
                $("#CCPA_GeoFenceLongitude").val('');
                $("#CCPA_Radius").val('');
                $("#hdnGeofenceData").val('');
                if (drawingManager) {
                    drawingManager.setMap(map);
                    drawingManager.setOptions({ drawingControl: true });
                }
                checkAndClearGeofenceError();
            };

            // Add the custom control to the map
            map.controls[google.maps.ControlPosition.TOP_LEFT].push(controlUI);

            // Zoom map to fit the geofence geometry bounds once map is ready/idle
            google.maps.event.addListenerOnce(map, 'idle', function () {
                if (polygon) {
                    var bounds = new google.maps.LatLngBounds();
                    polygon.getPath().forEach(function (vertex) {
                        bounds.extend(vertex);
                    });
                    map.fitBounds(bounds);
                } else if (circle) {
                    map.fitBounds(circle.getBounds());
                }
            });
        }

