                        PickUp_Pincode: $("#CCPA_PickUp_Pincode").val(),
                        Zone: $("#CCPA_Zone").val(),
                        Zone_Text: $("#CCPA_Zone option:selected").text().trim(),
                        Lane_id: $("#CCPA_Lane_id").val(),
                        Lane_Text: $("#CCPA_Lane_id option:selected").text().trim(),
                        Latitude: lat,
                        Longitude: lng,
                        Radius: radius,
                        GeoFenceLatitude: geolat,
                        GeoFenceLongitude: geolng,
                        srno: 0,
                        IsDeleted: 0,
                        AddID: ""
                    };

                    if (pickupAddressEditIndex === -1) {
                        item.srno = 0;
                        item.AddID = "temp_" + new Date().getTime() + "_" + Math.floor(Math.random() * 1000);
                        pickupAddressData.push(item);
                    } else {
                        var originalItem = pickupAddressData[pickupAddressEditIndex];
                        item.srno = originalItem.srno !== undefined ? originalItem.srno : 0;
                        item.IsDeleted = originalItem.IsDeleted !== undefined ? originalItem.IsDeleted : 0;
