        function isCoordinateInsideGeofence(latVal, lngVal, geoLatVal, geoLngVal, radiusVal) {
            if (!latVal || !lngVal || !geoLatVal || !geoLngVal) {
                return true;
            }
            var pLat = parseFloat(latVal);
            var pLng = parseFloat(lngVal);
            if (isNaN(pLat) || isNaN(pLng)) {
                return true;
            }

            var pinpoint = new google.maps.LatLng(pLat, pLng);
            var isInside = true;

            if (geoLatVal.indexOf(',') > -1) {
                // Polygon geofence
                var lats = geoLatVal.split(',');
                var lngs = geoLngVal.split(',');
                var coords = [];
                for (var i = 0; i < lats.length; i++) {
                    var flat = parseFloat(lats[i]);
                    var flng = parseFloat(lngs[i]);
                    if (!isNaN(flat) && !isNaN(flng)) {
                        coords.push(new google.maps.LatLng(flat, flng));
                    }
                }

                if (coords.length > 0) {
                    var poly = new google.maps.Polygon({ paths: coords });
                    if (google.maps.geometry && google.maps.geometry.poly) {
                        isInside = google.maps.geometry.poly.containsLocation(pinpoint, poly);
                    } else {
                        // Ray casting fallback
                        var x = pLng, y = pLat;
                        isInside = false;
                        for (var i = 0, j = coords.length - 1; i < coords.length; j = i++) {
                            var xi = coords[i].lng(), yi = coords[i].lat();
                            var xj = coords[j].lng(), yj = coords[j].lat();
                            var intersect = ((yi > y) !== (yj > y))
                                && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
                            if (intersect) isInside = !isInside;
                        }
                    }
                }
            } else {
                // Circle geofence
                var cLat = parseFloat(geoLatVal);
                var cLng = parseFloat(geoLngVal);
                var radius = parseFloat(radiusVal);

                if (!isNaN(cLat) && !isNaN(cLng) && !isNaN(radius)) {
                    var center = new google.maps.LatLng(cLat, cLng);
                    var distance = 0;
                    if (google.maps.geometry && google.maps.geometry.spherical) {
                        distance = google.maps.geometry.spherical.computeDistanceBetween(center, pinpoint);
                    } else {
                        // Haversine fallback
                        var R = 6371000;
                        var dLat = (pLat - cLat) * Math.PI / 180;
                        var dLon = (pLng - cLng) * Math.PI / 180;
                        var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                                Math.cos(cLat * Math.PI / 180) * Math.cos(pLat * Math.PI / 180) *
                                Math.sin(dLon / 2) * Math.sin(dLon / 2);
                        var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                        distance = R * c;
                    }
                    isInside = (distance <= radius);
                }
            }

            return isInside;
        }

        function checkAndClearGeofenceError() {
            var latField = $("#CCPA_Latitude");
            var lngField = $("#CCPA_Longitude");
            var latVal = latField.val();
            var lngVal = lngField.val();
            var geoLatVal = $("#CCPA_GeoFenceLatitude").val();
            var geoLngVal = $("#CCPA_GeoFenceLongitude").val();
            var radiusVal = $("#CCPA_Radius").val();

            if (!geoLatVal || !geoLngVal || isCoordinateInsideGeofence(latVal, lngVal, geoLatVal, geoLngVal, radiusVal)) {
                latField.removeClass("input-validation-error").closest(".form-group").removeClass("has-error");
                lngField.removeClass("input-validation-error").closest(".form-group").removeClass("has-error");

                latField.siblings(".validation-error-msg").each(function () {
                    if ($(this).text().indexOf("pinpoint marker") > -1) {
                        $(this).remove();
                    }
                });
                lngField.siblings(".validation-error-msg").each(function () {
                    if ($(this).text().indexOf("pinpoint marker") > -1) {
                        $(this).remove();
                    }
                });
            }
        }

        function validateTab(tabId) {
            var isValid = true;
            var tab = $("#" + tabId);

            // Clear ALL previous error messages and highlights
            // (includes our custom errors AND jQuery Validate help-block errors from the Next button)
            tab.find(".validation-error-msg").remove();
            tab.find(".help-block").remove();
            tab.find(".has-error").removeClass("has-error");
            tab.find(".input-validation-error").removeClass("input-validation-error");
            tab.find(".select2-selection").removeClass("input-validation-error");

            tab.find(".required:input").each(function () {
                var field = $(this);
                var value = field.val();

                // If value is null, undefined, empty string, or empty array
                if (value === "" || value == null || (Array.isArray(value) && value.length === 0)) {
                    field.addClass("input-validation-error");
                    var errorMsg = '<div class="validation-error-msg text-danger small mt-1">This field is required</div>';

                    // Detect any Select2-enhanced field
                    var select2Container = field.nextAll(".select2-container").first();
                    var isSelect2field = select2Container.length > 0;

                    if (isSelect2field) {
                        // Highlight the visible Select2 widget border
                        select2Container.find(".select2-selection").addClass("input-validation-error");
                        // Place error after the container
                        select2Container.after(errorMsg);
                    } else {
                        // Plain input / file � insert directly after the field
                        field.after(errorMsg);
                    }

                    isValid = false;
                } else {
                    // Specific Format Validations
                    var fieldId = field.attr('id');
                    var value = field.val().toUpperCase();
                    var formatError = "";

                    if (fieldId === "CCBD_Bill_PAN") {
                        if (!isValidPAN(value)) {
                            formatError = "Invalid PAN Format (e.g. ABCDE1234F)";
                        }
                    } else if (fieldId === "CCBD_Bill_GSTIN") {
                        if (!isValidGST(value)) {
                            formatError = "Invalid GST Format (e.g. 22AAAAA0000A1Z5)";
                        }
                    }

                    if (formatError !== "") {
                        field.addClass("input-validation-error");
                        field.after('<div class="validation-error-msg text-danger small mt-1">' + formatError + '</div>');
                        isValid = false;
                    } else {
                        field.removeClass("input-validation-error");
                        // Clear Select2 highlight on valid fields too
                        field.nextAll(".select2-container").first()
                             .find(".select2-selection").removeClass("input-validation-error");
                    }
                }
            });

            if (isValid && tabId === "tab-Address") {
                var latField = $("#CCPA_Latitude");
                var lngField = $("#CCPA_Longitude");
                var latVal = latField.val();
                var lngVal = lngField.val();
                var geoLatVal = $("#CCPA_GeoFenceLatitude").val();
                var geoLngVal = $("#CCPA_GeoFenceLongitude").val();
                var radiusVal = $("#CCPA_Radius").val();

                if (latVal && lngVal && geoLatVal && geoLngVal) {
                    var isInside = isCoordinateInsideGeofence(latVal, lngVal, geoLatVal, geoLngVal, radiusVal);
                    if (!isInside) {
                        latField.addClass("input-validation-error").closest(".form-group").addClass("has-error");
                        lngField.addClass("input-validation-error").closest(".form-group").addClass("has-error");

                        var errorMsg = '<div class="validation-error-msg text-danger small mt-1">The pinpoint marker must be inside the drawn geofence area.</div>';
                        latField.after(errorMsg);
                        lngField.after(errorMsg);

                        TosterNotification("error", "The pinpoint marker must be inside the geofence (polygon or circle).", "Oppps..!!");
                        isValid = false;
                    }
                }
            }

            return isValid;
        }

