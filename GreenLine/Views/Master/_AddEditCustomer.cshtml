                        tableBody.empty();
                        var activeItems = [];
                        $.each(pickupAddressData, function (index, item) {
                            if (item.IsDeleted !== 1 && item.IsDeleted !== "1" && item.IsDeleted !== true && item.IsDeleted !== "true") {
                                activeItems.push({ originalIndex: index, item: item });
                            }
                        });

                        if (activeItems.length === 0) {
                            tableBody.append('<tr><td colspan="9" class="text-center text-muted">No data available</td></tr>');
                        } else {
                            $.each(activeItems, function (idx, obj) {
                                var index = obj.originalIndex;
                                var item = obj.item;
                                var row = '<tr>' +
                                    '<td class="text-center">' + item.PickUp_Address + '</td>' +
                                    '<td class="text-center">' + (item.PickUp_Country_Text || item.PickUp_Country || '') + '</td>' +
                                    '<td class="text-center">' + (item.PickUp_State_Text || item.PickUp_State || '') + '</td>' +
                                    '<td class="text-center">' + (item.PickUp_City_Text || item.PickUp_City || '') + '</td>' +
                                    '<td class="text-center">' + item.PickUp_Pincode + '</td>' +
                                    '<td class="text-center">' + (item.Zone_Text || item.Zone || '') + '</td>' +
                                    '<td class="text-center">' + (item.Lane_Text || item.Lane_id || '') + '</td>' +
                                    '<td class="text-center">' + (item.Radius || '') + '</td>' +
                                    '<td class="text-center">' +
                                        '<div class="d-flex gap-2 justify-content-center">' +
                                            '<button type="button" class="@ViewBag.UI.Buttons.Edit.CssClass" onclick="editPickupAddressRow(' + index + ')">' +
                                                '<i class="@ViewBag.UI.Buttons.Edit.Icon"></i>' +
                                            '</button>' +
                                            '<button type="button" class="@ViewBag.UI.Buttons.Delete.CssClass" onclick="removePickupAddressRow(' + index + ')">' +
                                                '<i class="@ViewBag.UI.Buttons.Delete.Icon"></i>' +
                                            '</button>' +
                                        '</div>' +
                                    '</td>' +
                                '</tr>';
                                tableBody.append(row);
                            });
                        }
                        $("#hdnPickupAddressData").val(JSON.stringify(pickupAddressData));

                        var allGeofencePoints = [];
                        $.each(pickupAddressData, function (i, item) {
                            if (item.IsDeleted !== 1 && item.IsDeleted !== "1" && item.IsDeleted !== true && item.IsDeleted !== "true") {
                                $.each(item.GeofencePoints || [], function (j, pt) {
                                    pt.AddID = item.AddID || (item.srno ? item.srno.toString() : "");
                                    pt.Customer = $("#CUSTCD").val() || "";
                                    pt.srno = j + 1; // Ensure sequence number is strictly 1, 2, 3...
                                    allGeofencePoints.push(pt);
                                });
                            }
                        });
                        $("#hdnGeofenceData").val(JSON.stringify(allGeofencePoints));
                    }
