                // Modern Bootstrap 5 Switch Handling
                $check.on('change', function () {
                    var state = $(this).is(':checked');
                    $("#" + clsName).val(state);
                    if ($("#form_sample").data("validator")) {
                        $("#" + clsName).valid(); // Trigger validation for the hidden field
                    }

                    handleToggleLogic(clsName, state);
                });

                // Initialize logic for current state
                handleToggleLogic(clsName, $check.is(':checked'));
                return;
            }

            // Legacy BootstrapSwitch Handling
            $('.' + clsName + 'Y').bootstrapSwitch('state', true);
            $('.' + clsName + 'Y').bootstrapSwitch('size', 'mini');
            $('.' + clsName + 'N').bootstrapSwitch('state', false);
            $('.' + clsName + 'N').bootstrapSwitch('size', 'mini');

            $('.' + clsName + 'Change').on('switchChange.bootstrapSwitch', function (event, state) {
                $("#" + clsName + "").val(state);
                if ($("#form_sample").data("validator")) {
                    $("#" + clsName + "").valid();
                }
                handleToggleLogic(clsName, state);
            });
        }

