                    // Also reset the Document Type Select2 dropdown
                    $("#CCKD_KYC_Document_Type").val("").trigger("change");
                    $("#tab-KYCDoc .form-control").removeClass("input-validation-error");
                    $("#tab-KYCDoc .select2-selection").removeClass("input-validation-error");
                    $("#tab-KYCDoc .validation-error-msg").remove();

                    kycEditIndex = -1;
                    $("#btn_AddKYCDocDetails_txt").text("Add");
                    $("#btn_AddKYCDocDetails_icon").attr("class", "@ViewBag.UI.Buttons.Add.Icon label-icon align-middle fs-16 me-2");
                });

                $(document).off("click", "#btn_AddKYCDocDetails").on("click", "#btn_AddKYCDocDetails", function () {
                    if (!validateTab("tab-KYCDoc")) {
                        var firstError = $("#tab-KYCDoc .input-validation-error").first();
                        if (firstError.length > 0) {
                            $('html, body').animate({ scrollTop: firstError.offset().top - 150 }, 500);
                        }
                        return;
                    }

                    var fileInput = document.getElementById('CCKD_KYC_File');
                    if (fileInput.files.length === 0) {
                        TosterNotification("error", "Please select a file to upload.", "Error");
                        return;
                    }

                    var file = fileInput.files[0];
                    var fileName = file.name;

                    // Simple extension check
                    var allowedExtensions = /(\.jpg|\.png|\.pdf)$/i;
                    if (!allowedExtensions.exec(fileName)) {
                        TosterNotification("error", "Invalid file format. Please upload JPG, PNG, or PDF.", "Error");
                        return;
                    }

                    var formData = new FormData();
                    formData.append("kycFile", file);
                    formData.append("testData", "Checking Body"); // Test if form data reaches server

                    App.blockUI({ boxed: true });

                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', 'UploadCustomerKYCDoc', true);
                    xhr.onload = function () {
                        App.unblockUI();
                        if (xhr.status === 200) {
                            var response = JSON.parse(xhr.responseText);
                            if (response.success) {
                                var item = {
                                    KYC_Document_Type: $("#CCKD_KYC_Document_Type").val(),
                                    KYC_Document_Type_Text: $("#CCKD_KYC_Document_Type option:selected").text().trim(),
                                    KYC_Document: response.fileName,
                                    KYC_File_Path: response.filePath
                                };

                                if (kycEditIndex === -1) {
                                    kycData.push(item);
                                } else {
                                    kycData[kycEditIndex] = item;
                                    kycEditIndex = -1;
                                    $("#btn_AddKYCDocDetails_txt").text("Add");
                                    $("#btn_AddKYCDocDetails_icon").attr("class", "@ViewBag.UI.Buttons.Add.Icon label-icon align-middle fs-16 me-2");
                                }

                                refreshKYCTable();

                                // Clear inputs
                                $("#CCKD_KYC_Document_Type").val("").trigger("change");
                                $("#CCKD_KYC_File").val("");
                            } else {
                                TosterNotification("error", response.message, "Upload Failed");
                            }
                        } else {
                            TosterNotification("error", "Error " + xhr.status + ": " + xhr.statusText, "Upload Error");
                        }
                    };
                    xhr.onerror = function () {
                        App.unblockUI();
                        TosterNotification("error", "Network error occurred during upload.", "Error");
                    };
                    xhr.send(formData);
                });

