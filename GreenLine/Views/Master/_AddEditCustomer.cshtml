@model GreenLineDataService.Models.CYGNUS_CUSTHDR
@using GreenLineDataService.Models;

@{
    var type = "Add";
    if (Model.CUSTCD != null && Model.CUSTCD != "0")
    {
        type = "Edit";
    }
    else
    {
        Model.TBB = true;
    }
    string CUSTLOC = Model.CUSTLOC;
    string BusinessType = Model.BusinessType;
    string MAP_CSGN = Model.MAP_CSGN;
    string MAP_CSGE = Model.MAP_CSGE;

    bool Active = true, MobileService = false, Consignee = false, Consignnor = false, ScheduleApply = false;
    string ThirdParty = "";
    char IsRegistered = 'N';
    string IsRegisteredText = "";
    if (Model.CUST_ACTIVE != null && Model.CUST_ACTIVE.ToUpper() == "N")
    {
        Active = false;
    }
    if (Model.MOBSERV_ENABLED != null && Model.MOBSERV_ENABLED.ToUpper() == "N")
    {
        MobileService = true;
    }

    if (Model.Consignee != null && Model.Consignee.ToUpper() == "Y")
    {
        Consignee = true;
    }
    if (Model.Consignnor != null && Model.Consignnor.ToUpper() == "Y")
    {
        Consignnor = true;
    }

    if (Model.ThirdParty != null && Model.ThirdParty.ToUpper() == "Y")
    {
        ThirdParty = "checked";
        Model.ThirdParty = "Y";
    }
    else
    {
        ThirdParty = "";
        Model.ThirdParty = "N";
    }
    bool AutoBillAllowed = true;
    if (Model.AutoBillAllowed != null && Model.CUSTCD == null || Model.CUSTCD == "0")
    {
        AutoBillAllowed = false;
    }
    bool BillingAtDestination = true;
    if (Model.BillingAtDestination != null && Model.CUSTCD == null || Model.CUSTCD == "0")
    {
        BillingAtDestination = false;
    }
    bool EInvoice = true;
    if (Model.EInvoice != null && Model.CUSTCD == null || Model.CUSTCD == "0")
    {
        EInvoice = false;
    }
    bool IsGTA = true;
    if (Model.IsGTA != null && Model.CUSTCD == null || Model.CUSTCD == "0")
    {
        IsGTA = false;
    }
    bool IsBusiness = true;
    if (Model.IsBusiness != null)
    {
        IsBusiness = false;
    }
    if (Model.ScheduleApply != null && Model.ScheduleApply.ToUpper() == "Y")
    {
        ScheduleApply = true;
    }

    if (Model.IsRegistered == true || Model.CUSTCD == null || Model.CUSTCD == "0" || Model.GSTNO != null)
    {
        IsRegistered = 'Y';
        IsRegisteredText = "checked";
        Model.IsRegistered = true;
    }
    if (Model.TANNo != "" || Model.TANNo != null)
    {
        Model.IsTDSApplicable = true;
    }
    if (Model.TANNo == null)
    {
        Model.IsTDSApplicable = false;
    }

    GreenLineDataService.Helper.Interface.IMasterService _masterService = new GreenLineDataService.Helper.MasterService();

    List<CYGNUS_GRPMST> GroupList = _masterService.GetCustomerGroupMasterObject().Where(c => c.ActiveFlag == null ? c.ActiveFlag == null : c.ActiveFlag == "Y").ToList();

    foreach (var item in GroupList)
    {
        item.GRPNM = item.GRPCD + "~" + item.GRPNM;
    }
    List<CYGNUS_State> Liststate = _masterService.GetStateMaster().Where(c => c.activeflag == "Y").ToList();
    List<CYGNUS_Master_General> ListMasterGeneral = _masterService.GetGeneralMaster();
    List<CYGNUS_location> ListLocations = _masterService.GetLocationDetails().Where(c => c.ActiveFlag == null ? c.ActiveFlag == null : c.ActiveFlag == "Y").OrderBy(c => c.LocName).ToList();

    List<CYGNUS_Master_General> generalMasterList = _masterService.GetGeneralMaster();
    string GSTVALIDATE = generalMasterList.Where(c => c.CodeType == "GSTVALIDATE").FirstOrDefault().CodeId;
    List<CYGNUS_pincode_master> pincodeList = _masterService.GetPincodeMaster().ToList();
    List<CYGNUS_citymaster> cityList = _masterService.GetCityMaster().Where(c => c.activeflag == "Y").OrderBy(c => c.Location).ToList();
    List<CYGNUX_Master_Countries> CountryList = _masterService.GetCountryMaster().ToList();

    List<CYGNUS_State> AddressStateList = new List<CYGNUS_State>();
    List<CYGNUS_location> AddressLocationList = new List<CYGNUS_location>();
    List<CYGNUS_CUSTHDR> AddressCustomerList = new List<CYGNUS_CUSTHDR>();
    List<CYGNUS_LaneMaster> ListLane = _masterService.GetLaneDetails().ToList();

    if (type == "Edit")
    {
        int cityId = 0;
        if (Model.CCPA != null && !string.IsNullOrEmpty(Model.CCPA.PickUp_City))
        {
            int.TryParse(Model.CCPA.PickUp_City, out cityId);
        }

        if (cityId > 0)
        {
            AddressStateList = _masterService.GetStateByCityJson(cityId);
            AddressLocationList = _masterService.GetLOCATIONByCityJson(cityId);
        }
        AddressCustomerList = _masterService.GetCustomerListforAddress().Where(c => c.CUSTCD == Model.CUSTCD).ToList();
    }

    var AdvancedInstance = new List<SelectListItem> {
    new SelectListItem { Text = "Before Vehicle Allocation", Value = "1" },
    new SelectListItem { Text = "Before POD Upload", Value = "2" }
};
}
<style>
    .nav-tabs-custom {
        border-bottom: 2px solid #eff2f7;
        gap: 30px;
        background: transparent;
        padding: 0 10px;
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
    }

    .help-block {
        font-size: 11px;
        margin-top: 5px;
        font-weight: 500;
        color: #f06548 !important;
        display: block;
    }

    .nav-tabs-custom .nav-item {
        border: none;
        background: transparent;
    }

        .nav-tabs-custom .nav-item .nav-link {
            border: none;
            font-weight: 600;
            color: #878a99;
            padding: 15px 0;
            font-size: 14px;
            background: transparent;
            border-radius: 0;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 0px;
        }

            .nav-tabs-custom .nav-item .nav-link i {
                font-size: 18px;
                opacity: 0.7;
            }

            .nav-tabs-custom .nav-item .nav-link.active {
                color: #405189 !important;
                background-color: transparent !important;
            }

                .nav-tabs-custom .nav-item .nav-link.active i {
                    color: #405189;
                    opacity: 1;
                }

            .nav-tabs-custom .nav-item .nav-link::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0;
                height: 3px;
                background-color: #405189;
                transition: width 0.3s ease;
                border-radius: 3px 3px 0 0;
            }

            .nav-tabs-custom .nav-item .nav-link.active::after {
                width: 100%;
            }

            .nav-tabs-custom .nav-item .nav-link:hover {
                color: #405189;
            }
</style>
<div class="page-title-box d-sm-flex align-items-center justify-content-between">
