@model IEnumerable<GreenLineDataService.Models.CYGNUS_Vehicle_Master>
@{
    ViewBag.Title = "Vehicle Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">@ViewBag.Title</h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0 shadow-none bg-transparent">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Master</a></li>
                    <li class="breadcrumb-item active">Vehicle List</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<!-- end page title -->

<div class="row" id="mainContainer" style="display:none;">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-0">
            <div class="card-header border-bottom-dashed d-flex align-items-center py-3">
                <h4 class="card-title mb-0 flex-grow-1">List of Vehicles</h4>
                <div class="flex-shrink-0 d-flex gap-2">
                    <a class="@ViewBag.UI.Buttons.Excel.CssClass" id="btnDownload">
                        <i class="@ViewBag.UI.Buttons.Excel.Icon"></i>
                    </a>
                    @if (ViewBag.BaseUserReadWrite == "W" || ViewBag.BaseUserReadWrite == null)
                    {
                        <a class="@ViewBag.UI.Buttons.Add.CssClass" href="@Url.Content("~/Master/AddEditVehicle")">
                            <i class="@ViewBag.UI.Buttons.Add.Icon"></i>
                        </a>
                    }
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped align-middle table-nowrap mb-0" id="VehicleList">
                    <thead class="table-light">
                        <tr>
                            <th class="center">Vehicle ID</th>
                            <th class="center">Vehicle No.</th>
                            <th class="center">Vehicle Code</th>
                            <th class="center">Registered</th>
                            <th class="center">Status</th>
                            <th class="center no-cc">Action</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- QR Code Viewer Modal -->
<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header p-3 border-bottom">
                <h5 class="modal-title d-flex align-items-center gap-2 text-primary" id="qrCodeModalLabel" style="color: #405189 !important;">
                    <i class="ri-qr-code-fill text-success fs-18"></i> Vehicle QR Code
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <!-- QR Code Image Container -->
                <div class="d-inline-block p-3 bg-white rounded-3 mb-3 border shadow-sm">
                    <img id="qrCodeImg" src="" alt="QR Code" style="width: 220px; height: 220px; border-radius: 4px;" />
                </div>
                
                <!-- Vehicle ID & Vehicle No in a common alert banner -->
                <div class="d-block w-100 mx-auto mb-2" style="max-width: 320px;">
                    <div class="alert alert-success d-flex align-items-center justify-content-center gap-2 py-2 px-3 mb-0" role="alert">
                        <i class="ri-car-fill fs-18"></i>
                        <span class="fs-15 fw-semibold">
                            <span id="qrVehicleId"></span>
                            <span class="text-muted mx-2">|</span>
                            <span id="qrVehicleNo"></span>
                        </span>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light p-3 d-flex justify-content-end gap-2 border-top">
                <button type="button" class="@ViewBag.UI.Buttons.Cancel.CssClass" data-bs-dismiss="modal">
                    <i class="@ViewBag.UI.Buttons.Cancel.Icon"></i>@ViewBag.UI.Buttons.Cancel.Label
                </button>
                <button type="button" class="btn btn-sm btn-label btn-success" id="btnPrintQR">
                    <i class="ri-printer-line label-icon align-middle fs-16 me-2"></i> Print QR Code
                </button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    var UI = {
        editBtn: '@ViewBag.UI.Buttons.Edit.CssClass',
        editIcon: '@ViewBag.UI.Buttons.Edit.Icon'
    };

    var FormComponents = function (DomainName) {

        var loadData = function (DomainName, tblId) {
            App.blockUI({ boxed: true });
            var strUrl = DomainName + '/Master/GetVehicleListJson'
            $.ajax({
                url: strUrl,
                type: 'POST',
                success: function (result) {
                    GlDataTable.refresh(tblId, {
                        data: result,
                        statusFilter: [3, 4],
                        columns: [
                            { data: "ID" },
                            { data: "VehicleNo" },
                            { data: "VehicleCode" },
                            { data: "IsRegistered" },
                            { data: "IsActive" },
                            { data: "ID" }
                        ],
                        columnDefs: [
                            { orderable: false, targets: [3, 4, 5] },
                            {
                                targets: [3],
                                render: function (data) {
                                    var isChecked = data ? "checked" : "";
                                    return '<label class="switch"><input type="checkbox" ' + isChecked + ' disabled><span class="slider round"></span></label>';
                                }
                            },
                            {
                                targets: [4],
                                render: function (data, type, full) {
                                    var isChecked = data ? "checked" : "";
                                    return '<label class="switch"><input class="btnToggleStatus" type="checkbox" ' + isChecked + ' data-id="' + full.ID + '" data-name="' + full.VehicleNo + '"><span class="slider round"></span></label>';
                                }
                            },
                            {
                                targets: [5],
                                render: function (data, type, row) {
                                    var val = data ? data.toString().trim() : "";
                                    var qrCode = row.VehicleQRCode ? row.VehicleQRCode.toString().trim() : "";
                                    var vehicleNo = row.VehicleNo ? row.VehicleNo.toString().trim() : "";
                                    
                                    return '<div class="d-flex justify-content-center align-items-center gap-1">' +
                                           '  <a href="' + DomainName + '/Master/AddEditVehicle/' + encodeURIComponent(val) + '" class="' + UI.editBtn + '"><i class="' + UI.editIcon + '"></i></a>' +
                                           '  <button type="button" class="btn btn-light btn-sm btnShowQRCode" data-qrcode="' + qrCode + '" data-vehicleno="' + vehicleNo + '" data-vehicleid="' + val + '" title="View QR Code"><i class="ri-qr-code-line"></i></button>' +
                                           '</div>';
                                }
                            }
                        ],
                        createdRow: function (row) {
                            $('td', row).addClass('text-center align-middle');
                        }
                    });
                    $('#mainContainer').show(500);
                    App.unblockUI();
                },
                error: function (req, status, error) {
                    TosterNotification("error", 'Operation failed. There is some issue please try again or contact your administrator.', "Oops!");
                    App.unblockUI();
                }
            });
        }

        var Events = function (DomainName) {
            $(document).on("click", "#VehicleList a.btnAddEdit", function (e) {
                App.blockUI({ boxed: true });
            });

            $(document).on('click', '#btnDownload', function (e) {
                e.preventDefault();
                DownloadMasterReport(DomainName, "Vehicle", "Vehicle Master List");
            });

            // Toggle Status Handler
            $(document).on("click", ".btnToggleStatus", function (e) {
                e.preventDefault();
                var checkbox = $(this);
                var id = checkbox.data("id");
                var name = checkbox.data("name");
                var isChecked = checkbox.is(':checked');

                var action = isChecked ? "Activate" : "Deactivate";
                var type = isChecked ? "success" : "info";

                showConfirm({
                    title: action + " Vehicle",
                    message: 'Are you sure you want to <strong>' + action.toLowerCase() + '</strong> status for vehicle <strong class="text-primary">' + name + '</strong>?',
                    type: type,
                    confirmText: "Yes, Confirm",
                    onConfirm: function () {
                        App.blockUI({ boxed: true });
                        $.post(DomainName + '/Master/ActiveInActive_Vehicle', { id: id }, function (res) {
                            App.unblockUI();
                            if (res) {
                                TosterNotification("success", "Status updated successfully!", "Success");
                                loadData(DomainName, "VehicleList");
                            } else {
                                TosterNotification("error", "Failed to update status.", "Error");
                            }
                        }).fail(function () {
                            App.unblockUI();
                            TosterNotification("error", "A server-side error occurred.", "Error");
                        });
                    }
                });
            });

            // Show QR Code Modal
            $(document).on("click", ".btnShowQRCode", function (e) {
                e.preventDefault();
                var qrCode = $(this).data("qrcode");
                var vehicleNo = $(this).data("vehicleno");
                var vehicleId = $(this).data("vehicleid");
                
                if (!qrCode) {
                    TosterNotification("warning", "No QR Code generated for this vehicle.", "Warning");
                    return;
                }
                
                $("#qrVehicleId").text(vehicleId);
                $("#qrVehicleNo").text(vehicleNo);
                
                // Store on print button
                $("#btnPrintQR").data("vehicleid", vehicleId);
                $("#btnPrintQR").data("vehicleno", vehicleNo);
                $("#btnPrintQR").data("qrcode", qrCode);
                
                var qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=" + encodeURIComponent(qrCode);
                $("#qrCodeImg").attr("src", qrUrl);
                
                var myModal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
                myModal.show();
            });

            // Print QR Code via new dedicated print page
            $(document).on("click", "#btnPrintQR", function () {
                var vehicleId = $(this).data("vehicleid");
                var vehicleNo = $(this).data("vehicleno");
                var qrCode = $(this).data("qrcode");
                
                var printUrl = DomainName + '/Master/PrintVehicleQRCode?vehicleId=' + encodeURIComponent(vehicleId) + '&vehicleNo=' + encodeURIComponent(vehicleNo) + '&qrCode=' + encodeURIComponent(qrCode);
                window.open(printUrl, '_blank', 'width=800,height=500');
            });
        }

        return {
            init: function (DomainName) {
                loadData(DomainName, 'VehicleList');
                Events(DomainName);
            }
        }
    }();
</script>