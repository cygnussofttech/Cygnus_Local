@model IEnumerable<GreenLineDataService.Models.CYGNUS_Master_CodeTypes>
@{
    ViewBag.Title = "General Master Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Compatibility Stubs for Velzon app.js (Prevents Console Error) -->
<div style="display:none !important;">
    <button id="light-dark-mode"></button>
    <button class="search-widget-icon" id="search-options"></button>
    <div id="search-close-options"></div>
    <div id="search-dropdown"></div>
</div>

<style>
    /* Premium Card Design */
    .master-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--vz-border-color);
        border-radius: 12px;
        background-color: var(--vz-card-bg-custom, #fff);
        position: relative;
        overflow: hidden;
    }
    .master-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.08) !important;
        border-color: var(--vz-primary);
    }
    
    /* Dynamic Icon Containers */
    .master-icon-container {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 22px;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

    /* Category-specific Colors */
    .cat-user { background: rgba(255, 111, 0, 0.1); color: #ff6f00; }
    .cat-finance { background: rgba(40, 167, 69, 0.1); color: #28a745; }
    .cat-transport { background: rgba(0, 123, 255, 0.1); color: #007bff; }
    .cat-location { background: rgba(220, 53, 69, 0.1); color: #dc3545; }
    .cat-system { background: rgba(102, 16, 242, 0.1); color: #6610f2; }
    .cat-default { background: var(--vz-light); color: var(--vz-secondary); }

    .master-card:hover .master-icon-container {
        transform: scale(1.1) rotate(5deg);
    }
    .master-card:hover .cat-user { background: #ff6f00; color: #fff; }
    .master-card:hover .cat-finance { background: #28a745; color: #fff; }
    .master-card:hover .cat-transport { background: #007bff; color: #fff; }
    .master-card:hover .cat-location { background: #dc3545; color: #fff; }
    .master-card:hover .cat-system { background: #6610f2; color: #fff; }
    
    /* Hub Toolbar Styling */
    .hub-container {
        background: #fff;
        border: 1px solid var(--vz-border-color);
        border-radius: 10px;
        padding: 10px;
        margin-bottom: 20px;
        box-shadow: var(--vz-box-shadow-sm);
    }
    .hub-icon-box {
        width: 60px;
        height: 60px;
        background: #f3f6f9;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0ab39c; /* Teal */
        font-size: 26px;
    }
    .hub-title {
        font-size: 20px;
        font-weight: 700;
        color: #495057;
        letter-spacing: -0.5px;
    }
    .hub-subtitle {
        font-size: 13px;
        color: #878a99;
    }
    .hub-search-group {
        position: relative;
        min-width: 320px;
    }
    .hub-search-group i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #0ab39c;
        font-size: 18px;
    }
    .hub-search-group input {
        padding-left: 48px;
        border-radius: 12px;
        height: 48px;
        border: 1px solid rgba(10, 179, 156, 0.4);
        background: #fff;
        font-size: 14px;
        transition: all 0.3s ease;
    }
    .hub-search-group input:focus {
        border-color: #0ab39c;
        box-shadow: 0 0 0 4px rgba(10, 179, 156, 0.1);
    }
    .hub-count-btn {
        background: #0ab39c;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 0 24px;
        height: 48px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(10, 179, 156, 0.25);
        cursor: default;
    }
    
    .master-label {
        font-size: 9px;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--vz-muted);
        background: var(--vz-light);
        padding: 2px 6px;
        border-radius: 4px;
        display: inline-block;
    }

    .master-anchor {
        text-decoration: none !important;
        color: inherit !important;
    }

    .arrow-indicator {
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.3s ease;
        color: var(--vz-primary);
    }
    .master-card:hover .arrow-indicator {
        opacity: 1;
        transform: translateX(0);
    }
</style>

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">General Master</h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0 shadow-none bg-transparent">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Master</a></li>
                    <li class="breadcrumb-item active">General Master</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<!-- end page title -->

<!-- Hub Toolbar -->
<div class="hub-container">
    <div class="row align-items-center g-4">
        <div class="col-sm">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 me-3">
                    <div class="hub-icon-box shadow-sm">
                        <i class="ri-dashboard-3-line"></i>
                    </div>
                </div>
                <div>
                    <h5 class="hub-title mb-1">Configuration Hub</h5>
                    <p class="hub-subtitle mb-0">System-wide master data and library management.</p>
                </div>
            </div>
        </div>
        <div class="col-sm-auto">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <div class="hub-search-group">
                    <i class="ri-search-2-line"></i>
                    <input type="text" id="masterFilterBox" class="form-control" placeholder="Search library (Ctrl + K)">
                </div>
                <div class="hub-count-btn">
                    <i class="ri-database-2-line"></i>
                    <span>@Model.Count() Masters</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Master Grid -->
<div class="row" id="masterGridContainer">
    @foreach (var item in Model)
    {
        <div class="col-xxl-3 col-lg-4 col-sm-6 master-card-item" data-search="@item.HeaderDesc.ToLower()">
            <a href="@Url.Content("~/Master/GeneralMaster/" + item.HeaderCode)" class="master-anchor">
                <div class="card master-card shadow-sm border-0">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                @{
                                    string icon = "ri-settings-4-line";
                                    string colorClass = "cat-default";
                                    string desc = item.HeaderDesc.ToLower();
                                    
                                    if (desc.Contains("user") || desc.Contains("employee") || desc.Contains("booked") || desc.Contains("cust")) 
                                    { 
                                        icon = "ri-user-star-line"; colorClass = "cat-user"; 
                                    }
                                    else if (desc.Contains("account") || desc.Contains("bill") || desc.Contains("gst") || desc.Contains("tax") || desc.Contains("bank") || desc.Contains("hsn")) 
                                    { 
                                        icon = "ri-bank-card-line"; colorClass = "cat-finance"; 
                                    }
                                    else if (desc.Contains("vehicle") || desc.Contains("truck") || desc.Contains("tyre") || desc.Contains("diesel") || desc.Contains("driver")) 
                                    { 
                                        icon = "ri-truck-line"; colorClass = "cat-transport"; 
                                    }
                                    else if (desc.Contains("location") || desc.Contains("route") || desc.Contains("city") || desc.Contains("zone") || desc.Contains("state")) 
                                    { 
                                        icon = "ri-map-pin-2-line"; colorClass = "cat-location"; 
                                    }
                                    else if (desc.Contains("status") || desc.Contains("reason") || desc.Contains("exit") || desc.Contains("type") || desc.Contains("category")) 
                                    { 
                                        icon = "ri-list-settings-line"; colorClass = "cat-system"; 
                                    }
                                }
                                <div class="master-icon-container @colorClass shadow-sm">
                                    <i class="@icon"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="text-truncate mb-1 fw-bold fs-14 text-dark">@item.HeaderDesc</h6>
                                <span class="master-label">@item.HeaderCode</span>
                            </div>
                            <div class="ms-2">
                                <i class="ri-arrow-right-line fs-18 arrow-indicator"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<!-- Empty State -->
<div id="noResultsState" class="text-center py-5 d-none animate__animated animate__fadeIn">
    <lord-icon src="@Url.Content("~/assets/img/msoeawqm.json")" trigger="loop" colors="primary:#405189,secondary:#0ab39c" style="width:75px;height:75px"></lord-icon>
    <h5 class="mt-4 fw-semibold">No results found</h5>
    <p class="text-muted mb-0">We couldn't find any master matching your search term.</p>
</div>

@section scripts {
    <script src="~/Velzon_assets/js/pages/plugins/lord-icon-2.1.0.js" defer></script>
    <script>
        var FormComponents = function () {
            return {
                // main function to initiate the module
                init: function (DomainName) {
                    
                    // Real-time Filtering Logic for Modern Cards
                    $("#masterFilterBox").on("keyup", function () {
                        var value = $(this).val().toLowerCase();
                        var count = 0;

                        $("#masterGridContainer .master-card-item").each(function () {
                            var searchData = $(this).data("search");
                            if (searchData.indexOf(value) > -1) {
                                $(this).removeClass('d-none');
                                count++;
                            } else {
                                $(this).addClass('d-none');
                            }
                        });

                        // Toggle Empty State
                        if (count === 0) {
                            $("#noResultsState").removeClass('d-none');
                            $("#masterGridContainer").addClass('d-none');
                        } else {
                            $("#noResultsState").addClass('d-none');
                            $("#masterGridContainer").removeClass('d-none');
                        }
                    });
                }
            };
        }();

        $(document).ready(function () {
            FormComponents.init(DomainName);
        });
    </script>
}