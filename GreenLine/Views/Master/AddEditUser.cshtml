@model GreenLineDataService.ViewModel.CYGNUS_Master_UsersViewModel
@using GreenLineDataService.Models;

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var Text = "Submit"; var type = "Add";
    if (Model.EditFlag != null && Model.EditFlag == true)
    {
        type = "Edit";
    }
    else
    {
        if (Model.WMU.DOJ_ORG == null || Model.WMU.DOJ_ORG == System.DateTime.MinValue)
        {
            Model.WMU.DOJ_ORG = System.DateTime.Now;
        }
    }
    string IsActive = "";
    if (Model.WMU.Status != null && Model.WMU.Status.ToUpper() == "100" || Model.EditFlag == false)
    {
        IsActive = "checked";
        Model.WMU.Status = "Y";
    }
    string ShowTBBCharges = "";
    if (Model.WMU.ShowTBBCharges != null && Model.WMU.ShowTBBCharges.ToUpper() == "Y" || Model.EditFlag == false)
    {
        ShowTBBCharges = "checked";
        Model.WMU.ShowTBBCharges = "Y";
    }
    else
    {
        ShowTBBCharges = "";
        Model.WMU.ShowTBBCharges = "N";
    }
}
@{
    GreenLineDataService.Helper.Interface.IMasterService MS = new GreenLineDataService.Helper.MasterService();
    List<SelectListItem> genderList = new List<SelectListItem>(){
        new SelectListItem { Text = "Male", Value = "M"},
        new SelectListItem { Text = "Female", Value = "F"},
    };

    List<CYGNUS_Master_Users> ManagerList = new List<CYGNUS_Master_Users>();
    List<CYGNUS_Master_General> DesignationList = new List<CYGNUS_Master_General>();
    if (Model.EditFlag != null && Model.EditFlag == true)
    {
        DesignationList = MS.GetDesignationFromCategory(Model.WMU.Category).ToList();
        //ManagerList = MS.GetManagerFromDesignationandLocation(Model.WMU.Category, Model.WMU.BranchCode).ToList();
    }
    //List<CYGNUS_Master_Users> userMasterList = MS.GetUserDetails().Where(c => c.Status == "100").OrderBy(c => c.EmpId).ToList();
    //List<CYGNUS_location> locationList = MS.GetLocationDetails().Where(c => c.ActiveFlag == "Y").OrderBy(c => c.LocName).ToList();
    List<CYGNUS_Master_General> Department = MS.GetGeneralMasterWithParam("USERDEPRT").ToList();
    List<CYGNUS_Master_General> UserTypeList = MS.GetGeneralMasterWithParam("USERTYP").ToList();
    List<CYGNUS_Master_General> UserStatusList = MS.GetGeneralMasterWithParam("EMPST").ToList();
    List<CYGNUS_Master_General> RolesList = MS.GetGeneralMasterWithParam("HIERARCHY").ToList();
    List<CYGNUS_Master_General> ReadWriteList = MS.GetGeneralMasterWithParam("RW").ToList();
    //List<CYGNUS_Master_General> Grade = MS.GetGeneralMasterWithParam("USERGRADE").ToList();

    ViewBag.Title = @type + " User";
    Model.WMU.Read_Witre = "W";
}

<!-- start page title -->
<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <h4 class="mb-sm-0">@ViewBag.Title</h4>

    <div class="page-title-right">
        <ol class="breadcrumb m-0 shadow-none bg-transparent">
            <li class="breadcrumb-item"><a href="javascript: void(0);">Master</a></li>
            <li class="breadcrumb-item"><a href="@Url.Content("~/Master/UserList")">User List</a></li>
            <li class="breadcrumb-item active">@type</li>
        </ol>
    </div>
</div>
<!-- end page title -->
