@{
    ViewBag.Title = "Notes Category Mapping Done";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6">
        @if (ViewBag.Status == "DONE")
        {
            <div class="card shadow-lg border-0">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="avatar-lg mx-auto">
                            <div class="avatar-title bg-soft-success text-success display-3 rounded-circle" style="width: 100px; height: 100px; line-height: 100px; margin: 0 auto;">
                                <i class="ri-checkbox-circle-fill"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="fw-bold mb-2">Success!</h3>
                    <p class="text-muted fs-15"> Notes Category Mapping Successfully Done!</p>
                    <div class="mt-4">
                        <a href="@Url.Action("NotesCategoryMapping", "Master")" class="btn btn-primary d-inline-flex align-items-center gap-1">
                            <i class="ri-arrow-left-line"></i> Back to List
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-soft-light border-0 py-3 text-center">
                    <p class="mb-0 text-muted fs-12">Note: You can always manage Notes Category Mapping details from this view.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card shadow-lg border-0 border-top border-top-danger border-4">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="avatar-lg mx-auto">
                            <div class="avatar-title bg-soft-danger text-danger display-3 rounded-circle" style="width: 100px; height: 100px; line-height: 100px; margin: 0 auto;">
                                <i class="ri-error-warning-fill"></i>
                            </div>
                        </div>
                    </div>

                    <h3 class="fw-bold text-danger mb-2">Transaction Failed</h3>
                    <p class="text-muted fs-15">Something went wrong during the save process. Please check the details below or contact support.</p>

                    <div class="alert alert-danger border-0 mt-4 mb-4" role="alert">
                        <strong>Oops!</strong> There was an issue processing your request. Please try again.
                    </div>
                    <div class="mt-4">
                        <a href="@Url.Action("NotesCategoryMapping", "Master")" class="btn btn-danger d-inline-flex align-items-center gap-1">
                            <i class="ri-arrow-left-line"></i> Back to List
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-soft-success {
        background-color: rgba(69, 203, 133, 0.1) !important;
        color: #45cb85 !important;
    }

    .bg-soft-danger {
        background-color: rgba(240, 101, 72, 0.1) !important;
        color: #f06548 !important;
    }

    .bg-soft-light {
        background-color: rgba(243, 246, 249, 0.1) !important;
    }

    .fs-12 {
        font-size: 12px;
    }

    .fs-15 {
        font-size: 15px;
    }
</style>
