@model GreenLineDataService.Models.Cygnus_Master_Vehicle_DocumentType
@{
    bool isEdit = !string.IsNullOrEmpty(ViewBag.SelectedVehicleType);
    var modeText = isEdit ? "Edit" : "Add";
    ViewBag.Title = modeText + " Document Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">@ViewBag.Title</h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0 shadow-none bg-transparent">
                    <li class="breadcrumb-item"><a href="javascript:void(0);">Master</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Content("~/Master/VehicleType_WiseDocument")"> Document Type List</a></li>
                    <li class="breadcrumb-item active">@modeText</li>
                </ol>
            </div>
        </div>
    </div>
</div>
@using (Html.BeginForm("VehicleDocumentType_Submit", "Master", FormMethod.Post, new { id = "form_sample", @class = "form-modern-ui" }))
{
    @Html.HiddenFor(m => m.Id)

    <div class="row">
        <div class="col-12">
            <div class="card mb-0">
                <div class="card-header border-bottom-dashed d-flex align-items-center py-3">
                    <h5 class="card-title mb-0 flex-grow-1">
                        <i class="ri-file-list-3-line align-middle me-1"></i> Document  Type Details
                    </h5>
                </div>
                <div class="card-body">

                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-label">Document Name</label>
                                @Html.TextBoxFor(m => m.Document_Name, new { @class = "form-control required", @placeholder = "Enter Document Name" })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-label">Short Name</label>
                                @Html.TextBoxFor(m => m.ShortName, new { @class = "form-control required", @placeholder = "Enter Short Name" })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label d-block">Is Date</label>
                                <div class="form-check form-switch form-switch-success pt-1">
                                    @Html.CheckBoxFor(m => m.Is_Date, new { @class = "form-check-input", role = "switch" })
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label d-block">Is Insurance</label>
                                <div class="form-check form-switch form-switch-success pt-1">
                                    @Html.CheckBoxFor(m => m.Is_Insurance, new { @class = "form-check-input", role = "switch" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="form-actions">
                <a href="@Url.Content("~/Master/VehicleDocumentType_List")" class="@ViewBag.UI.Buttons.Cancel.CssClass">
                    <i class="@ViewBag.UI.Buttons.Cancel.Icon"></i> @ViewBag.UI.Buttons.Cancel.Label
                </a>
                <button type="button" id="btnSave" class="@ViewBag.UI.Buttons.Submit.CssClass">
                    <i class="@ViewBag.UI.Buttons.Submit.Icon"></i> @ViewBag.UI.Buttons.Submit.Label
                </button>
            </div>
        </div>
    </div>

}

<script>
    var FormComponents = function (DomainName) {
        var Formvalidate = function (DomainName) {
            var form1 = $('#form_sample');
            var error1 = $('.alert-danger', form1);
            var success1 = $('.alert-success', form1);
            form1.validate({
                doNotHideMessage: true,
                errorElement: 'span', //default input error message container
                errorClass: 'help-block', // default input error message class
                // errorClass: 'validate-inline',
                focusInvalid: false, // do not focus the last invalid input
                rules: {

                },
                messages: {

                },
                errorPlacement: function (error, element) {
                    error.insertAfter(element);
                },
                invalidHandler: function (event, validator) {
                    for (var i = 0; i < validator.errorList.length; i++) {

                    }

                    for (var i in validator.errorMap) {
                    }
                    success1.hide();
                    error1.show();
                    App.scrollTo(error1, -200);
                },
                highlight: function (element) { // hightlight error inputs
                    $(element)
                        .closest('.form-group').addClass('has-error'); // set error class to the control group
                },
                unhighlight: function (element) { // revert the change done by hightlight
                    $(element)
                        .closest('.form-group').removeClass('has-error'); // set error class to the control group
                },
                success: function (label) {
                    label
                        .closest('.form-group').removeClass('has-error'); // set success class to the control group
                },
                submitHandler: function (form) {
                    success1.show();
                    error1.hide();
                    //  form1.submit();
                }
            });
        }
        return {
            init: function (DomainName) {
                Formvalidate(DomainName);
                // Save button click – validate required fields then AJAX POST
                $('#btnSave').on('click', function () {
                    App.blockUI({ boxed: true });
                    if (!$('#form_sample').valid()) {
                        App.unblockUI();
                        return;
                    }

                    $("#form_sample").find(":disabled").prop("disabled", false);

                    document.forms['form_sample'].submit();

                });

                // Remove invalid highlight on input
                $('#frmVehicleDocumentType').on('input change', '.required', function () {
                    if ($.trim($(this).val()) !== '') {
                        $(this).removeClass('is-invalid');
                    }
                });
            }
        }
    }();
</script>