            init: function (DomainName) {

                FormValidate(DomainName);

                $('.required').closest('.form-group').find('label.form-label').addClass('required-field');

                //Events(DomainName);

                //event(DomainName);

                if ('@Model.WFDM.Driver_Id' == 0)

                {

                    $("#WFDM_Date_of_ReJoining").val("");

                    $("#WFDM_Date_of_Exit").val("");

                }

                if ($("#WFDM_Date_of_ReJoining").val() == "01 Jan 1900") {

                    $("#WFDM_Date_of_ReJoining").val("");

                }

                if ($("#WFDM_Date_of_Exit").val() == "01 Jan 1900") {

                    $("#WFDM_Date_of_Exit").val("");

                }

