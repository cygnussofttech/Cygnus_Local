                    var code = $(this).val();

                    var StrURL = DomainName + "/Master/CheckDuplicateDriverCode?Code=" + code + "";

                    $.ajax({

                        url: StrURL,

                        cache: false,

                        data: {},

                        type: 'POST',

                        success: function (data) {

                            if (data.Count > "0") {

                                TosterNotification("error", 'Driver Manual code: <b>"' + code + '"</b> already exists!!!', "Oops..!!");

