                        dateInput.prop("disabled", true);

                        dateButton.prop("disabled", true);

                        $("#exitDate_error").hide();

                    } else {

                        $("#WFDM_VEHNO").removeClass("required required2");

                        dateInput.prop("disabled", false);

                        dateButton.prop("disabled", false);

                        $("#exitDate_error").show();

                    }

                });



