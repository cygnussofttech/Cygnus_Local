                    }

                    else {

                        $("#WFDM_Police_Verification").removeClass("required required2");

                    }

                });



                $("#WFDM_Date_of_ReJoining").on('change', function () {

                    var joiningDate = new Date($("#WFDM_Date_of_Joining").val());

                    var rejoiningDate = new Date($(this).val());



                    if (rejoiningDate <= joiningDate) {

                        $("#rejoining_error").text('Please select the valid Rejoining Date, it should be greater than joining date.');

                    } else {

                        $("#rejoining_error").text('');

                    }

                });



                $("#WFDM_Date_of_Exit").on('change', function () {

                    var joiningDate = new Date($("#WFDM_Date_of_Joining").val());

                    var exitDate = new Date($(this).val());



                    if (exitDate <= joiningDate) {

                        $("#exitDate_error").text('Please select the valid Exit Date, it should be greater than joining date.');

                    }

                    else {

                        $("#exitDate_error").text('');

                    }

                })



                $("#WFDM_D_DOB").on('change', function () {

                    var selectedDate = new Date($(this).val());

                    var currentDate = new Date();

                    var ageDate = new Date(currentDate - selectedDate);

                    var age = Math.abs(ageDate.getUTCFullYear() - 1970);



                    if (age < 18) {

                        $("#DOB_error").text('Age must be 18 years or older.');

                    }

                    else {

                        $("#DOB_error").text('');

                      

                    }

                });



                $('.date-picker').datepicker({

                    rtl: App.isRTL(),

                    format: "dd M yyyy",

                    autoclose: true,

