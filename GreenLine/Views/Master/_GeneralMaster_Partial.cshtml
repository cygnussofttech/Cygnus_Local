@model GreenLineDataService.ViewModel.CYGNUS_Master_GeneralViewModel
@using GreenLineDataService.Models
@{
    bool Status = false;
    if (Model.WMG.StatusCode == null || Model.WMG.StatusCode == "Y" || Model.WMG.StatusCode == "")
    {
        Status = true;
    }
    List<CYGNUS_location> mainZoneList = new List<CYGNUS_location>();
    GreenLineDataService.Helper.Interface.IMasterService _masterService = new GreenLineDataService.Helper.MasterService();

    if (Model.WMG.CodeType.ToUpper() == "ZONE")
    {
        mainZoneList = _masterService.GetLocationDetails().Where(c => c.Loc_Level == 2 && c.ActiveFlag == "Y").ToList();
    }
    List<CYGNUS_Master_General> GenearlList = new List<CYGNUS_Master_General>();
    if (Model.WMG.CodeType.ToUpper() == "HSNCAT")
    {
        GenearlList = _masterService.GetGeneralMasterWithParam("GSTPER").Where(c => c.CodeDesc != "0").ToList();
    }
    if (Model.WMG.CodeType.ToUpper() == "TRN")
    {
        GenearlList = _masterService.GetGeneralMasterWithParam("HSNCAT").Where(c => c.CodeDesc != "0").ToList();
    }

    if (Model.WMG.CodeType.ToUpper() == "VENDTY")
    {
        GenearlList = _masterService.GetGeneralMasterWithParam("VENDTY").Where(c => c.CodeDesc != "0").ToList();
    }
}

@using (Html.BeginForm("AddEditGeneralMaster", "Master", FormMethod.Post, new { id = "form_sample", @class = "form-horizontal form-modern-ui", enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(c => c.WMG.CodeId)
    @Html.HiddenFor(c => c.WMG.CodeType)

    <div class="section-box">
        <h5 class="text-uppercase fw-bold fs-13 mb-2 pb-2 border-bottom border-bottom-dashed text-primary">
            <i class="ri-sound-module-line align-middle me-1"></i> Master Specifications
        </h5>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Code ID</label>
                    @Html.TextBoxFor(c => c.WMG.CodeId, new { placeholder = "System Generated", @class = "form-control bg-light", @readonly = "true" })
                    @Html.ValidationMessageFor(m => m.WMG.CodeId)
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label required-label">@Model.WMCT.Name_Desc</label>
                    @Html.TextBoxFor(m => m.WMG.CodeDesc, new { placeholder = "Enter " + @Model.WMCT.Name_Desc, @class = "required form-control" })
                    @Html.ValidationMessageFor(m => m.WMG.CodeDesc)
                </div>
            </div>

            @if (@Model.WMG.CodeType.ToUpper() == "ZONE")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">Main Zone</label>
                        @Html.DropDownListFor(m => m.WMG.codefor, new SelectList(mainZoneList, "LocCode", "LocName", Model.WMG.codefor), Model.WMG.codefor, new { @class = "select2 form-control required", placeholder = "Select Main Zone" })
                        @Html.ValidationMessageFor(m => m.WMG.codefor)
                    </div>
                </div>
            }
            @if (@Model.WMG.CodeType.ToUpper() == "HSNCAT")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">SAC Code</label>
                        @Html.TextBoxFor(m => m.WMG.codefor, new { placeholder = "Enter SAC Code", @class = "required form-control text-uppercase" })
                        @Html.ValidationMessageFor(m => m.WMG.codefor)
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">GST %</label>
                        @Html.DropDownListFor(m => m.WMG.noofdigits, new SelectList(GenearlList, "CodeId", "CodeDesc", Model.WMG.noofdigits), Model.WMG.noofdigits.ToString(), new { @class = "select2 form-control required", placeholder = "Select GST %" })
                        @Html.ValidationMessageFor(m => m.WMG.noofdigits)
                    </div>
                </div>
            }
            @if (@Model.WMG.CodeType.ToUpper() == "TRN")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">SAC Code</label>
                        @Html.DropDownListFor(m => m.WMG.codefor, new SelectList(GenearlList, "CodeId", "CodeDesc", Model.WMG.codefor), Model.WMG.codefor, new { @class = "select2 form-control required", placeholder = "Select SAC Code" })
                        @Html.ValidationMessageFor(m => m.WMG.codefor)
                    </div>
                </div>
            }

            @if (@Model.WMG.CodeType.ToUpper() == "VENDTY")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">Select Module</label>
                        @Html.TextBoxFor(m => m.WMG.codefor, new { placeholder = "Select Module", @class = "required form-control text-uppercase " })
                        @Html.ValidationMessageFor(m => m.WMG.codefor)
                    </div>
                </div>
            }
            @if (@Model.WMG.CodeType.ToUpper() == "VSL")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required-label">Days</label>
                        @Html.TextBoxFor(m => m.WMG.noofdigits, new { placeholder = "Enter Days", @class = "required form-control text-uppercase " })
                        @Html.ValidationMessageFor(m => m.WMG.noofdigits)
                    </div>
                </div>
            }

            @if (Model.WMG.CodeId != null && Model.WMG.CodeId != "")
            {
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Active Status</label>
                        <div class="form-check form-switch form-switch-md pt-1">
                            @Html.CheckBox("WMG_StatusCode", @Status, new { @class = "form-check-input" })
                        </div>
                    </div>
                </div>
            }
            else
            {
                @Html.Hidden("WMG_StatusCode", true)
            }
        </div>
    </div>
}
