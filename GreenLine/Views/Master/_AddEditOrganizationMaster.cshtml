                    <i class="@ViewBag.UI.Buttons.Previous.Icon"></i> <lable id="btn_Tab_2_Previous_txt">@ViewBag.UI.Buttons.Previous.Label</lable>
                </button>
                <button type="button" class="@ViewBag.UI.Buttons.Submit.CssClass" id="btn_SaveOrgDetails">
                    <i class="@ViewBag.UI.Buttons.Submit.Icon"></i> <lable id="btn_SaveOrgDetails_txt">@ViewBag.UI.Buttons.Submit.Label</lable>
