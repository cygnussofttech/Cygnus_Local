}

<script type="text/javascript">
    var bankData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(bankList));

    var bindLocationByPincodeApi = function (code, type, callback) {

        var url = DomainName + "/Master/Get_Country_State_City_Zone_on_Pincode?Code=" + code + "&Type=" + type;

        $.ajax({
            url: url,
            cache: false,
            type: "GET",
            success: function (response) {
                if (response && response.length > 0) {
                    var item = response[0];

                    if (type === 'P') {
                        if (item.CountryId) {
                            $("#OrgDet_Country_Code").val(item.CountryId);
                            $("#OrgDet_Country_Code").select2("data", { id: item.CountryId, text: item.CountryName || "India" });
                            $("#hfCountryCode").val(item.CountryId);
                        }
                        if (item.StateCode) {
                            $("#OrgDet_State_Code").val(item.StateCode);
                            $("#OrgDet_State_Code").select2("data", { id: item.StateCode, text: item.stnm || item.StateName || "" });
                            $("#hfStateCode").val(item.StateCode);
                        }
                        if (item.CityCode) {
                            $("#OrgDet_City_Code").val(item.CityCode);
                            $("#OrgDet_City_Code").select2("data", { id: item.CityCode, text: item.CityName || "" });
                            $("#hfCityCode").val(item.CityCode);
                        }
                    }

                    if (callback) callback(true);
                } else {
                    if (callback) callback(false);
                }
            },
            error: function () {
                if (callback) callback(false);
            }
        });
    };

    // ✅ Normalize IsActive
    bankData.forEach(function (item) {
        item.IsActive = (item.IsActive === true || item.IsActive === "True" || item.IsActive == 1) ? 1 : 0;
    });

    var editIndex = -1;

    var Formvalidate = function (DomainName) {

        var form1 = $('#form_sample');
        form1.validate({
            doNotHideMessage: true,
            errorElement: 'span',
            errorClass: 'help-block',
            focusInvalid: false,
            ignore: ":hidden:not(.select2-hidden-accessible)",
            rules: {},
            messages: {},
            errorPlacement: function (error, element) {
                if (element.parent(".input-group").length > 0) {
                    error.insertAfter(element.parent(".input-group"));
                } else if (element.hasClass("select2-hidden-accessible") || element.next(".select2-container").length > 0) {
                    error.insertAfter(element.next(".select2-container"));
                } else {
                    error.insertAfter(element);
                }
            },
            highlight: function (element) {
                $(element).closest('.form-group').addClass('has-error');
            },
            unhighlight: function (element) {
                $(element).closest('.form-group').removeClass('has-error');
            },
            success: function (label) {
                label.closest('.form-group').removeClass('has-error');
            }
        });
    }

    function FillDropDownfromOtherTest(DDLName, StrURL, DllType, callback) {
        var $ddl = $("#" + DDLName);

        $ddl.empty();

        // ✅ IMPORTANT empty option
        $ddl.html('<option value=""></option>');

        $.get(StrURL, function (data) {

            $ddl.append('<option value="">Select ' + (DllType || 'Option') + '</option>');

            for (var i = 0; i < data.length; i++) {
                var val = data[i].Value !== undefined ? data[i].Value : data[i].value;
                var txt = data[i].Text !== undefined ? data[i].Text : data[i].text;
                $ddl.append('<option value="' + val + '">' + txt + '</option>');
            }

            // ✅ destroy old select2
            if ($ddl.hasClass("select2-hidden-accessible")) {
                $ddl.select2('destroy');
            }

            // ✅ init select2
            $ddl.select2({
                placeholder: 'Select ' + (DllType || 'Option'),
                allowClear: true,
                width: '100%'
            });

            // ✅ reset value so placeholder shows
            $ddl.select2("val", "");

            if (callback) callback(data);

        }, "json");
    }

    function validateGSTPattern(input) {

        let value = input.value.toUpperCase();
        let result = '';

        for (let i = 0; i < value.length; i++) {

            let ch = value[i];
            // 1-2 Numeric
            if (i <= 1) {
                if (/[0-9]/.test(ch)) {
                    result += ch;
                }
            }
            // 3-7 Alphabet
            else if (i >= 2 && i <= 6) {
                if (/[A-Z]/.test(ch)) {
                    result += ch;
                }
            }
            // 8-11 Numeric
            else if (i >= 7 && i <= 10) {
                if (/[0-9]/.test(ch)) {
                    result += ch;
                }
            }
            // 12 Alphabet
            else if (i == 11) {
                if (/[A-Z]/.test(ch)) {
                    result += ch;
                }
            }
            // 13 Numeric
            else if (i == 12) {
                if (/[0-9]/.test(ch)) {
                    result += ch;
                }
            }
            // 14 Alphabet
            else if (i == 13) {
                if (ch === 'Z') {
                    result += ch;
                }
            }
            // 15 AlphaNumeric
            else if (i == 14) {
                if (/[A-Z0-9]/.test(ch)) {
                    result += ch;
                }
            }
        }
        input.value = result;

        // ✅ GST Complete
        if (result.length === 15) {
            // avoid multiple calls for the SAME GST number
            if (input.dataset.lastfetchedgst !== result) {

                input.dataset.lastfetchedgst = result;

                // GST Validation
                if (ValidateField(input.id, 'gst')) {

                    // CALL FUNCTION
                    GetGSTDetails(input.id);
                }
            }
        }
    }

    function validateIFSCPattern(input) {
        let value = input.value.toUpperCase();
        let result = '';

        for (let i = 0; i < value.length; i++) {
            let ch = value[i];

            // First 4 characters: A-Z
            if (i <= 3) {
                if (/[A-Z]/.test(ch)) {
                    result += ch;
                }
            }
            // 5th character: must be '0'
            else if (i === 4) {
                if (ch === '0') {
                    result += ch;
                }
            }
            // Last 6 characters (index 5 to 10): A-Z0-9
            else if (i >= 5 && i <= 10) {
                if (/[A-Z0-9]/.test(ch)) {
                    result += ch;
                }
            }
        }
        input.value = result;

        // ✅ IFSC Complete
        if (result.length === 11) {
            ValidateField(input.id, 'ifsc');
        }
    }

    var clearGSTFields = function (id1) {
        var gstInput = $("#" + id1);
        gstInput.val("");
        if (gstInput[0]) gstInput[0].dataset.lastfetchedgst = "";

        $("#OrgDet_PANNo").val("");
        $("#OrgDet_BRCD").val("");
        $("#OrgDet_COMPANY_NAME").val("");
        $("#OrgDet_ADDRESS").val("");
        $("#OrgDet_PinCode").val("").trigger("change");
        $("#OrgDet_Country_Code").val("").trigger("change");
        $("#OrgDet_State_Code").val("").trigger("change");
        $("#OrgDet_City_Code").val("").trigger("change");
        $("#OrgDet_Biling_Type").val("").trigger("change");
    }

    var GetGSTDetails = function (id1) {
        var GSTNO = $("#" + id1).val();

        if (GSTNO != "" && GSTNO != null) {
            App.blockUI({ boxed: true });

            var StrURL1 = DomainName + '/Master/GetGSTDetails?GSTNO=' + GSTNO;

            $.ajax({
                url: StrURL1,
                cache: false,
                type: 'POST',
                success: function (response) {
                    if (response.Status) {
                        var Data = response.Data[0];

                        $("#OrgDet_PANNo").val(Data.PanNo);
                        $("#OrgDet_COMPANY_NAME").val(Data.legalName || Data.TradeName);
                        $("#OrgDet_ADDRESS").val(Data.CSGEAddress);

                        if (Data.PinCode != null && Data.PinCode != '') {
                            $("#OrgDet_PinCode").val(Data.PinCode).trigger("change");
                        } else {
                            $("#OrgDet_PinCode").val("").trigger("change");
                        }

                        App.unblockUI();
                    }
                    else {
                        clearGSTFields(id1);

                        TosterNotification(
                            "error",
                            response.Message,
                            "Error"
                        );
                        App.unblockUI();
                    }
                },
                error: function (req, status, error) {
                    clearGSTFields(id1);

                    TosterNotification(
                        "error",
                        "Something went wrong",
                        "Error"
                    );
                    App.unblockUI();
                }
            });
        }
    }

    function getShortName(companyName) {
        if (!companyName || companyName.trim() === "")
            return "";

        let words = companyName.trim().split(/\s+/);

        let shortName = "";

        words.forEach(function (word) {
            shortName += word.charAt(0).toUpperCase();
        });

        return shortName;
    }

    var FormComponents = function () {
        function loadFormForEdit(item) {
            $("#OrgBnkDet_Beneficiary_Name").val(item.Beneficiary_Name);
            $("#OrgBnkDet_Bank_Name").val(item.Bank_Name);
            $("#OrgBnkDet_Bank_Account_No").val(item.Bank_Account_No);
            $("#OrgBnkDet_Branch_Name").val(item.Branch_Name);
            $("#OrgBnkDet_IFSC_Code").val(item.IFSC_Code);
            $("#OrgBnkDet_MICR_Code").val(item.MICR_Code);
            $("#OrgBnkDet_RTGS_NEFT_Code").val(item.RTGS_NEFT_Code);
            $("#OrgBnkDet_Bank_Address").val(item.Bank_Address);

            // Store index
                editIndex = bankData.findIndex(function (x) { return x.Bank_Account_No.trim() === item.Bank_Account_No.trim() && x.Bank_Name === item.Bank_Name; });

            // Change button text
            $("#btn_AddBankDetails_txt").text("Update");
        }

        function validateTab(tabId) {
            var isValid = true;

            $("#" + tabId + " .required").each(function () {
                var $this = $(this);

                if (!$this.is("input, select, textarea")) return;

                var value = $this.val();

                if (value === null || value === "" || (typeof value === "string" && value.trim() === "")) {

                    isValid = false;

                    //$this.addClass("is-invalid");

                    $this.closest(".form-group").find(".help-block").remove();

                    if ($this.hasClass("select2-hidden-accessible")) {
                        $this.next(".select2-container").after('<div class="help-block">This field is required</div>');
                    } else {
                        $this.after('<div class="help-block">This field is required</div>');
                    }
                }
                else {
                    //$this.removeClass("is-invalid");
                    $this.closest(".form-group").find(".help-block").remove();
                }
            });

            return isValid;
        }

        function refreshBankTable() {
            GlDataTable.refresh("tblBank", {
                data: bankData,
                statusFilter: 8,
                columns: [
                    { data: "Beneficiary_Name" },
                    { data: "Bank_Name" },
                    { data: "Bank_Account_No" },
                    { data: "IFSC_Code" },
                    { data: "Branch_Name" },
                    { data: "MICR_Code" },
                    { data: "RTGS_NEFT_Code" },
                    { data: "Bank_Address" },
                    { data: "IsActive" },
                    { data: "Bank_Account_No" } // use account no as key for action column
                ],
                columnDefs: [
                    {
                        targets: [8],
                        render: function (data, type, full, meta) {
                            var isActive = data == 1 ? "checked" : "";
                            return '<label class="switch"><input type="checkbox" ' + isActive + ' class="btnToggleStatus" data-index="' + meta.row + '" data-name="' + full.Bank_Name + '"><span class="slider round"></span></label>';
                        }
                    },
                    {
                        targets: [9],
                        render: function (data, type, full) {
                            var index = bankData.findIndex(function (x) { return x.Bank_Account_No === data; });
                            return '<button type="button" class="@ViewBag.UI.Buttons.Edit.CssClass me-1 btnBankEdit" title="Edit" data-index="' + index + '">' +
                                    '<i class="@ViewBag.UI.Buttons.Edit.Icon"></i></button>' +
                                    '<button type="button" class="@ViewBag.UI.Buttons.Delete.CssClass btnBankDelete" title="Delete" data-index="' + index + '">' +
                                    '<i class="@ViewBag.UI.Buttons.Delete.Icon"></i></button>';
                        }
                    },
                    { orderable: false, targets: [8, 9] }
                ],
                createdRow: function (row, data) {
                    $(row).find('td').addClass('text-center');
                }
            });
        }

        return {
            init: function (DomainName) {

                Formvalidate(DomainName);

                // Add indicator class to all required field labels
                $('.required').closest('.form-group').find('label.form-label').addClass('required-field');

                // Sync status toggle to hidden field
                $(document).off("change", "#chkActive").on("change", "#chkActive", function () {
                    $("#hfIsActive").val($(this).is(":checked"));
                });

                $("#OrgDet_Biling_Type").change(function () {
                    var billtype = $("#OrgDet_Biling_Type option:selected").text();
                    var orgName = getShortName($("#OrgDet_COMPANY_NAME").val());
                    var brcd = orgName + ' - ' + billtype
                    $("#OrgDet_BRCD").val(brcd);
                });

                $("#fileUpload").change(function () {
                    var file = this.files[0];
                    if (file) {
                        validateImageFile(file, this);
                    }
                });

                $("#customTabs li a").click(function (e) {
                    e.preventDefault();

                    var clickedTab = $(this).attr("href");
                    var clickedPaneId = clickedTab.replace("#", "");

                    var currentTabLink = $("#customTabs .nav-link.active");
                    var currentTab = currentTabLink.attr("href");
                    var activePaneId = currentTab.replace("#", "");

                    var currentIndex = parseInt(activePaneId.replace("tab_", ""));
                    var clickedIndex = parseInt(clickedPaneId.replace("tab_", ""));

                    // Only validate if navigating forward
                    if (clickedIndex > currentIndex) {
                        for (var i = currentIndex; i < clickedIndex; i++) {
                            if (i === 0) {
                                if (!validateTab("tab_0")) {
                                    TosterNotification("error", "Please fill all required fields", "Error");
                                    return;
                                }
                            } else if (i === 1) {
                                if (bankData.length === 0) {
                                    TosterNotification("error", "Please add at least one bank detail", "Error");
                                    return;
                                }
                            }
                        }
                    }

                    // ✅ REMOVE ALL VALIDATION ERROR LABELS
                    $(".form-control, select").removeClass("help-block");
                    $(".help-block").remove();

                    // Tab switch logic
                    $("#customTabs .nav-link").removeClass("active");
                    $(this).addClass("active");

                    $(".tab-pane").removeClass("active").hide();
                    $(clickedTab).fadeIn(200).addClass("active");
                });

                $(document).off("click", ".btn-next").on("click", ".btn-next", function () {
                    var currentTab = $(this).closest(".tab-pane").attr("id");
                    var nextTab = $(this).data("next");

                    if (currentTab === "tab_0") {
                        if (!validateTab("tab_0")) {
                            TosterNotification("error", "Please fill all required fields", "Error");
                            return;
                        }
                    } else if (currentTab === "tab_1") {
                        if (bankData.length === 0) {
                            TosterNotification("error", "Please add at least one bank detail", "Error");
                            return;
                        }
                    }

                    // Switch tab
                    $('#customTabs li').removeClass("active");
                    $('#customTabs .nav-link').removeClass("active");
                    $('#customTabs li a[href="' + nextTab + '"]').addClass("active").parent().addClass("active");

                    $(".tab-pane").removeClass("active").hide();
                    $(nextTab).fadeIn(200).addClass("active");

                    // ✅ REMOVE ALL VALIDATION ERROR LABELS
                    $(".form-control, select").removeClass("help-block");
                    $(".help-block").remove();
                });

                $(document).off("click", ".btn-previous").on("click", ".btn-previous", function () {
                    var nextTab = $(this).data("next");

                    // Switch tab without validating
                    $('#customTabs li').removeClass("active");
                    $('#customTabs .nav-link').removeClass("active");
                    $('#customTabs li a[href="' + nextTab + '"]').addClass("active").parent().addClass("active");

                    $(".tab-pane").removeClass("active").hide();
                    $(nextTab).fadeIn(200).addClass("active");

                    // ✅ REMOVE ALL VALIDATION ERROR LABELS
                    $(".form-control, select").removeClass("help-block");
                    $(".help-block").remove();
                });

                $(document).on("input change", ".form-control, select", function () {
                    var $this = $(this);

                    if ($this.val() && $this.val().toString().trim() !== "") {
                        $this.closest(".form-group").find(".help-block").remove();
                    }
                });

                $(document).on("change", ".select2", function () {
                    var $this = $(this);

                    if ($this.val()) {
                        $this.closest(".form-group").find(".help-block").remove();
                    }
                });

                // Pincode Change → Auto-bind Country, State, City
                $(document).off("change", "#OrgDet_PinCode").on("change", "#OrgDet_PinCode", function () {
                    var pincode = $(this).val();
                    if (pincode && pincode.trim().length === 6) {
                        bindLocationByPincodeApi(pincode, 'P');
                    } else {
                        $("#OrgDet_Country_Code").val("").trigger("change");
                        $("#OrgDet_State_Code").val("").trigger("change");
                        $("#OrgDet_City_Code").val("").trigger("change");
                        $("#hfCountryCode").val("");
                        $("#hfStateCode").val("");
                        $("#hfCityCode").val("");
                    }
                });

                $(document).off("click", "#btn_CancelBankDetails").on("click", "#btn_CancelBankDetails", function () {

                    // Clear all input fields inside tab_1
                    $("#tab_1 input.form-control").val("");

                    // Remove validation errors
                    $("#tab_1 .form-control").removeClass("help-block");
                    $("#tab_1 .help-block").remove();

                    editIndex = -1;
                    $("#btn_AddBankDetails_txt").text("Add");

                });

                $(document).off("click", "#btn_AddBankDetails").on("click", "#btn_AddBankDetails", function () {
                    if (!validateTab("tab_1")) {
                        TosterNotification("error", "Please fill all required fields", "Error");
                        return;
                    }

                    var item = {
                        SrNo: editIndex === -1 ? 0 : (bankData[editIndex].SrNo || 0),
                        Beneficiary_Name: $("#OrgBnkDet_Beneficiary_Name").val(),
                        Bank_Name: $("#OrgBnkDet_Bank_Name").val(),
                        Bank_Account_No: $("#OrgBnkDet_Bank_Account_No").val(),
                        Branch_Name: $("#OrgBnkDet_Branch_Name").val(),
                        IFSC_Code: $("#OrgBnkDet_IFSC_Code").val(),
                        MICR_Code: $("#OrgBnkDet_MICR_Code").val(),
                        RTGS_NEFT_Code: $("#OrgBnkDet_RTGS_NEFT_Code").val(),
                        Bank_Address: $("#OrgBnkDet_Bank_Address").val(),
                        IsActive: editIndex === -1 ? 1 : bankData[editIndex].IsActive
                    };

                    // ✅ Duplicate check
                    var exists = bankData.some((x, i) => x.Bank_Account_No.trim() === item.Bank_Account_No && i !== editIndex);
                    if (exists) {
                        TosterNotification("error", "Account No already exists", "Error");
                        return;
                    }

                    if (editIndex === -1) {
                        bankData.push(item);
                    }
                    else {
                        bankData[editIndex] = item;
                        editIndex = -1;
                        $("#btn_AddBankDetails_txt").text("Add");
                    }

                    // ✅ Refresh DataTable
                    refreshBankTable();

                    // ✅ Clear inputs
                    $("#tab_1 input.form-control").val("");
                });

                // Initialize Bank table using GlDataTable (same approach as StateMaster)
                refreshBankTable();

                // Edit button - delegated
                $(document).off("click", ".btnBankEdit").on("click", ".btnBankEdit", function (e) {
                    e.preventDefault();
                    var idx = parseInt($(this).data("index"));
                    if (idx >= 0 && idx < bankData.length) {
                        loadFormForEdit(bankData[idx]);
                    }
                });

                // Delete button - delegated
                $(document).off("click", ".btnBankDelete").on("click", ".btnBankDelete", function (e) {
                    e.preventDefault();
                    var idx = parseInt($(this).data("index"));
                    if (idx >= 0 && idx < bankData.length) {
                        var item = bankData[idx];
                        showConfirm({
                            title: "Delete Bank",
                            message: 'Are you sure you delete this bank <strong style="color:#405189">"' + item.Bank_Name + '"</strong>?',
                            type: "delete",
                            confirmText: "Yes",
                            cancelText: "No",
                            onConfirm: function () {
                                bankData.splice(idx, 1);
                                GLModal.showSuccess("Bank deleted locally!");
                                refreshBankTable();
                            }
                        });
                    }
                });

                // Toggle active - delegated
                $(document).off("click", ".btnToggleStatus").on("click", ".btnToggleStatus", function (e) {
                    e.preventDefault();
                    var checkbox = $(this);
                    var index = parseInt(checkbox.data("index"));
                    var name = checkbox.data("name");
                    var isChecked = checkbox.is(':checked');

                    // Revert until confirmed
                    checkbox.prop('checked', !isChecked);

                    var action = isChecked ? "Activate" : "Inactivate";
                    var type = isChecked ? "success" : "info";

                    showConfirm({
                        title: action + " Bank",
                        message: 'Are you sure you want to <strong>' + action.toLowerCase() + '</strong> status for bank <strong style="color:#405189">"' + name + '"</strong>?',
                        type: type,
                        confirmText: "Yes",
                        cancelText: "No",
                        onConfirm: function () {
                            if (index >= 0 && index < bankData.length) {
                                bankData[index].IsActive = bankData[index].IsActive == 1 ? 0 : 1;
                                GLModal.showSuccess("Status updated locally!");
                                refreshBankTable();
                            }
                        }
                    });
                });

                $(document).off("click", "#btn_SaveOrgDetails").on("click", "#btn_SaveOrgDetails", function () {
                    if (!validateTab("tab_0")) {
                        TosterNotification("error", "Please fill all required fields", "Error");
                        return;
                    }

                    if (bankData.length === 0) {
                        TosterNotification("error", "Please add at least one bank detail", "Error");
                        return;
                    }
                    $("#hdnBankData").val(JSON.stringify(bankData));

                    //if (!$("#form_sample").valid()) {
                    //    TosterNotification("error", "Please fill all required fields", "Error");
                    //    return;
                    //}

                    $("#form_sample").submit();
                });
            }
        }
    }();
</script>