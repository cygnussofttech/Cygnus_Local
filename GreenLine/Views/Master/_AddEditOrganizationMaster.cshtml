@model GreenLineDataService.Models.CYGNUS_Organization_Master
@using GreenLineDataService.Models;

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Organization";
}

@{
    var buttonText = (Model.OrgDet.COMPANY_CODE == "0" ? "Add" : "Edit");

    var bankList = Model.OrgBnkDetList ?? new List<Organization_Bank_Details>();

    GreenLineDataService.Helper.Interface.IMasterService _masterService = new GreenLineDataService.Helper.MasterService();

    List<CYGNUS_Master_General> BillType = _masterService.GetGeneralMaster().Where(c => c.CodeType == "BILLTYP" && c.StatusCode == "Y").ToList();
    List<CYGNUX_Master_Countries> CountryList = _masterService.GetCountryMaster().ToList();
    List<CYGNUS_State> StateList = _masterService.GetStateMaster().ToList();
    List<CYGNUS_citymaster> CityList = _masterService.GetCityMaster().ToList();
    List<CYGNUS_pincode_master> ListPincode = _masterService.GetPincodeMaster().Where(c => c.ActiveFlag == "Y").GroupBy(c => c.pincode).Select(g => g.First()).OrderBy(c => c.pincode).ToList();
}

<style>
    /*image logo*/
    #imgContainer {
        transition: all 1s ease;
    }

    .ui-page-header {
        margin: 1rem 0 !important;
        padding: 5px 0px !important;
    }

    span.field-validation-error, span.error, label.error, form .help-block, .has-error .help-block, span.help-block[id$="-error"] {
        color: #f06548 !important;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    input.error, select.error, .has-error .select2-selection {
        border-color: #b94a48 !important;
    }

    /* Modern Tab Container */
    .custom-tabs-container {
        background: #ffffff;
        border-radius: 12px;
        padding: 8px;
        border: 1px solid rgba(223, 227, 235, 0.6);
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
        margin-bottom: 10px;
    }

    /* Modern Pills Styles */
    .custom-modern-pills {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 6px;
        padding: 0;
        margin: 0;
        list-style: none;
        border: none !important;
        scrollbar-width: none; /* Hide scrollbar for Firefox */
    }

        .custom-modern-pills::-webkit-scrollbar {
            display: none; /* Hide scrollbar for Chrome/Safari */
        }

        .custom-modern-pills .nav-item {
            flex: 0 0 auto;
        }

        .custom-modern-pills .nav-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #64748b;
            border-radius: 8px;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
        }

            .custom-modern-pills .nav-link i {
                font-size: 16px;
                transition: transform 0.25s ease;
            }

            /* Hover styles */
            .custom-modern-pills .nav-link:hover {
                color: #4f46e5;
                background-color: #f8fafc;
            }

                .custom-modern-pills .nav-link:hover i {
                    transform: translateY(-1px);
                }

            /* Active state */
            .custom-modern-pills .nav-link.active {
                color: #ffffff !important;
                background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%) !important;
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25) !important;
            }

                .custom-modern-pills .nav-link.active i {
                    color: #ffffff !important;
                }

    @@media (max-width: 768px) {
        .custom-modern-pills .nav-item {
            flex: 1 1 0 !important;
        }

        .custom-modern-pills .nav-link {
            padding: 10px 0 !important;
            gap: 0 !important;
            justify-content: center !important;
        }

            .custom-modern-pills .nav-link span {
                display: none !important;
            }

            .custom-modern-pills .nav-link i {
                font-size: 18px !important;
            }
    }

    /* Make select2 readonly visually but still submit */
    .select2-readonly + .select2-container {
        pointer-events: none;
        opacity: 0.8;
    }
</style>

<!-- start page title -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-0">
                @buttonText @ViewBag.Title
            </h4>

            <div class="page-title-right">
                <ol class="breadcrumb m-0 shadow-none bg-transparent">
                    <li class="breadcrumb-item">Master</li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Organization", "Master")">Organization</a>
                    </li>
                    <li class="breadcrumb-item active">@buttonText</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<!-- end page title -->
<!-- Tab Navigation -->
<div class="custom-tabs-container">
    <ul class="nav nav-tabs custom-modern-pills" role="tablist" id="customTabs">
        <li class="nav-item">
            <a class="nav-link active" href="#tab_0" role="tab">
                <i class="ri-information-line"></i> <span>Information</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#tab_1" role="tab">
                <i class="ri-bank-line"></i> <span>Bank Details</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#tab_2" role="tab">
                <i class="ri-receipt-line"></i> <span> E-Invoice</span>
            </a>
        </li>
    </ul>
</div>

@using (Html.BeginForm("AddEditOrganization", "Master", FormMethod.Post, new { id = "form_sample", @class = "form-modern-ui", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(m => m.OrgDet.COMPANY_CODE)
    @Html.Hidden("OrgDet.City_Code", Model.OrgDet.City_Code, new { id = "hfCityCode" })
    @Html.Hidden("OrgDet.State_Code", Model.OrgDet.State_Code, new { id = "hfStateCode" })
    @Html.Hidden("OrgDet.Country_Code", Model.OrgDet.Country_Code, new { id = "hfCountryCode" })

    <div class="tab-content text-muted">
        <!-- GST Details -->
        <div class="tab-pane active" id="tab_0">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0 flex-grow-1">
                                <i class="ri-file-info-line align-middle me-1"></i> GST Details
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">GST Number</label>
                                        @Html.TextBoxFor(m => m.OrgDet.GST_Number, new { placeholder = "Enter GST Number", @maxlength = "15", @class = "required form-control", oninput = "validateGSTPattern(this)", onchange = "validateGSTPattern(this)", onpaste = "setTimeout(() => validateGSTPattern(this), 0)", onblur = "ValidateField(this.id, 'gst')" })
                                        <small class="text-muted d-block mt-1">
                                            Format: 22AAAAA0000A1Z5
                                        </small>
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">PAN No</label>
                                        @Html.TextBoxFor(m => m.OrgDet.PANNo, new { placeholder = "Enter Pan No", @maxlength = "10", @class = "required form-control", @readonly = true })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Organization Name</label>
                                        @Html.TextBoxFor(m => m.OrgDet.COMPANY_NAME, new { placeholder = "Enter Organization Name", @class = "required form-control", @readonly = true })
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Biling Type</label>
                                        @Html.DropDownListFor(m => m.OrgDet.Biling_Type, new SelectList(BillType, "CodeId", "CodeDesc", Model.OrgDet.Biling_Type), "", new { @class = "select2 form-control required", @placeholder = "Select Billing Type" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">PinCode</label>
                                        @Html.DropDownListFor(m => m.OrgDet.PinCode, new SelectList(ListPincode, "pincode", "pincode", Model.OrgDet.PinCode), "", new { @class = "required select2 form-control", @placeholder = "Select PinCode" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">City Name</label>
                                        @Html.DropDownListFor(m => m.OrgDet.City_Code, new SelectList(CityList, "city_code", "Location", Model.OrgDet.City_Code), "", new { @class = "required select2 form-control", @placeholder = "Select City", @disabled = "disabled" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">State Name</label>
                                        @Html.DropDownListFor(m => m.OrgDet.State_Code, new SelectList(StateList, "stcd", "stnm", Model.OrgDet.State_Code), "", new { @class = "required select2 form-control", @placeholder = "Select State", @disabled = "disabled" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Country Name</label>
                                        @Html.DropDownListFor(m => m.OrgDet.Country_Code, new SelectList(CountryList, "Id", "CountryName", Model.OrgDet.Country_Code), "", new { @class = "required select2 form-control", @placeholder = "Select Country", @disabled = "disabled" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Branch Code</label>
                                        @Html.TextBoxFor(m => m.OrgDet.BRCD, new { placeholder = "Enter Branch Code", @class = "required form-control", @readonly = true })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">SAP Code</label>
                                        @Html.TextBoxFor(m => m.OrgDet.Sap_Code, new { placeholder = "Enter SAP Code", @class = "required form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--Basic  Information -->
            <div class="row">
                <div class="col-md-12">
                    <div class="card mb-0">
                        <div class="card-header">
                            <h5 class="card-title mb-0 flex-grow-1">
                                <i class="ri-information-line align-middle me-1"></i> Basic Information
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Address</label>
                                        @Html.TextAreaFor(m => m.OrgDet.ADDRESS, new { placeholder = "Enter Address", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Address 1</label>
                                        @Html.TextAreaFor(m => m.OrgDet.Address1, new { placeholder = "Enter Address 1", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Address 2</label>
                                        @Html.TextAreaFor(m => m.OrgDet.Address2, new { placeholder = "Enter Address 2", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Location</label>
                                        @Html.TextBoxFor(m => m.OrgDet.Location, new { placeholder = "Enter Location", @class = "form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Mobile No</label>
                                        @Html.TextBoxFor(m => m.OrgDet.CONTACTNO, new { placeholder = "Enter Mobile No", @class = "form-control", @maxlength = "10", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", onblur = "ValidateField(this.id, 'mobile')" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Email</label>
                                        @Html.TextBoxFor(m => m.OrgDet.Email, new { placeholder = "Enter Email", @class = "form-control", onblur = "ValidateField(this.id, 'email')" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">CIN Number</label>
                                        @Html.TextBoxFor(m => m.OrgDet.CINNumber, new { placeholder = "Enter CIN Number", @class = "form-control" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Employee Code</label>
                                        @Html.TextBoxFor(m => m.OrgDet.Employee_Code, new { placeholder = "Enter Employee Code", @class = "form-control" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Invoice Bottom Address</label>
                                        @Html.TextAreaFor(m => m.OrgDet.Invoice_Bottom_Address, new { placeholder = "Enter Invoice Bottom Address", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Trip Series</label>
                                        @Html.TextBoxFor(m => m.OrgDet.Trip_Series, new { placeholder = "Enter Trip Series", @class = "form-control" })
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Organization Person Name</label>
                                        @Html.TextBoxFor(m => m.OrgDet.CONTACT_PERSON, new { placeholder = "Enter Organization Person Name", @class = "form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Register Office Address</label>
                                        @Html.TextAreaFor(m => m.OrgDet.Register_Office_Address, new { placeholder = "Enter Register Office Address", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Terms And Condition</label>
                                        @Html.TextAreaFor(m => m.OrgDet.TermsAndCondition, new { placeholder = "Enter Terms And Condition", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">LR Terms And Condition</label>
                                        @Html.TextAreaFor(m => m.OrgDet.LR_Terms_And_Condition, new { placeholder = "Enter LR Terms And Condition", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Credit Debit Terms And Condition</label>
                                        @Html.TextAreaFor(m => m.OrgDet.Credit_Debit_Terms_And_Condition, new { placeholder = "Enter Credit Debit Terms And Condition", @class = "form-control", style = "height: 38px; min-height: 38px; resize: vertical;" })
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Status</label>
                                        <div class="form-check form-switch mt-1">
                                            <input type="checkbox" class="form-check-input" id="chkActive" @(Model.OrgDet.IsActive ? "checked" : "")>
                                        </div>
                                        @Html.HiddenFor(m => m.OrgDet.IsActive, new { id = "hfIsActive" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-4">
                                    <div class="form-group">
                                        <label class="form-label">Company Logo</label>
                                        <!-- Hidden value -->
                                        <input type="hidden" value="@Model.OrgDet.CompanyLogoUrl" name="OrgDet.CompanyLogoUrl" id="CompanyLogoUrl">
                                        <!-- File Upload -->
                                        <input type="file" id="fileUpload" name="fileUpload" class="form-control" accept="image/*" />
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(Model.OrgDet.CompanyLogoUrl))
                                {
                                    var logoPath = Model.OrgDet.CompanyLogoUrl.StartsWith("~") || Model.OrgDet.CompanyLogoUrl.StartsWith("http") 
                                       ? Model.OrgDet.CompanyLogoUrl 
                                       : "~/assets/img/logos/" + Model.OrgDet.CompanyLogoUrl;
                                    <div class="col-lg-3 col-md-4">
                                        <div class="form-group">
                                            <label class="form-label">&nbsp;</label>
                                            <div>
                                                <a href="@Url.Content(logoPath)" target="_blank" class="btn btn-sm btn-outline-success">
                                                    <i class="ri-image-line align-bottom me-1"></i> View Photo
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Organization", "Master")" class="@ViewBag.UI.Buttons.Cancel.CssClass"><i class="@ViewBag.UI.Buttons.Cancel.Icon"> </i>&nbsp;@ViewBag.UI.Buttons.Cancel.Label</a>
                <button type="button" class="@ViewBag.UI.Buttons.Next.CssClass btn-next" id="btn_Tab_0_Next" data-next="#tab_1">
                    <i class="@ViewBag.UI.Buttons.Next.Icon"></i> <lable id="btn_Tab_0_Next_txt">@ViewBag.UI.Buttons.Next.Label</lable>
                </button>
            </div>
        </div>

        <!-- Bank Details -->
        <div class="tab-pane" id="tab_1">
            <div class="row">
                <div class="col-md-12">
                    <div class="card mb-0">
                        <div class="card-header">
                            <h5 class="card-title mb-0 flex-grow-1">
                                <i class="ri-bank-fill align-middle me-1"></i> Bank Details
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Beneficiary Name</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.Beneficiary_Name, new { placeholder = "Enter Beneficiary Name", @class = "required form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Bank Name</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.Bank_Name, new { placeholder = "Enter Bank", @class = "required form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Account No</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.Bank_Account_No, new { placeholder = "Enter Account No", @class = "required form-control", onKeyPress = "javascript:return validFloat(event,this.getAttribute('id'))" })
                                    </div>
                                </div>


                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">IFSC Code</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.IFSC_Code, new { placeholder = "Enter IFSC Code (Ex.ABCD0123456)", @maxlength = "11", @class = "required form-control", oninput = "validateIFSCPattern(this)", onblur = "ValidateField(this.id, 'ifsc')" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Branch</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.Branch_Name, new { placeholder = "Enter Branch Name", @class = "form-control", onKeyPress = "return ValidateAlpha(event);" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">MICR Code</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.MICR_Code, new { placeholder = "Enter MICR Code", @class = "form-control" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">RTGS/NEFT Code</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.RTGS_NEFT_Code, new { placeholder = "Enter RTGS/NEFT Code", @class = "form-control" })
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">Bank Address</label>
                                        @Html.TextBoxFor(m => m.OrgBnkDet.Bank_Address, new { placeholder = "Enter Bank Address", @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-actions text-end">
                            <button type="button" class="@ViewBag.UI.Buttons.Cancel.CssClass" id="btn_CancelBankDetails">
                                <i class="@ViewBag.UI.Buttons.Cancel.Icon"></i> <lable id="btn_CancelBankDetails_txt">@ViewBag.UI.Buttons.Cancel.Label</lable>
                            </button>
                            <button type="button" class="@ViewBag.UI.Buttons.Add.CssClass" id="btn_AddBankDetails">
                                <i class="@ViewBag.UI.Buttons.Add.Icon"></i> <lable id="btn_AddBankDetails_txt">@ViewBag.UI.Buttons.Add.Label</lable>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-12">
                    <div class="card mb-0">
                        <div class="card-header">
                            <h5 class="card-title mb-0 flex-grow-1">
                                <i class="ri-bank-fill align-middle me-1"></i> Bank List
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <!-- Replaced jsGrid with a standard table and GlDataTable usage (same pattern as StateMaster.cshtml) -->
                            <table class="table table-hover table-striped align-middle table-nowrap mb-0" id="tblBank">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center">Beneficiary Name</th>
                                        <th class="text-center">Bank Name</th>
                                        <th class="text-center">Account No</th>
                                        <th class="text-center">IFSC Code</th>
                                        <th class="text-center">Branch</th>
                                        <th class="text-center">MICR</th>
                                        <th class="text-center">RTGS/NEFT</th>
                                        <th class="text-center">Address</th>
                                        <th class="text-center no-cc">Status</th>
                                        <th class="text-center no-cc">Action</th>
                                    </tr>
                                </thead>
                            </table>
                            <input type="hidden" id="hdnBankData" name="BankJsonData" />
                        </div>
                    </div>
                </div>
