@model List<GreenLineDataService.Models.CYGNUS_Additonal_Field_Configurator>
@using GreenLineDataService.Models

@{
    string ContractId = ViewBag.ContractId != null ? ViewBag.ContractId.ToString() : string.Empty;

    var dataType = new List<SelectListItem> {
      new SelectListItem { Text = "Numeric", Value = "int" },
      new SelectListItem { Text = "Decimal", Value = "decimal" },
      new SelectListItem { Text = "Text", Value = "varchar" },
      new SelectListItem { Text = "Date", Value = "Date" },
 };
}

@using (Html.BeginForm("AddContractAdditionalFieldConfigurartor", "Contract", FormMethod.Post, new { id = "form_additonal_field", @class = "form-modern-ui", enctype = "multipart/form-data" }))
{
    <input type="hidden" id="ContractId" value="@ContractId" />
    <div class="row">
        <div class="col-md-12">
            <div class="card mb-0">
                @*Additonal Field Configurator*@
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="ri-add-box-line align-middle me-1"></i> Additonal Field Configurator
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-12">
                            <table id="tbl_AddFieldConfig" class="table table-striped table-bordered table-hover m-0">
                                <thead>
                                    <tr>
                                        <th class="text-center">Label</th>
                                        <th class="text-center">Data Type</th>
                                        <th class="text-center">Min Length</th>
                                        <th class="text-center">Max Length</th>
                                        <th class="text-center">IsRequired</th>
                                    </tr>
                                </thead>
                                <tbody id="tbl_body_AddFieldConfig">
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        <tr>
                                            @Html.HiddenFor(m => m[i].Id)
                                            @Html.HiddenFor(m => m[i].ContractId)
                                            @Html.HiddenFor(m => m[i].Name)
                                            <td>@Html.TextBoxFor(m => m[i].Label, new { @class = "form-control", placeholder = "Label" })</td>
                                            <td>
                                                @Html.DropDownListFor(m => m[i].DataType, new SelectList(dataType, "Value", "Text", Model[i].DataType), "", new { @class = "select2 form-control", placeholder = "Select Data Type" })
                                            </td>
                                            <td>
                                                <input type="text" name="[@(i)].MinLength" id="Model_@(i)__MinLength" class="form-control" placeholder="Min Length" value="@(Model[i].MinLength == 0 ? "" : Model[i].MinLength.ToString())" onkeypress="javascript:return validDigits(event,this)" />
                                            </td>
                                            <td>
                                                <input type="text" name="[@(i)].MaxLength" id="Model_@(i)__MaxLength" class="form-control" placeholder="Max Length" value="@(Model[i].MaxLength == 0 ? "" : Model[i].MaxLength.ToString())" onkeypress="javascript:return validDigits(event,this)" />
                                            </td>
                                            <td>
                                                <div class="gap-3 d-flex justify-content-center">
                                                    <div class="form-check">
                                                        @Html.RadioButtonFor(m => m[i].Required, "Y", new { @class = "form-check-input" })
                                                        <label class="form-check-label">Yes</label>
                                                    </div>

                                                    <div class="form-check">
                                                        @Html.RadioButtonFor(m => m[i].Required, "N", new { @class = "form-check-input" })
                                                        <label class="form-check-label">No</label>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="form-actions">
    <button type="button" onclick="goToTab(1)" class="@ViewBag.UI.Buttons.Previous.CssClass"><i class="@ViewBag.UI.Buttons.Previous.Icon"></i>@ViewBag.UI.Buttons.Previous.Label</button>
    <button type="button" id="btnAdditionalFieldSubmit" class="@ViewBag.UI.Buttons.Submit.CssClass"><i class="@ViewBag.UI.Buttons.Submit.Icon"></i>Save & Next</button>
    <button type="button" onclick="goToTab(3)" id="btnAdditionalFieldNext" class="@ViewBag.UI.Buttons.Next.CssClass"><i class="@ViewBag.UI.Buttons.Next.Icon"></i>@ViewBag.UI.Buttons.Next.Label</button>
</div>


