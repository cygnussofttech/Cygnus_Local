                            var parsedDate = new Date(selectedVal);
                            if (parsedDate instanceof Date && !isNaN(parsedDate.getTime())) {
                                var $fromField = $row.find('.modal-effective-from');
                                if ($fromField.length > 0 && $fromField.hasClass('date-picker-modal')) {
