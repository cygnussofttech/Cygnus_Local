        //Tab 3 Additional Field Configurator Length Validator
        function validateAdditionalFieldLengths() {
            var isValid = true;
            $('#tbl_body_AddFieldConfig tr').each(function () {
                var $tr = $(this);
                var $minInput = $tr.find('td').eq(2).find('input');
                var $maxInput = $tr.find('td').eq(3).find('input');
                var dataType = ($tr.find('td').eq(1).find('select').val() || "").trim();

                var minValStr = ($minInput.val() || "").trim();
                var maxValStr = ($maxInput.val() || "").trim();
                var minVal = minValStr !== "" ? parseInt(minValStr, 10) : NaN;
                var maxVal = maxValStr !== "" ? parseInt(maxValStr, 10) : NaN;

                if (dataType === 'varchar') {
                    if (!isNaN(minVal) && !isNaN(maxVal)) {
                        if (maxVal < minVal) {
                            isValid = false;
                            $maxInput.addClass('is-invalid');
                            $maxInput.after('<div class="help-block text-danger small length-validation-error">Max length cannot be less than Min length</div>');
                        }
                    }
                    if (!isNaN(maxVal) && maxVal > 200) {
                        isValid = false;
                        $maxInput.addClass('is-invalid');
                        $maxInput.after('<div class="help-block text-danger small length-validation-error">Max length cannot be more than 200</div>');
                    }
                } else if (dataType === 'int') {
                    if (!isNaN(maxVal) && maxVal > 10) {
                        isValid = false;
                        $maxInput.addClass('is-invalid');
                        $maxInput.after('<div class="help-block text-danger small length-validation-error">Max length cannot be more than 10</div>');
                    }
                } else if (dataType === 'decimal') {

                    if (!isNaN(minVal)) {
                        if (minVal < 1 || minVal > 28) {
                            isValid = false;
                            $minInput.addClass('is-invalid');
                            $minInput.after('<div class="help-block text-danger small length-validation-error">Precision must be between 1 and 28</div>');
                        }
                    }

                    if (!isNaN(maxVal)) {
                        if (maxVal < 0 || maxVal > 10) {
                            isValid = false;
                            $maxInput.addClass('is-invalid');
                            $maxInput.after('<div class="help-block text-danger small length-validation-error">Scale must be between 0 and 10</div>');
                        }
                    }
                }
            });
            return isValid;
        }

        function validateAdditionalFieldsRowComplete() {
            var isValid = true;
            $('#tbl_body_AddFieldConfig tr').each(function () {
                var $tr = $(this);
                
                var labelVal = ($tr.find('td').eq(0).find('input').val() || "").trim();
                var dataTypeVal = ($tr.find('td').eq(1).find('select').val() || "").trim();
                var minLengthVal = ($tr.find('td').eq(2).find('input').val() || "").trim();
                var maxLengthVal = ($tr.find('td').eq(3).find('input').val() || "").trim();
                
                // For radio buttons, check which one is checked
                var requiredChecked = $tr.find('td').eq(4).find('input:checked');
                var requiredVal = requiredChecked.length > 0 ? requiredChecked.val() : "";

                // Check if any field in the row has been filled/selected
                var hasAnyInput = (labelVal !== "" || dataTypeVal !== "" || minLengthVal !== "" || maxLengthVal !== "" || requiredVal !== "");

                if (hasAnyInput) {
                    var isRowValid = true;

                    // Label is always required
                    if (labelVal === "") {
                        $tr.find('td').eq(0).find('input').addClass('is-invalid').each(function() {
                            this.style.setProperty('border-color', '#f06548', 'important');
                        });
                        isRowValid = false;
                    }
                    // DataType is always required
                    if (dataTypeVal === "") {
                        var $select = $tr.find('td').eq(1).find('select');
                        $select.addClass('is-invalid').each(function() {
                            this.style.setProperty('border-color', '#f06548', 'important');
                        });
                        $tr.find('td').eq(1).find('.select2-selection, .select2-choice').each(function() {
                            this.style.setProperty('border-color', '#f06548', 'important');
                        });
                        isRowValid = false;
                    }
                    // Required (Yes/No) is always required
                    if (requiredVal !== "Y" && requiredVal !== "N") {
                        $tr.find('td').eq(4).find('input').addClass('is-invalid');
                        isRowValid = false;
                    }

                    // DataType-dependent checks for MinLength / MaxLength completeness
                    if (dataTypeVal === "varchar" || dataTypeVal === "decimal") {
                        if (minLengthVal === "") {
                            $tr.find('td').eq(2).find('input').addClass('is-invalid').each(function() {
                                this.style.setProperty('border-color', '#f06548', 'important');
                            });
                            isRowValid = false;
                        }
                    }
                    if (dataTypeVal === "varchar" || dataTypeVal === "decimal") {
                        if (maxLengthVal === "") {
                            $tr.find('td').eq(3).find('input').addClass('is-invalid').each(function() {
                                this.style.setProperty('border-color', '#f06548', 'important');
                            });
                            isRowValid = false;
                        }
                    }

                    if (!isRowValid) {
                        isValid = false;
                    }
                }
            });
            return isValid;
        }

        //Dynamic Segmented Progress Tracker
        function updateContractProgress() {
            var visibleTabs = [];
            var activeIndex = 1;

            var tabItems = document.querySelectorAll('.custom-modern-pills .nav-item');
            tabItems.forEach(function (item) {
                // Only count currently visible tabs
                if (window.getComputedStyle(item).display !== 'none') {
                    visibleTabs.push(item);
                }
            });

            // Find active index
            for (var i = 0; i < visibleTabs.length; i++) {
                var link = visibleTabs[i].querySelector('.nav-link');
                if (link && link.classList.contains('active')) {
                    activeIndex = i + 1;
                    break;
                }
            }

            var totalTabs = visibleTabs.length || 8; // considers the 8-tab maximum base layout beautifully
            var percentage = Math.round((activeIndex / totalTabs) * 100);

            if (percentage > 100) percentage = 100;

            // Update DOM elements dynamically with smooth transition width
            var progressFill = document.querySelector('.progress-fill');
            var percentageBadge = document.querySelector('.progress-percentage-badge');
            if (progressFill) {
                $(".progress-fill").css("width", percentage + '%')
            }
            if (percentageBadge) {
                percentageBadge.textContent = percentage + '%';
            }
        }

        function lockSavedGridRows(tableSelector) {
            $(tableSelector + " tbody tr.editorRow").each(function () {
                var $row = $(this);
                var srnoVal = $row.find("input.row-srno").val();

                if (srnoVal && srnoVal !== "0" && srnoVal !== "") {
                    // Lock existing saved rows
                    $row.find("input[type='text'], input[type='number'], select").prop("disabled", true);
                    $row.find("select").trigger("change.select2");
                    $row.attr("data-locked", "true");
                    $row.removeClass("is-editing");

                    // Restore original edit icon class stored or fallback
                    var $editBtn = $row.find(".btn-edit-row");
                    if (!$editBtn.data("original-icon")) {
                        var iconClass = $editBtn.find("i").attr("class") || "ri-pencil-line";
                        $editBtn.data("original-icon", iconClass);
                    }
                    $editBtn.html('<i class="' + $editBtn.data("original-icon") + '"></i>').removeClass("btn-save-mode");
                } else {
                    // Unlock unsaved rows
                    $row.find("input[type='text'], input[type='number'], select").not("[readonly]").prop("disabled", false);
                    $row.find("select").trigger("change.select2");
                    $row.attr("data-locked", "false");
                    $row.addClass("is-editing");

                    // Show save icon for unsaved rows
                    var $editBtn = $row.find(".btn-edit-row");
                    if (!$editBtn.data("original-icon")) {
                        var iconClass = $editBtn.find("i").attr("class") || "ri-pencil-line";
                        $editBtn.data("original-icon", iconClass);
                    }
                    $editBtn.html('<i class="ri-save-line"></i>').addClass("btn-save-mode");
                }
            });
        }

        function saveSingleGridRow($row, $btn, DomainName) {
            if (stopTochangeinContract()) {
                return;
            }
            var isFTL = $row.closest("table").attr("id") === "sample_FTL";
            var formId = isFTL ? "form_SundryFTL" : "form_freightCharge";
            var actionUrl = isFTL ? (DomainName + '/Contract/AddSundryFTL_New') : (DomainName + '/Contract/AddfreightCharge');

            // 1. Clear custom validation messages and trigger form validation setup
            $(".help-block").remove();
            Formvalidate(DomainName, formId);

            // 2. Validate Attachment (mandatory)
            var attachmentVal = isFTL ? $("#AddFreightFTL #Attachment").val() : $("#AddFreightCharge #Attachment").val();
            var fileUploadVal = isFTL ? $("#AddFreightFTL #fileUpload").val() : $("#AddFreightCharge #fileUpload").val();
            if ((attachmentVal == "" || attachmentVal == null) && (fileUploadVal == "" || fileUploadVal == null)) {
                TosterNotification("warning", "Please upload attachment", "Warning");
                return;
            }

            // 2.1 Validate Rate (must be greater than 0)
            var $rateInput = isFTL ? $row.find("input[name$='.FTL1_TRIP_RATE']") : $row.find("input[name$='.rate']");
            if ($rateInput.length > 0) {
                var rateVal = parseFloat($rateInput.val()) || 0;
                if (rateVal <= 0) {
                    $rateInput.after('<span class="help-block">Rate must be greater than 0</span>');
                    return;
                }
            }

            // 3. Row level manual validation check

            App.blockUI({ boxed: true });
            if (!$('#' + formId).valid()) {
                TosterNotification("error", "Please fill all required field..!!", "error..!!");
                App.unblockUI();
                return false;
            }

            // 5. Check for duplicate rows in the table
            var tableSelector = isFTL ? "#sample_FTL" : "#sample_2";
            if (checkDuplicateRows(tableSelector)) {
                TosterNotification("error", "Same data found for FromLane, ToLane, Product Group, FromQty, ToQty, FromDate, ToDate. Please check your data.", "Duplicate Record");
                return;
            }


            // 6. Construct FormData including row fields, top-level fields, files and anti-forgery token
            var formData = new FormData();
            var $form = $("#" + formId);

            // Enable disabled inputs inside this row temporarily to read their values
            var $inputsToEnable = $row.find(":input:disabled");
            $inputsToEnable.prop("disabled", false);

            // Append all inputs from the active row
            $row.find(":input").each(function () {
                var name = $(this).attr("name");
                if (name) {
                    if ($(this).attr("type") === "checkbox") {
                        formData.append(name, $(this).prop("checked"));
                    } else {
                        formData.append(name, $(this).val());
                    }
                }
            });

            // Append top-level inputs (hidden/text/select, etc.)
            var prefix = isFTL ? "FTLfreightCharge." : "CustsingleSlab.";
            $form.find(":input").each(function () {
                var name = $(this).attr("name");
                if (name && name.startsWith(prefix)) {
                    if ($(this).attr("type") === "checkbox") {
                        formData.append(name, $(this).prop("checked"));
                    } else {
                        formData.append(name, $(this).val());
                    }
                }
            });

            // Append Anti-Forgery Token
            var token = $form.find("input[name='__RequestVerificationToken']").val();
            if (token) {
                formData.append("__RequestVerificationToken", token);
            }

            // Append SaveType flag to distinguish single row saves
            formData.append("SaveType", "single");

            // Append File Upload
            var fileInput = $form.find("input[type='file']")[0];
            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                formData.append(fileInput.name, fileInput.files[0]);
            }

            // Restore disabled state of row inputs
            $inputsToEnable.prop("disabled", true);

            $.ajax({
                url: actionUrl,
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    App.unblockUI();
                    if (response.Status) {
                        TosterNotification("success", response.Message, "Success");
                        // Refresh the grid to show newly saved database records and reload correctly
                        if (isFTL) {
                            $("#btngetSundryFTL").click();
                        } else {
                            $("#btngetfreightCharge").click();
                        }
                    } else {
                        TosterNotification("error", response.Message, "Error");
                    }
                },
                error: function () {
                    App.unblockUI();
                    TosterNotification("error", "A network error occurred while saving changes.", "Error");
                }
            });
        }

