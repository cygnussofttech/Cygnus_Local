                //Dynamic Segmented Progress Tracker Initializer
                $(document).ready(function () {
                    // Limit manual selection to maximum 5 rows
                    $(document).on("change", "#tblfreightcharge .row-checkbox, #tblSundryFTL .row-checkbox", function () {
                        var $table = $(this).closest("table");
                        var checkedCount = $table.find(".row-checkbox:checked").length;
                        if (checkedCount > 5) {
                            $(this).prop("checked", false);
                            TosterNotification("warning", "You can select maximum 5 rows for cloning.", "Selection Limit");
                        }
                    });

                    // Globally allow selection of radio button by clicking its label text
                    $(document).on("click", "label", function (e) {
                        if ($(e.target).is("input[type='radio']")) {
                            return;
                        }
                        var $label = $(this);
                        if (!$label.attr("for")) {
                            var $radio = $label.find("input[type='radio']");
                            if ($radio.length === 0) {
                                $radio = $label.siblings("input[type='radio']");
                            }
                            if ($radio.length === 0) {
                                $radio = $label.closest(".form-check").find("input[type='radio']");
                            }
                            if ($radio.length > 0 && !$radio.prop("disabled")) {
                                $radio.trigger("mousedown");
                                $radio.trigger("click");
                            }
                        }
                    });

                    setTimeout(updateContractProgress, 1000);

                    // Track Bootstrap tab selection changes (handles clicks & programmatical tabs switching)
                    $(document).on('shown.bs.tab click', '.custom-modern-pills .nav-link', function () {
                        setTimeout(updateContractProgress, 50);
                    });

                    // Watch for FTL/PTL dynamic visibility dropdown state modifications
                    if (window.MutationObserver) {
                        var observer = new MutationObserver(function (mutations) {
                            updateContractProgress();
                        });

                        var ptlTab = document.getElementById('liPTL');
                        var ftlTab = document.getElementById('liFTL');

                        if (ptlTab) {
                            observer.observe(ptlTab, { attributes: true, attributeFilter: ['style'] });
                        }
                        if (ftlTab) {
                            observer.observe(ftlTab, { attributes: true, attributeFilter: ['style'] });
                        }
                    }

                    // Watch for AJAX completions to automatically lock dynamic tab content
                    $(document).ajaxComplete(function () {
                        setTimeout(function () {
                            disabledButton();
                            if ($("#sample_2").length > 0) {
                                lockSavedGridRows("#sample_2");
                            }
                            if ($("#sample_FTL").length > 0) {
                                lockSavedGridRows("#sample_FTL");
                            }
                        }, 1000);
                    });
                });

                updateIndexes();
            }
        }
