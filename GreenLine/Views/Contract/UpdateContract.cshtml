                }

                // Past date validation: if rowStartDate is less than today's date, make it today's date
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                if (rowStartDate < today) {
                    rowStartDate = today;
                }

                var pickerStartDate = rowStartDate;
                var pickerEndDate = rowEndDate;

                if ($this.hasClass('modal-effective-from') || ($this.attr('name') && $this.attr('name').indexOf('EffectiveFrom') > -1)) {
                    if (rowEffectiveToVal && rowEffectiveToVal.trim() !== "") {
