        return {
            init: function (DomainName) {
                Formvalidate(DomainName, "form_sample");
                Formvalidate(DomainName, "form_docs");
                Formvalidate(DomainName, "form_additonal_field");
                Formvalidate(DomainName, "form_sampleservice");
                Formvalidate(DomainName, "form_sampleModeVice");
                Formvalidate(DomainName, "form_freightCharge");
                Formvalidate(DomainName, "form_SundryFTL");
                Formvalidate(DomainName, "form_sampleChargeMatrix");
                Formvalidate(DomainName, "form_StandardCharge");
                Formvalidate(DomainName, "form_BillConfiguration");

                SaveFunction(DomainName);

                // Initialize select2 on the loaded Basic Info fields
                $("#BasicInfo select").select2({
                    placeholder: "Select an option",
                    allowClear: true
                });

                // ✅ Initialize on input directly
                $('.valid-date-picker').datepicker({
                    isRTL: App.isRTL(),
                    format: "dd M yyyy",
                    autoclose: true,
                    pickerPosition: (App.isRTL() ? "bottom-right" : "bottom-left"),
                    startDate: new Date(),
                    todayBtn: true,
                });

                initDatePicker();
                disabledButton();

                //Tab Change
                $(document).off("click", "#customTabs li a").on("click", "#customTabs li a", function (e) {

                    var skipValidation = $(this).data("skip-validation") === true;
                    e.preventDefault();

                    // ✅ VALIDATE CURRENT TAB BEFORE SWITCHING
                    var currentTabLink = $("#customTabs .nav-link.active");
                    var currentTabId = currentTabLink.attr("href");

                    // Get ID without # for validateTab
                    var activePaneId = currentTabId.replace("#", "");

                    // Determine tab indexes to skip validation if going backwards (Previous)
                    var $tabs = $("#customTabs li a");
                    var currentTabIndex = $tabs.index(currentTabLink);
                    var targetTabIndex = $tabs.index($(this));
                    if (targetTabIndex < currentTabIndex) {
                        skipValidation = true;
                    }

                    if (!skipValidation) {
                        if (!validateTab(activePaneId)) {
                            if (activePaneId != "tab_2") {
                                TosterNotification("error", "Please fill all required field..!!", "error..!!");
                            }
                            return false;
                        }
                    }

                    // ✅ REMOVE ALL VALIDATION
                    $(".form-control, select").removeClass("is-invalid");
                    $(".invalid-feedback").remove();
                    $(".help-block").remove();

                    // Tab switch logic
                    $("#customTabs .nav-link").removeClass("active");
                    $(this).addClass("active");

                    $(".tab-pane").removeClass("active").hide();

                    var target = $(this).attr("href");
                    $(target).fadeIn(200).addClass("active");

                    // ✅ SWITCH CASE
                    switch (target) {

                        case "#tab_1":
                            ContractBasicInfo(DomainName);
                            break

                        case "#tab_2":
                            Documents(DomainName);
                            break

                        case "#tab_3":
                            AdditionalFieldConfig(DomainName);
                            break

                        case "#tab_4":
                            ServiceSelection(DomainName);
                            break

                        //case "#tab_5":
                        //    ModeWiseSelection(DomainName);
                        //    break

                        case "#tab_6":
                            LoadFreightChargePTL(DomainName);
                            break

                        case "#tab_7":
                            LoadFreightChargeFTL(DomainName);
                            break

                        case "#tab_8":
                            ChargeMatrix(DomainName);
                            break
                        case "#tab_9":
                            LoadStandardCharge(DomainName);
                            break;
                        case "#tab_10":
                            BillingConfiguration(DomainName);
                            break;

                        default:
                            break;
                    }
                    disabledButton();
                });

                $(document).on('change keyup input', "input, select, textarea", function () {
                    var $form = $(this).closest('form');
                    if ($form.length > 0 && $form.data('validator')) {
                        $(this).valid();
                    }
                });

                // Clear manual rate validation error on type/change
                $(document).on("keyup change input", "input[name$='.rate'], input[name$='.FTL1_TRIP_RATE'], .modal-new-rate", function () {
                    var val = parseFloat($(this).val()) || 0;
                    if (val > 0) {
                        $(this).siblings(".help-block").remove();
                    }
                });

                // Clear validation error when rate type is selected or rate becomes 0 on standard charge tab
                $(document).on("change keyup input", "#tblStndfreightSlab select[name$='.ratetype'], #tblStndfreightSlab input[name$='.rate']", function () {
                    var $row = $(this).closest("tr");
                    var $rateInput = $row.find("input[name$='.rate']");
                    var $rateTypeSelect = $row.find("select[name$='.ratetype']");

                    var rateVal = parseFloat($rateInput.val()) || 0;
                    var rateTypeVal = $rateTypeSelect.val();

                    if (rateVal <= 0 || (rateTypeVal && rateTypeVal !== "")) {
                        $rateTypeSelect.removeClass("is-invalid");
                        var $container = $rateTypeSelect.next(".select2-container");
                        if ($container.length > 0) {
                            $container.next(".help-block").remove();
                        } else {
                            $rateTypeSelect.next(".help-block").remove();
                        }
                    }
                });

                //Tab 1 File Upload
                $(document).off("change", "#fileUpload").on("change", "#fileUpload", function () {
                    var file = this.files[0];
                    if (file) {
                        if (!validateImageFile(file, this)) return;
                    }
                });

                //Tab 2 date change
                $(document).off("change", "#Contract_Eddate").on("change", "#Contract_Eddate", function () {
                    contractEndDate = $(this).val();
                });

                //Tab 2 File Upload
                $(document).off("change", ".fileUpload").on("change", ".fileUpload", function () {

                    var input = this;
