        color: #f06548 !important;
        font-size: 11px !important;
        margin-top: 4px !important;
        display: block !important;
        font-weight: 500 !important;
    }
    /* New Tab Styles from _AddEditCustomer */
    .nav-tabs-custom {
        border-bottom: 2px solid #eff2f7;
        gap: 30px;
        background: transparent;
        padding: 0 10px;
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
    }

        .nav-tabs-custom .nav-item {
            border: none;
            background: transparent;
        }

            .nav-tabs-custom .nav-item .nav-link {
                border: none;
                font-weight: 600;
                color: #878a99;
                padding: 15px 0;
                font-size: 14px;
                background: transparent;
                border-radius: 0;
                transition: all 0.3s ease;
                position: relative;
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 0px;
            }

                .nav-tabs-custom .nav-item .nav-link i {
                    font-size: 18px;
                    opacity: 0.7;
                }

                .nav-tabs-custom .nav-item .nav-link.active {
                    color: #405189 !important;
                    background-color: transparent !important;
                }

                    .nav-tabs-custom .nav-item .nav-link.active i {
                        color: #405189;
                        opacity: 1;
                    }

                .nav-tabs-custom .nav-item .nav-link::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 0;
                    height: 3px;
                    background-color: #405189;
                    transition: width 0.3s ease;
                    border-radius: 3px 3px 0 0;
                }

                .nav-tabs-custom .nav-item .nav-link.active::after {
                    width: 100%;
                }

                .nav-tabs-custom .nav-item .nav-link:hover {
                    color: #405189;
                }

    /* Duplicate Row Highlight Styling */
    .duplicate-row-highlight {
        background-color: #fdf2f2 !important; /* Soft rose/red background */
        transition: background-color 0.3s ease;
    }

        .duplicate-row-highlight td {
            border-top: 1.5px solid #f8b4b4 !important;
            border-bottom: 1.5px solid #f8b4b4 !important;
        }

        .duplicate-row-highlight select + .select2-container .select2-selection,
        .duplicate-row-highlight input + .select2-container .select2-selection,
        .duplicate-row-highlight .form-control {
            border-color: #f8b4b4 !important;
            background-color: #fff8f8 !important;
            box-shadow: 0 0 0 0.2rem rgba(248, 180, 180, 0.25) !important;
        }

    /* EffectiveTo Exceeded Highlight Styling */
    .effective-to-highlight {
        background-color: #fdf2f2 !important; /* Soft rose/red background */
        transition: background-color 0.3s ease;
    }

        .effective-to-highlight td {
            border-top: 1.5px solid #f8b4b4 !important;
            border-bottom: 1.5px solid #f8b4b4 !important;
        }

        .effective-to-highlight select + .select2-container .select2-selection,
        .effective-to-highlight input + .select2-container .select2-selection,
        .effective-to-highlight .form-control {
            border-color: #f8b4b4 !important;
            background-color: #fff8f8 !important;
            box-shadow: 0 0 0 0.2rem rgba(248, 180, 180, 0.25) !important;
        }

    /* Sticky First & Last Columns for PTL & FTL Tables */
    #sample_2 th:first-of-type,
    #sample_2 td:first-of-type,
    #sample_FTL th:first-of-type,
    #sample_FTL td:first-of-type {
        position: sticky !important;
        left: 0 !important;
        z-index: 100 !important;
        border-right: none !important;
        border-top: 1px solid #dfe3eb !important;
        border-bottom: 1px solid #dfe3eb !important;
        box-shadow: 2px 0 5px rgba(0,0,0,0.05) !important;
        width: 35px !important;
        min-width: 35px !important;
        max-width: 35px !important;
    }

    #sample_2 td:first-of-type,
    #sample_FTL td:first-of-type {
        background: linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, #ffffff 1.5px, #ffffff 100%) !important;
    }

    #sample_2 th:first-of-type,
    #sample_FTL th:first-of-type {
        border-right: none !important;
        background: linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, #f3f6f9 1.5px, #f3f6f9 100%) !important;
    }

    #sample_2 th:last-of-type,
    #sample_2 td:last-of-type,
    #sample_FTL th:last-of-type,
    #sample_FTL td:last-of-type {
        position: sticky !important;
        right: 0 !important;
        z-index: 100 !important;
        border-left: none !important;
        border-top: 1px solid #dfe3eb !important;
        border-bottom: 1px solid #dfe3eb !important;
        box-shadow: -2px 0 5px rgba(0,0,0,0.05) !important;
        width: 90px !important;
        min-width: 125px !important;
        max-width: 125px !important;
    }

    #sample_2 td:last-of-type,
    #sample_FTL td:last-of-type {
        background: linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, #ffffff 1.5px, #ffffff 100%) !important;
    }

    #sample_2 th:last-of-type,
    #sample_FTL th:last-of-type {
        border-left: none !important;
        background: linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, #f3f6f9 1.5px, #f3f6f9 100%) !important;
    }

    /* Keep highlighted backgrounds for sticky columns */
    .duplicate-row-highlight td:first-of-type,
    .effective-to-highlight td:first-of-type {
        background: linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, #fdf2f2 1.5px, #fdf2f2 100%) !important;
    }

    .duplicate-row-highlight td:last-of-type,
    .effective-to-highlight td:last-of-type {
        background: linear-gradient(to left, #c5c5c5 0px, #c5c5c5 1.5px, transparent 1.5px), linear-gradient(to right, #c5c5c5 0px, #c5c5c5 1.5px, #fdf2f2 1.5px, #fdf2f2 100%) !important;
    }

    .contract-header-card {
        background: #ffffff;
        border-radius: 12px;
        padding: 16px 20px;
        border: 1px solid rgba(223, 227, 235, 0.6);
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 20px;
        margin-bottom: 10px;
    }

        .contract-header-card .icon-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .contract-header-card .bg-primary-subtle {
            background-color: rgba(79, 70, 229, 0.1) !important;
        }

        .contract-header-card .text-primary {
            color: #4f46e5 !important;
        }

        .contract-header-card .bg-success-subtle {
            background-color: rgba(16, 185, 129, 0.1) !important;
        }

        .contract-header-card .text-success {
            color: #10b981 !important;
        }

        .contract-header-card .fs-11 {
            font-size: 11px !important;
            letter-spacing: 0.5px;
        }

        .contract-header-card .fs-14 {
            font-size: 14px !important;
        }

    /* Modern Tab Container */
    .custom-tabs-container {
        background: #ffffff;
        border-radius: 12px;
        padding: 8px;
        border: 1px solid rgba(223, 227, 235, 0.6);
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
        margin-bottom: 10px;
    }

    /* Modern Pills Styles */
    .custom-modern-pills {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 6px;
        padding: 0;
        margin: 0;
        list-style: none;
        border: none !important;
        scrollbar-width: none; /* Hide scrollbar for Firefox */
    }

        .custom-modern-pills::-webkit-scrollbar {
            display: none; /* Hide scrollbar for Chrome/Safari */
        }

        .custom-modern-pills .nav-item {
            flex: 0 0 auto;
        }

        .custom-modern-pills .nav-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #64748b;
            border-radius: 8px;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
        }

            .custom-modern-pills .nav-link i {
                font-size: 16px;
                transition: transform 0.25s ease;
            }

            /* Hover styles */
            .custom-modern-pills .nav-link:hover {
                color: #4f46e5;
                background-color: #f8fafc;
            }

                .custom-modern-pills .nav-link:hover i {
                    transform: translateY(-1px);
                }

            /* Active state */
            .custom-modern-pills .nav-link.active {
                color: #ffffff !important;
                background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%) !important;
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25) !important;
            }

                .custom-modern-pills .nav-link.active i {
                    color: #ffffff !important;
                }

    /* Modern Progress Bar styling */
    .modern-progress-wrapper {
        background: #ffffff;
        border-radius: 12px;
        padding: 16px 20px;
        border: 1px solid rgba(223, 227, 235, 0.6);
        box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
        margin-bottom: 24px;
    }

    .progress-percentage-badge {
        background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
        box-shadow: 0 2px 6px rgba(6, 182, 212, 0.2);
    }

    .progress-track {
        width: 100%;
        height: 8px;
        background-color: #f1f5f9;
        border-radius: 10px;
        overflow: hidden;
        position: relative;
    }

    .progress-fill {
        height: 100%;
        border-radius: 10px;
        background: linear-gradient(90deg, #06b6d4 0%, #3b82f6 50%, #4f46e5 100%);
        background-size: 200% auto;
        animation: shimmer 3s linear infinite;
        position: relative;
        transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .progress-fill-glow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient( 90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.4) 50%, rgba(255, 255, 255, 0) 100% );
        background-size: 200% 100%;
        animation: shimmer-glow 1.5s infinite;
    }

    @@keyframes shimmer {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    @@keyframes shimmer-glow {
        0% {
            background-position: -200% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            opacity: 0.6;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: 0.6;
        }
    }

    .text-indigo {
        color: #4f46e5;
    }

    .header-progress-container {
        width: 18%;
        transition: all 0.3s ease;
    }

    @@media (min-width: 1200px) {
        .contract-header-card {
            flex-wrap: nowrap !important;
        }

        .header-id-container {
            width: auto !important;
        }

        .header-customer-container {
            flex-grow: 1 !important;
        }
    }

    @@media (max-width: 1199px) {
        .header-progress-container {
            width: 100% !important;
            margin-top: 12px;
        }

        .header-id-container {
            width: auto !important;
        }

        .header-customer-container {
            flex-grow: 1 !important;
        }

        .contract-header-card {
            gap: 12px 20px !important;
            padding: 14px 18px !important;
        }
    }

    @@media (max-width: 767px) {
        .contract-header-card {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 14px !important;
            padding: 16px !important;
        }

        .header-id-container {
            width: 100% !important;
            justify-content: space-between !important;
        }

        .header-customer-container {
            width: 100% !important;
            flex-grow: 0 !important;
        }

        .header-progress-container {
            width: 100% !important;
            margin-top: 4px !important;
        }
    }

    @@media (max-width: 768px) {
        .custom-modern-pills .nav-item {
            flex: 1 1 0 !important;
        }

        .custom-modern-pills .nav-link {
            padding: 10px 0 !important;
            gap: 0 !important;
            justify-content: center !important;
        }

            .custom-modern-pills .nav-link span {
                display: none !important;
            }

            .custom-modern-pills .nav-link i {
                font-size: 18px !important;
            }
    }

    /* =========================================================================
       Select2 Disabled / Locked Multi-Select Premium Compact Layout (PTL/FTL)
       ========================================================================= */
    #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled,
    #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled {
        max-width: 220px !important;
        width: 220px !important;
        display: inline-block !important;
    }

        #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices,
        #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices {
            border: 1px solid #dfe3eb !important;
            background-color: #f3f6f9 !important;
            background-image: none !important;
            padding: 0 4px !important;
            margin: 0 !important;
            display: flex !important;
            flex-wrap: nowrap !important;
            overflow-x: auto !important;
            overflow-y: hidden !important;
            max-height: 32px !important;
            height: 32px !important;
            align-items: center !important;
            border-radius: 4px !important;
            scrollbar-width: thin !important;
            scrollbar-color: #cbd5e1 transparent !important;
            max-width: 100% !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

            /* Webkit scrollbar customization for thin, premium horizontal scrolling of tags */
            #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar,
            #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar {
                height: 3px !important;
            }

            #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar-thumb,
            #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar-thumb {
                background: #cbd5e1 !important;
                border-radius: 10px !important;
            }

            #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar-track,
            #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-choices::-webkit-scrollbar-track {
                background: transparent !important;
            }

        /* Force tags (search choices) to stay inline and not wrap */
        #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice,
        #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice {
            float: none !important;
            display: inline-flex !important;
            align-items: center !important;
            margin: 0 4px 0 0 !important;
            padding: 2px 8px !important;
            background-color: #ffffff !important;
            background-image: none !important;
            border: 1px solid #e2e8f0 !important;
            color: #334155 !important;
            font-size: 11px !important;
            font-weight: 500 !important;
            height: 22px !important;
            white-space: nowrap !important;
            flex-shrink: 0 !important;
            border-radius: 4px !important;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02) !important;
        }

        /* Hide the select2 multi-select tag close icon when disabled */
        #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice-close,
        #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice-close {
            display: none !important;
        }

        /* Standard Select2 choice text styling inside disabled tags */
        #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice div,
        #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-choice div {
            padding: 0 !important;
            white-space: nowrap !important;
            overflow: hidden !important;
            text-overflow: ellipsis !important;
        }

        /* Hide the trailing search box in disabled select2 multi-select */
        #sample_2 tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-field,
        #sample_FTL tr.editorRow:not(.is-editing) .select2-container-multi.select2-container-disabled .select2-search-field {
            display: none !important;
        }
</style>


