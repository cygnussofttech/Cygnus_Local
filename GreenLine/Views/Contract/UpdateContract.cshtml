
@model GreenLineDataService.ViewModel.CustomerContractViewModel
@using GreenLineDataService.Models

@{
    ViewBag.Title = "Contract";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var PTLFTL = ViewBag.ServiceType;
    string IsPTLVisible = PTLFTL == "1" ? "block" : "none";
    string IsFTLVisible = PTLFTL == "2" ? "block" : "none";

    @*bool isFinalSubmitDone = Model.CustomerContract.IsFinalSubmitDone;*@
    bool isFinalSubmitDone = false;
}

<style>
  

    .section-box {
