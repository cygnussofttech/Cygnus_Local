                //Tab 9 Standard Charge (Multiple RoW Add)
                $(document).off("click", "#btnStanardAddRows").on("click", "#btnStanardAddRows", function () {
                    var itemIndex = $("#tblStndfreightSlab input.iHidden").length
                    var TOTRows = $("#StandardRows").val();
                    if (TOTRows == "" || TOTRows == "0") {
                        TosterNotification("warning", "Warning !! No. of rows should be greater than 0.", "Error");
                        return;
                    }
                    for (var i = 0; i <= TOTRows - 1; i++) {
                        setTimeout(function () {
                            itemIndex = itemIndex + 1;
                            AddQuestionsCharge(DomainName, itemIndex);
                        }, 250 * i);
                    }
                });

                //Tab 9 DrpDown Change
                $(document).off("change", "#chargeContraint_basedon").on("change", "#chargeContraint_basedon", function () {
                    Formvalidate(DomainName, "form_StandardCharge");
                    $("#btnGetStandardCharge").stop(true, true).show();
                    $("#divStandardMultiple").stop(true, true).hide();
                    $("#btnStandardCharge, #btnStandardChargeStay").stop(true, true).hide();
                    $("#btnStandardChargeNext").stop(true, true).show();
                });

                //Tab 10 - Bill Configuration (Add Item Description)
                $(document).off("click", "#ddlItemDesc").on("click", "#ddlItemDesc", function () {

                    var selectedValue = $(this).val();   // <<Destination>>
                    var textarea = $("#txtItemDesc");

                    if (!selectedValue) return;

                    var currentText = textarea.val();

                    // 🔐 regex safe (special chars માટે)
                    var escapedValue = selectedValue.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                    var regex = new RegExp("\\s?" + escapedValue + "\\s?", "g");

                    if (regex.test(currentText)) {
                        // ❌ already exists → REMOVE (toggle off)
                        var newText = currentText.replace(regex, " ");
                        textarea.val(newText.trim() + " ");
                    } else {
                        // ✅ not exists → ADD
                        var newText = currentText + selectedValue + " ";
                        textarea.val(newText);
                    }

                    textarea.focus();

                    // cursor end પર મૂકી દઈએ
                    var len = textarea.val().length;
                    textarea[0].selectionStart = textarea[0].selectionEnd = len;

                    // reset dropdown
                    $(this).val(null).trigger("change");
                });

                //Tab 10 Billing Information
                $(document).off("change", "input[name='bank_guarantee_Y_N']")
                    .on("change", "input[name='bank_guarantee_Y_N']", function () {
