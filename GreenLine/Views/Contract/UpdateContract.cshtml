        function getDynamicStartDate()
        {
            var parsedStDate = new Date(contractStartDate);
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            if (parsedStDate instanceof Date && !isNaN(parsedStDate.getTime()))
            {
                var compStDate = new Date(parsedStDate); compStDate.setHours(0, 0, 0, 0);
                if (today < compStDate)
                {
                    return parsedStDate;
                }
            } return today;
        }

        function bindDatePicker(selector, isBasic) {
            $(selector).each(function () {
                
                var $this = $(this);
                if ($this.data('datepicker')) {
                    $this.datepicker('destroy');
                }
                
                var initialValue = $this.val();
                var rowEndDate = new Date(contractEndDate); // fallback
                var rowStartDate = isBasic ? new Date(contractStartDate) : getDynamicStartDate();

                var $row = $this.closest('tr');
