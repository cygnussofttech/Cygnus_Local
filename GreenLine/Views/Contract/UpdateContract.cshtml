                        // Draw routes if fromLane or toLane changed
                        var thisId = $(this).attr('id') || "";
                        if (thisId.endsWith('__FromLane') || thisId.endsWith('__ToLane')) {
                            drawAllRoutes("FTL");
                        }

                        var $currentRow = $(this).closest('tr');
                        var fromLane = $currentRow.find("select[id$='__FromLane']").val();
                        var toLane = $currentRow.find("select[id$='__ToLane'], input[id$='__ToLane']").val();
                        var prodGroup = $currentRow.find("input[id$='__ProductGroup']").val();
                        var effFrom = $currentRow.find("input[id$='__EffectiveFrom']").val();
                        var effTo = $currentRow.find("input[id$='__EffectiveTo']").val();

                        if (fromLane && toLane && prodGroup && effFrom && effTo) {
                            var maxToQty = 0;
                            var foundMatch = false;
                            var normProdGroup = normalizeProductGroup(prodGroup);

                            $currentRow.siblings('tr').each(function () {
                                var $siblingRow = $(this);
                                var sibFrom = $siblingRow.find("select[id$='__FromLane']").val();
                                var sibTo = $siblingRow.find("select[id$='__ToLane'], input[id$='__ToLane']").val();
                                var sibProd = $siblingRow.find("input[id$='__ProductGroup']").val();
                                var sibEffFrom = $siblingRow.find("input[id$='__EffectiveFrom']").val();
                                var sibEffTo = $siblingRow.find("input[id$='__EffectiveTo']").val();

                                if (sibFrom === fromLane && sibTo === toLane && normalizeProductGroup(sibProd) === normProdGroup && sibEffFrom === effFrom && sibEffTo === effTo) {
                                    var sibToQty = parseFloat($siblingRow.find("input[id$='__ToQty']").val()) || 0;
                                    if (sibToQty > maxToQty) {
                                        maxToQty = sibToQty;
                                    }
                                    foundMatch = true;
                                }
                            });

                            if (foundMatch) {
                                $currentRow.find("input[id$='__FromQty']").val(maxToQty + 1);
                                $currentRow.find("input[id$='__ToQty']").val(maxToQty + 10);
                            } else {
                                $currentRow.find("input[id$='__FromQty']").val(0);
                                $currentRow.find("input[id$='__ToQty']").val(10);
                            }
                        } else {
                            $currentRow.find("input[id$='__FromQty']").val(0);
                            $currentRow.find("input[id$='__ToQty']").val(10);
                        }
