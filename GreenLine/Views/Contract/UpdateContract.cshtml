                            $input.data("original-value", $input.val());

                            var isRestricted = id.indexOf("__FromLane") > -1 || name.indexOf(".FromLane") > -1 ||
                                id.indexOf("__ToLane") > -1 || name.indexOf(".ToLane") > -1 ||
                                id.indexOf("__MapDistance") > -1 || name.indexOf(".MapDistance") > -1 ||
                                id.indexOf("__ProductGroup") > -1 || name.indexOf(".ProductGroup") > -1 ||
