                var rowEffectiveToVal = $row.length > 0 ? $row.find("input[id$='__EffectiveTo']").val() : "";

                if (isSavedRow) {
                    if (rowEffectiveFromVal && rowEffectiveFromVal.trim() !== "") {
                        var parsedStDate = new Date(rowEffectiveFromVal);
                        if (parsedStDate instanceof Date && !isNaN(parsedStDate.getTime())) {
                            rowStartDate = parsedStDate;
                        }
                    }

                    // Check if this is an End Date field (EffectiveTo)
                    if ($this.attr('name') && $this.attr('name').indexOf('EffectiveTo') > -1) {
                        if (initialValue && initialValue.trim() !== "") {
                            var parsedEdDate = new Date(initialValue);
                            if (parsedEdDate instanceof Date && !isNaN(parsedEdDate.getTime())) {
                                rowEndDate = parsedEdDate;
                            }
                        }
                    }
                } else {
                    // For new/cloned rows, dynamically resolve start/end dates from values if present
                    if (rowEffectiveFromVal && rowEffectiveFromVal.trim() !== "") {
                        var parsedStDate = new Date(rowEffectiveFromVal);
                        if (parsedStDate instanceof Date && !isNaN(parsedStDate.getTime())) {
                            rowStartDate = parsedStDate;
                        }
                    }
                    if (rowEffectiveToVal && rowEffectiveToVal.trim() !== "") {
                        var parsedEdDate = new Date(rowEffectiveToVal);
                        if (parsedEdDate instanceof Date && !isNaN(parsedEdDate.getTime())) {
                            rowEndDate = parsedEdDate;
                        }
                    }
                }
                
                
                // Past date validation: if rowStartDate is less than today's date, make it today's date
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                if (rowStartDate < today) {
                    rowStartDate = today;
                }

                var pickerStartDate = rowStartDate;
                var pickerEndDate = rowEndDate;

                // Adjust selectable ranges based on companion values
                if ($this.attr('name') && $this.attr('name').indexOf('EffectiveFrom') > -1) {
                    if (rowEffectiveToVal && rowEffectiveToVal.trim() !== "") {
                        var parsedEdDate = new Date(rowEffectiveToVal);
                        if (parsedEdDate instanceof Date && !isNaN(parsedEdDate.getTime())) {
                            pickerEndDate = parsedEdDate;
                        }
                    }
                }
                if ($this.attr('name') && $this.attr('name').indexOf('EffectiveTo') > -1) {
                    if (rowEffectiveFromVal && rowEffectiveFromVal.trim() !== "") {
                        var parsedStDate = new Date(rowEffectiveFromVal);
                        if (parsedStDate instanceof Date && !isNaN(parsedStDate.getTime())) {
                            pickerStartDate = parsedStDate < today ? today : parsedStDate;
                        }
