        function initDatePicker() {
            bindDatePicker('.date-picker', true);
        }

        function validateTab(tabId) {

            if (contractMode === 'View') {
                return true;
            }
            // Skip validation for specific tabs
            if (tabId === "tab_6" || tabId === "tab_7" || tabId === "tab_9") {
                return true;
            }

            if (tabId === "tab_2") {
                // ✅ Check Minimum One Document (only if no existing documents)
                var existingCount = parseInt($("#hdnExistingDocCount").val()) || 0;

                if (existingCount == 0 ) {
                    TosterNotification("warning", "Operation fail..!! Minimum one document is mandatory.", "Oppps..!!");
                    return false;
                }
                return true;
            }

            var $tab = $("#" + tabId);
            var isValid = true;

            // Clear previous manual messages in this tab
            $tab.find(".help-block").remove();

            if (tabId === "tab_3") {
                clearAdditionalFieldsErrors();
                var isLengthValid = validateAdditionalFieldLengths();
                var isRowComplete = validateAdditionalFieldsRowComplete();
                if (!isLengthValid || !isRowComplete) {
                    isValid = false;
                }
            }

            // 1. Try to use standard form validation if available
            var $form = $tab.find("form");
            if ($form.length > 0) {
                if (!$form.valid()) {
                    isValid = false;
                }
            }

            // 2. Manual check for .required class (only if not already caught by form validation)
            $tab.find(".required:visible").each(function () {
                var $this = $(this);
                if (!$this.is("input, select, textarea")) return;

                // If standard validation already reported an error, skip manual check to avoid double messages
                if ($this.hasClass("is-invalid") ||
                    $this.next(".invalid-feedback").length > 0 ||
                    $this.next(".field-validation-error").length > 0 ||
                    $this.closest(".form-group").hasClass("has-error")) return;

                var value = $this.val();
                if (value === null || value === "" || (typeof value === "string" && value.trim() === "")) {
                    isValid = false;

                    if ($this.hasClass("select2-hidden-accessible")) {
                        $this.next(".select2-container")
                            .after('<div class="help-block text-danger small">This field is required</div>');
                    } else {
                        $this.after('<div class="help-block text-danger small">This field is required</div>');
                    }
                }
            });

            return isValid;
        }

        //Tab 6-7 Freight Charge PTL - Map Initialization
        function initializeMap(type) {
            mapPTL = new google.maps.Map(document.getElementById('googleMap' + type), {
                zoom: 5,
                center: {
                    lat: 20.5937,
                    lng: 78.9629
                }
            });
        }

        //Tab 6-7 Clear existing routes and markers from the map
        function clearAllRoutes() {
            directionsRenderers.forEach(function (renderer) {
                renderer.setMap(null);
            });

            directionsRenderers = [];

            markers.forEach(function (marker) {
                marker.setMap(null);
            });

            markers = [];
        }

        //Tab 6-7 Add marker to the map based on address
        function addMarker(address, title) {
            var geocoder = new google.maps.Geocoder();
            geocoder.geocode({ address: address }, function (results, status) {

                if (status === "OK") {

                    var marker = new google.maps.Marker({
                        map: mapPTL,
                        position: results[0].geometry.location,
                        title: title
                    });

                    markers.push(marker);

                    mapPTL.setCenter(results[0].geometry.location);
                }
            });
        }

        //Tab 6-7 Draw routes based on from and to locations in the table
        function drawAllRoutes(type) {

            clearAllRoutes();
            var tblName = "";

            if (type == "PTL") {
                $("#divGooglePTL").show(100);
                tblName = "sample_2";
            }

            if (type == "FTL") {
                $("#divGoogleFTL").show(100);
                tblName = "sample_FTL";
            }

            $("#" + tblName +  " tbody tr").each(function (index) {

                let $row = $(this);

                let fromText = $row.find("select[id$='__FromLane'] option:selected").text().trim();

                let toText = "";
                let $toLaneSelect = $row.find("select[id$='__ToLane']");
                if ($toLaneSelect.length > 0) {
                    toText = $toLaneSelect.find("option:selected").text().trim();
                } else {
                    let $toLaneInput = $row.find("input[id$='__ToLane']");
                    if ($toLaneInput.length > 0) {
                        let toData = null;
                        try {
                            if ($toLaneInput.data('select2')) {
                                toData = $toLaneInput.select2("data");
                            }
                        } catch (e) {
                            console.log("Error getting select2 data", e);
                        }
                        if (toData && toData.text) {
                            toText = toData.text.trim();
                        } else {
                            toText = ($toLaneInput.attr('data-option') || $toLaneInput.data('option') || "").trim();
                        }
                    }
                }

                if (fromText !== "" && fromText !== "Select From Lane") {
                    // ONLY FROM LOCATION
                    if (toText === "" || toText === "Select To Lane") {
                        addMarker(fromText, "From Location");
                    }
                    // DRAW ROUTE
                    else {
                        let directionsService = new google.maps.DirectionsService();
                        let routeColor = routeColors[index % routeColors.length];
                        let directionsRenderer = new google.maps.DirectionsRenderer({
                            map: mapPTL,
                            preserveViewport: true,
                            suppressMarkers: true,

                            polylineOptions: {
                                strokeColor: routeColor,
                                strokeOpacity: 0.45,
                                strokeWeight: 6
                            }
                        });

                        directionsRenderers.push(directionsRenderer);

                        directionsService.route(
                            {
                                origin: fromText,
                                destination: toText,
                                travelMode: google.maps.TravelMode.DRIVING
                            },
                            function (response, status) {

                                if (status === google.maps.DirectionsStatus.OK) {

                                    directionsRenderer.setDirections(response);

                                    let leg = response.routes[0].legs[0];
                                    // START MARKER (Origin)
                                    let startLabel = markerLabels[(index * 2) % markerLabels.length];
                                    let startMarker = new google.maps.Marker({
                                        position: leg.start_location,
                                        map: mapPTL,
                                        label: startLabel,
                                        title: "Start: " + fromText
                                    });
                                    markers.push(startMarker);

                                    // END MARKER (Destination)
                                    let endLabel = markerLabels[(index * 2 + 1) % markerLabels.length];
                                    let endMarker = new google.maps.Marker({
                                        position: leg.end_location,
                                        map: mapPTL,
                                        label: endLabel,
                                        title: "End: " + toText
                                    });
                                    markers.push(endMarker);

                                    // DISTANCE

                                    let distanceKM = Math.round(
                                        response.routes[0].legs[0].distance.value / 1000
                                    );

                                    $row.find("input[id$='__MapDistance']").val(distanceKM);
                                    $row.find("input[id$='__ContractualDistance']").val(distanceKM);

                                } else {

                                    console.log("Route Error : " + status);
                                }
                            }
                        );
                    }
                }
            });
        }

        // Helper function to normalize comma-separated ProductGroup list for order-independent duplicate checks
        function normalizeProductGroup(prodGroup) {
            if (!prodGroup) return "";
            return prodGroup.split(',')
                .map(function (item) { return item.trim().toLowerCase(); })
                .filter(function (item) { return item !== ""; })
                .sort()
                .join(',');
        }

        // Custom function to check and highlight duplicate rows in a table (PTL or FTL)
        function checkDuplicateRows(tableId) {
            var hasDuplicate = false;
            var rowKeys = {}; // Tracks key strings and their corresponding row elements

            // Clear previous highlighting
            $(tableId + " tbody tr.editorRow").removeClass("duplicate-row-highlight");

            $(tableId + " tbody tr.editorRow").each(function() {
                var $tr = $(this);
                // Read values of all required fields
                var fromLane = $tr.find("select[id$='__FromLane']").val();
                var toLane = $tr.find("select[id$='__ToLane'], input[id$='__ToLane']").val();
                var effectiveFrom = $tr.find("input[id$='__EffectiveFrom']").val();
                var effectiveTo = $tr.find("input[id$='__EffectiveTo']").val();
                var productGroup = $tr.find("input[id$='__ProductGroup']").val();
                var fromQty = $tr.find("input[id$='__FromQty']").val();
                var toQty = $tr.find("input[id$='__ToQty']").val();

                // Only validate if all required fields are non-empty
                if (fromLane && toLane && productGroup && fromQty && toQty &&
                    effectiveFrom && effectiveTo) {

                    fromLane = fromLane.trim();
                    toLane = toLane.trim();
                    var normalizedProd = normalizeProductGroup(productGroup);
                    fromQty = fromQty.trim();
                    toQty = toQty.trim();
                    effectiveFrom = effectiveFrom.trim();
                    effectiveTo = effectiveTo.trim();

                    // Create a composite unique key for duplicate identification (excludes fromLane and toLane)
                    var key = [
                        fromLane, toLane, normalizedProd, fromQty, toQty, effectiveFrom, effectiveTo
                    ].join('|').toLowerCase();

                    if (!rowKeys[key]) {
                        rowKeys[key] = [];
                    }
                    rowKeys[key].push($tr);
                }
            });

            // Apply highlighting class on all duplicate rows found
            Object.keys(rowKeys).forEach(function(key) {
                if (rowKeys[key].length > 1) {
                    hasDuplicate = true;
                    rowKeys[key].forEach(function($tr) {
                        $tr.addClass("duplicate-row-highlight");
                    });
                }
            });

            // Newly detected duplicate toast warning to prevent spamming
            window.lastDuplicateStates = window.lastDuplicateStates || {};
            if (hasDuplicate && !window.lastDuplicateStates[tableId]) {
                TosterNotification("error", "Same data found for FromLane, ToLane, Product Group, FromQty, ToQty, FromDate, ToDate. Please check your data.", "Duplicate Record");
            }
            window.lastDuplicateStates[tableId] = hasDuplicate;

            return hasDuplicate;
        }

        function stopTochangeinContract(showToast) {
            
            if (showToast === undefined) showToast = true;
            var endDate = new Date(contractEndDate);
            if (endDate) {
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                // Block if contract is expired
                if (endDate < today) {
                    if (showToast) {
                        TosterNotification(
                            "warning",
                            "Your contract has expired. Any operation is not allowed.",
                            "Contract Expired"
                        );
                    }
                    return true;
                }
            }
            return false;
        }

        function cloneSelectedRows(tableSelector, bodySelector, indexPrefix, mode, DomainName) {

            if (stopTochangeinContract()) {
                return;
            }

            var $checked = $(tableSelector + ' tbody .row-checkbox:checked');
            if ($checked.length === 0) {
                TosterNotification("warning", "Warning !! Please select at least one row to clone.", "Warning");
                return;
            }
            if ($checked.length > 5) {
                TosterNotification("warning", "Warning !! You can clone maximum 5 rows at a time.", "Limit Exceeded");
                return;
            }

            var $btn = (mode === 'PTL') ? $('#btnCloneFreightRows') : $('#btnCloneFTLRows');
            $btn.prop('disabled', true);

            $checked.each(function () {
                var $row = $(this).closest('tr');

                // Generate a new unique sequence index based on number of rows
                var newIndex = $(tableSelector + " input.iHidden").length + 1;

                // Clone the row without event handlers
                var $cloned = $row.clone(false);

                // Uncheck the checkbox in both original and cloned rows
                $(this).prop('checked', false);
                $cloned.find('.row-checkbox').prop('checked', false);

                // Get the original index from the collection Index hidden input inside this row
                // NOTE: BeginCollectionItem uses lowercase ".index" name casing
                var originalIndex = $row.find('input[name="' + indexPrefix + '.index"]').val();
                if (!originalIndex) {
                    originalIndex = $row.find('input[name$=".index"]').val();
                }

                if (originalIndex) {
                    // Set the new index in the cloned Index input
                    $cloned.find('input[name="' + indexPrefix + '.index"]').val(newIndex);
                    $cloned.find('input[name$=".index"]').val(newIndex);

                    // Replace the original index with the new sequence index in all input names and IDs
                    $cloned.find('input, select, textarea').each(function () {
                        var name = $(this).attr('name');
                        if (name) {
                            $(this).attr('name', name.replace('[' + originalIndex + ']', '[' + newIndex + ']'));
                        }
                        var id = $(this).attr('id');
                        if (id) {
                            $(this).attr('id', id.replace('_' + originalIndex + '__', '_' + newIndex + '__'));
                        }
                    });
                }

                // Reset sequence ID in the UI and hidden fields to the new incremented sequence number
                $cloned.find('input.iHidden').val(newIndex);
                $cloned.find('#hdnblnk, #hdnblnk1').val(newIndex);
                $cloned.find('.row-id-display').text(newIndex);

                // Copy the current values of ALL inputs, select dropdowns, and textareas from original to cloned row, resetting ToLane and ProductGroup
                $row.find('input, select, textarea').each(function (idx) {
                    var originalVal = $(this).val();
                    var name = $(this).attr('name') || "";
                    var id = $(this).attr('id') || "";
                    var $clonedField = $cloned.find('input, select, textarea').eq(idx);

                    var nameLower = name.toLowerCase();
                    if (nameLower.indexOf('tolane') > -1 || nameLower.endsWith('.rate') || nameLower.endsWith('.ftl1_trip_rate')) {
                        $clonedField.val('');
                        if (nameLower.indexOf('tolane') > -1) {
                            $clonedField.removeAttr('data-option');
                            $clonedField.data('option', '');
                        }
                    } else if (nameLower.endsWith('.effectivefrom')) {
                        var val = (mode === 'PTL') ? $("#CustsingleSlab_EffectiveFrom").val() : $("#FTLfreightCharge_EffectiveFrom").val();
                        $clonedField.val(val);
                    } else if (nameLower.endsWith('.effectiveto')) {
                        var val = $("#Contract_Eddate").val();
                        $clonedField.val(val);
                    } else if (name.indexOf('.srno') > -1) {
                        // Reset database primary key to '0' so it is saved as a new record
                        $clonedField.val('0');
                    } else if (name.indexOf('.index') > -1) {
                        // Maintain the new sequence index for collection item index
                        $clonedField.val(newIndex);
                    } else if (id === 'hdnblnk' || id === 'hdnblnk1' || $clonedField.hasClass('iHidden')) {
                        // Maintain the new sequence index for blank hidden headers
                        $clonedField.val(newIndex);
                    } else {
                        $clonedField.val(originalVal);
                    }
                });

                // Clean up Select2 container and classes for standard select dropdowns, ProductGroup and ToLane text inputs
                $cloned.find('.select2-container').remove();
                $cloned.find('select').removeClass('select2-hidden-accessible').removeAttr('data-select2-id').off();
                $cloned.find('input[id$="__ProductGroup"]').removeClass('select2-hidden-accessible').removeAttr('data-select2-id').off();
                $cloned.find('input[id$="__ToLane"]').removeClass('select2-hidden-accessible').removeAttr('data-select2-id').off();

                // Set up the delete button in the last td
                var $deleteTd = $cloned.find('td').last();
                if (mode === 'PTL') {
                    $deleteTd.html('<div class="d-flex align-items-center justify-content-center gap-1"><a href="#" id="btnDeleteFreightPTLMatrixCharge" class="@ViewBag.UI.Buttons.Delete.CssClass btn-delete-row"><i class="@ViewBag.UI.Buttons.Delete.Icon"></i></a></div>');
                }
                else {
                    $deleteTd.html('<div class="d-flex align-items-center justify-content-center gap-1"><a href="#" id="btnDeleteFreightFTLMatrixCharge" class="@ViewBag.UI.Buttons.Delete.CssClass btn-delete-row"><i class="@ViewBag.UI.Buttons.Delete.Icon"></i></a></div>');
                }


                // Always convert the cloned EffectiveFrom input to a date-picker
                var $effectiveFromInput = $cloned.find('input[name$=".EffectiveFrom"]');
                if ($effectiveFromInput.length > 0) {
                    $effectiveFromInput.removeClass('readonly').removeAttr('readonly');
                    $effectiveFromInput.addClass('date-picker effective-date required');
                    $effectiveFromInput.attr('autocomplete', 'off');
                }

                // Append the cloned row to the table body
                $(bodySelector).append($cloned);

                // Re-initialize Select2 on the cloned dropdowns
                $cloned.find('select').each(function () {
                    $(this).select2({
                        placeholder: "Select an option",
                        allowClear: true,
                        width: '100%'
                    });
                });

                // Re-initialize ProductGroup using GetType helper function (which sets up select2 tags)
                var productGroupId = indexPrefix + "_" + newIndex + "__ProductGroup";
                GetType(productGroupId, "PROD", DomainName + "/Contract/GetMasterList");

                // Re-initialize ToLane autocomplete search
                var toLaneId = indexPrefix + "_" + newIndex + "__ToLane";
                initToLaneAjaxDropdown("#" + toLaneId, DomainName);

                bindDatePicker($cloned.find('.date-picker'));
            });

            // Uncheck select all master checkboxes
            $(tableSelector + ' #chkSelectAllFreight, ' + tableSelector + ' #chkSelectAllFTL').prop('checked', false);

            // Redraw routes for mapping / distances
            setTimeout(function () {
                drawAllRoutes(mode);
                $btn.prop('disabled', false);
            }, 500);
        }

