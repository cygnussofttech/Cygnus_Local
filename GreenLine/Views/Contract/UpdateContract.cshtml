        function initToLaneAjaxDropdown(selector, DomainName) {
            $(selector).select2({
                placeholder: "Select To Lane",
                minimumInputLength: 3,
                allowClear: true,
                ajax: {
                    url: DomainName + "/Master/GetLaneListJson",
                    dataType: 'json',
                    data: function (term) {
                        return {
                            searchTerm: term
                        };
                    },
                    results: function (data) {
                        return {
                            results: data
                        };
                    }
                },
                initSelection: function (item, callback) {
                    var id = item.val();
                    var text = item.data('option') || item.find('option:selected').text();
                    if (!text && id) {
                        text = id;
                    }
                    var data = {
                        id: id,
                        text: text
                    };
                    callback(data);
                },
                formatResult: function (item) {
                    return ('<div>' + item.text + '</div>');
                },
                formatSelection: function (item) {
                    return (item.text);
                },
                escapeMarkup: function (m) {
                    return m;
                },
            });
        }

        var Formvalidate = function (DomainName, formName) {
            var form1 = $('#' + formName);
            form1.validate({
                doNotHideMessage: true,
                onfocusout: false,
                onkeyup: false,
                onclick: false,
                errorElement: 'span',
                errorClass: 'help-block',
                focusInvalid: false,
                ignore: ":hidden:not(.select2-hidden-accessible)",
                rules: {
                    //Tab 1
                    'conType': { required: true },
                    //Tab 2
                    'Dedicated_Vehicle': { required: true },
                    'risktype': { required: true },
                    'fuelSurchagre': { required: true },
                    //Tab 8
                    'PodRequired': { required: true },
                    'PodSubmission': { required: true },
                    'BillSubmission': { required: true },
                    'bank_guarantee_Y_N': { required: true },
                    'deposit_Y_N': { required: true },
                    'panlty_clause_Y_N': { required: true },
                },
                messages: {
                },
                errorPlacement: function (error, element) {
                    if (element.is(":radio")) {
                        error.insertAfter(element.closest('.form-group').find('.col-12'));
                    }
                    else if (element.parent(".input-group").length > 0) {
                        error.insertAfter(element.parent(".input-group"));
                    } else if (element.hasClass("select2-hidden-accessible") || element.next(".select2-container").length > 0) {
                        error.insertAfter(element.next(".select2-container"));
                    } else {
                        error.insertAfter(element);
                    }
                },
                highlight: function (element) {
                    $(element).closest('.form-group').addClass('has-error');
                },
                unhighlight: function (element) {
                    $(element).closest('.form-group').removeClass('has-error');
                },
                success: function (label) {
                    label.closest('.form-group').removeClass('has-error');
                }
            });
        }

