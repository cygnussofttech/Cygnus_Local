@model GreenLineDataService.Models.CYGNUS_custcontract_charge
@using GreenLineDataService.Models

@{
    GreenLineDataService.Helper.Interface.IMasterService _masterService = new GreenLineDataService.Helper.MasterService();


    var WeightconsiderList = new List<SelectListItem> {
        new SelectListItem { Text = "Higher of Volumetric and Actual Weight", Value = "H" },
        //new SelectListItem { Text = "Always Actual weight", Value = "A" },
        //new SelectListItem { Text = "Always Volumetric weight", Value = "V" },
    };

    var DiscountRateList = new List<SelectListItem> {
     new SelectListItem { Text = "In % of Freight", Value = "H" },
     new SelectListItem { Text = "Flat (In Rs.)", Value = "F" },
     new SelectListItem { Text = "PerKg", Value = "W" },
     new SelectListItem { Text = "PerPkg", Value = "P" },
     new SelectListItem { Text = "PerTon", Value = "T" },
    };

    var DemurrageCalculationList = new List<SelectListItem> {
        new SelectListItem { Text = "Inclusive of free storage days", Value = "1" },
        new SelectListItem { Text = "Exclusive of free storage days ", Value = "2" },
     };

    var DemurrageRateRateList = new List<SelectListItem> {
        new SelectListItem { Text = "% of Invoice", Value = "%I" },
        new SelectListItem { Text = "Per Kg Per Day", Value = "WD" },
        new SelectListItem { Text = "Per PKg Per Day", Value = "PD" },
    };

    var DieselHikeReviewType = new List<SelectListItem> {
        new SelectListItem { Text = "Monthly", Value = "M" },
        new SelectListItem { Text = "Yearly", Value = "Y" },
        new SelectListItem { Text = "EffectiveDate", Value = "ED" }
    };

    var EffectiveType = new List<SelectListItem> {
         new SelectListItem { Text = "From Fright Rate", Value = "FR" },
         new SelectListItem { Text = "Per KM", Value = "KM" },
    };

    var RefrenceFuelType = new List<SelectListItem> {
    new SelectListItem { Text = "HSD", Value = "R1" },
    new SelectListItem { Text = "LNG", Value = "R2" },
    new SelectListItem { Text = "CNG", Value = "R3" },
    new SelectListItem { Text = "Power", Value = "R4" },
};
}

@using (Html.BeginForm("AddServiceSelection", "Contract", FormMethod.Post, new { id = "form_sampleservice", @class = "form-modern-ui", enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(m => m.ContractId)
    @Html.HiddenFor(m => m.Custcode)
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="ri-service-line align-middle me-1"></i> Service Selection
                    </h5>
                </div>
                <div class="card-body">
                    @*Service Selection*@
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Transit Mode</label>
                                @Html.DropDownListFor(m => m.trans_type, new SelectList(ViewBag.trans_type, "CodeId", "CodeDesc", Model.trans_type), new { @class = "required select2 form-control", placeholder = "Select Transit Mode", @disabled = "disabled" })
                                @Html.HiddenFor(m => m.trans_type)
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Rate Types Allowed</label>
                                @Html.TextBoxFor(m => m.rate_type, new { placeholder = "Select Rate Type", @class = "form-control required" })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Matrices Allowed</label>
                                @Html.DropDownListFor(m => m.matrix_type, new SelectList(ViewBag.objMasterMatrixList, "CodeId", "CodeDesc"), new { placeholder = "Select Allowed Matrix", @class = "form-control select2 required", @disabled = "disabled" })
                                @Html.HiddenFor(m => m.matrix_type)
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Pickup/Delivery</label>
                                @Html.TextBoxFor(m => m.pkp_dly, new { placeholder = "Select PickUp delivery", @class = "form-control required" })
                            </div>
                        </div>
                   
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Fuel Type</label>
                                @Html.DropDownListFor(m => m.fuel_type, new SelectList(ViewBag.FUELTY, "CodeId", "CodeDesc"), "", new { @class = "select2 form-control required", placeholder = "Select Fuel Type" })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Weight to Consider</label>
                                @Html.DropDownListFor(m => m.cft_weight_type, new SelectList(WeightconsiderList, "Value", "Text"), new { @class = "required select2 form-control", placeholder = "Select Weight to Consider", @disabled = "disabled" })
                                @Html.HiddenFor(m => m.cft_weight_type)
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Service Type </label>
                                @if (string.IsNullOrEmpty(Model.service_type))
                                {
                                    @Html.DropDownListFor(m => m.service_type, new SelectList(ViewBag.SVCTYPE, "CodeId", "CodeDesc"), "", new { @class = "required select2 form-control", placeholder = "Select Service Type" })
                                }
                                else
                                {
                                    @Html.DropDownListFor(m => m.service_type, new SelectList(ViewBag.SVCTYPE, "CodeId", "CodeDesc"), new { @class = "required select2 form-control", placeholder = "Select Service Type" })
                                    @Html.HiddenFor(m => m.service_type)
                                }
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">LR Format</label>
                                @Html.DropDownListFor(m => m.lr_type, new SelectList(ViewBag.LRTYPE, "CodeId", "CodeDesc"), "", new { @class = "required select2 form-control", placeholder = "Select LR Format", })
                            </div>
                        </div>
                   
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Dedicated Vehicles</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Dedicated_Vehicle, "Y", new { @class = "form-check-input" })
                                        <label class="form-check-label">Yes</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Dedicated_Vehicle, "N", new { @class = "form-check-input" })
                                        <label class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Risk Type</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.risktype, "C_Q", new { @class = "form-check-input" })
                                        <label class="form-check-label">Carrier Risk</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.risktype, "O_Q", new { @class = "form-check-input" })
                                        <label class="form-check-label">Owner Risk</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

