        @*Diesel Hike*@
        <div class="col-md-12">
            <div class="card m-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="ri-fire-line align-middle me-1"></i> Fuel Hike
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Fuel Hike Applicable.?</label>
                                <div class="form-check">
                                    @Html.CheckBoxFor(m => m.IsDieselHikeApplicable, new { @class = "form-check-input" })
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Review Type</label>
                                @Html.DropDownListFor(m => m.DieselHikeReviewType, new SelectList(DieselHikeReviewType, "Value", "Text"), "", new { @class = "select2 required drp form-control", placeholder = "Select Hike Review Type" })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Base Fuel Rate</label>
                                @Html.TextBoxFor(m => m.BaseDieselRate, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))" })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Fuel Rate Date</label>
                                <div class="input-group date" data-date-format="dd M yyyy">
                                    @Html.TextBoxFor(m => m.RateDate,
                                        Convert.ToDateTime(Model.RateDate).Year < 1900
                                            ? Convert.ToDateTime(Model.Contract_Stdate).ToString("dd MMM yyyy") :
                                           Convert.ToDateTime(Model.RateDate).ToString("dd MMM yyyy"),
                                        new { @class = "form-control date-picker required", placeholder = "Select Fuel Rate Date" })
                                    <span class="input-group-text bg-light border-start-0" style="cursor:pointer;">
                                        <i class="ri-calendar-2-line"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="form-label">Current Fuel Rate</label>
                            @Html.TextBoxFor(m => m.CurrentDieselRate, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", @readonly = true })
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Change Amount (Rs.)</label>
                                @Html.TextBoxFor(m => m.Hike_Amount_Rs, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Effective Amount (Rs.)</label>
                                @Html.TextBoxFor(m => m.Effective_Amount_Rs, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Hike (%)</label>
                                @Html.TextBoxFor(m => m.Hike_Amount_Percentage, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", @max = "100", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Effective (%)</label>
                                @Html.TextBoxFor(m => m.Effective_Amount_Percentage, new { @class = "form-control", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", @max = "100", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Fuel (%)</label>
                                @Html.TextBoxFor(m => m.CurrentDieselPercentage, new { @class = "form-control", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Effected On Date</label>
                                <div class="input-group date" data-date-format="dd M yyyy">
                                    @Html.TextBoxFor(m => m.EffectedDate,
                                        Convert.ToDateTime(Model.EffectedDate).Year < 1900
                                            ? Convert.ToDateTime(Model.Contract_Stdate).ToString("dd MMM yyyy") :
                                           Convert.ToDateTime(Model.EffectedDate).ToString("dd MMM yyyy"),
                                        new { @class = "form-control date-picker required", placeholder = "Select Effected Date" })
                                    <span class="input-group-text bg-light border-start-0" style="cursor:pointer;">
                                        <i class="ri-calendar-2-line"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 DieselHikeDiv">
                            <div class="form-group">
                                <label class="form-label required-field">Effective Type</label>
                                @Html.DropDownListFor(m => m.EffectiveType, new SelectList(EffectiveType, "Value", "Text"), "", new { @class = "required select2 drp form-control", placeholder = "Select Effective Type" })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Reference Fuel Type</label>
                                @Html.DropDownListFor(m => m.ReferenceFuelType, new SelectList(RefrenceFuelType, "Value", "Text", Model.ReferenceFuelType), "", new { @class = "select2 reselect required form-control", placeholder = "Select Reference Fuel Type" })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Fuel Surcharge Applicable</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.fuelSurchagre, "Y", new { @class = "form-check-input" })
                                        <label class="form-check-label">Yes</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.fuelSurchagre, "N", new { @class = "form-check-input" })
                                        <label class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Fuel Hike Rate Details?</label>
                                <div class="chkactive">
                                    <a href="#" class="btn default btn-xs blue-stripe DieselHikeRate" style="padding: 7px 5px;" data-toggle="modal" data-type="1"><i class="fa fa-lock"></i>&nbsp;Show Diesel Hike Rate</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

<div class="form-actions">
    <button type="button" id="btnSubmitservicePreviousTab" class="@ViewBag.UI.Buttons.Previous.CssClass"><i class="@ViewBag.UI.Buttons.Previous.Icon"></i>@ViewBag.UI.Buttons.Previous.Label</button>
    <button type="button" id="btnSubmitservice" class="@ViewBag.UI.Buttons.Submit.CssClass"><i class="@ViewBag.UI.Buttons.Submit.Icon"></i>Save & Next</button>
    <button type="button" id="btnSubmitserviceNextTab" class="@ViewBag.UI.Buttons.Next.CssClass"><i class="@ViewBag.UI.Buttons.Next.Icon"></i>@ViewBag.UI.Buttons.Next.Label</button>
</div>