@model GreenLineDataService.ViewModel.ContractDocumentsViewModel

@using (Html.BeginForm("AddContractDocuments", "Contract", FormMethod.Post, new { id = "form_docs", @class = "form-modern-ui", enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(m => m.ContractId)
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                @*Documents*@
                <div class="card-header">
                    <div class="row">
                        <div class="col-lg-6">
                            <h5 class="card-title">
                                <i class="ri-file-2-line align-middle me-1"></i> Documents
                            </h5>
                        </div>
                        <div class="col-lg-6 text-end">
                            <button type="button" id="btnAddDocument" class="@ViewBag.UI.Buttons.Add.CssClass  btn-label"><i class="@ViewBag.UI.Buttons.Add.Icon label-icon align-middle fs-16 me-2"></i>@ViewBag.UI.Buttons.Add.Label</button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-12">
                            <table id="tbl_docUpload" class="table table-striped table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th class="col-5">Document Type</th>
                                        <th class="col-5 d-flex">File Upload(Image/PDF)</th>
                                        <th class="col-2 text-center">Remove</th>
                                    </tr>
                                </thead>
                                <tbody id="tbl_body_DocList">
                                    <tr class="docRow">
                                        <td>
                                            <div class="col-12">
                                                @Html.DropDownList("Documents[0].Doc_Type", new SelectList(ViewBag.docType, "CodeId", "CodeDesc"), "", new { @class = "select2 form-control", placeholder = "Select Document Type" })
                                            </div>
                                        </td>
                                        <td>
                                            <input type="file" name="Documents[0].fileUpload"
                                                   class="form-control fileUpload" />
                                        </td>
                                        <td class="text-center d-flex justify-content-center align-items-center">
                                            <button type="button" class="btn btn-sm ui-btn-cancel btnRemoveRow">X</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="hdnExistingDocCount" value="@(Model.ExistingDocuments != null ? Model.ExistingDocuments.Count : 0)" />
        @if (Model.ExistingDocuments != null && Model.ExistingDocuments.Count > 0)
        {
            <div class="col-md-12">
                <div class="card m-0">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="ri-file-list-3-line align-middle me-1"></i> Existing Documents
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-12">
                                <table class="table table-striped table-bordered table-hover m-0">
                                    <thead>
                                        <tr>
                                            <th class="col-2">SrNo</th>
                                            <th class="col-4">Document Type</th>
                                            <th class="col-3 text-center">Download</th>
                                            <th class="col-3 text-center">Delete</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in Model.ExistingDocuments)
                                        {
                                            var fileName = !string.IsNullOrEmpty(doc.Doc_File) ? System.IO.Path.GetFileName(doc.Doc_File) : "";
                                            <tr>
                                                <td>@doc.SrNo</td>
                                                <td>@doc.Doc_Type_Desc</td>
                                                <td class="text-center">
                                                    <a href="javascript:void(0);"
                                                       onclick="DownloadAttachment('@Url.Content("~/Uploads/Contract/BasicDocuments/" + fileName)', '@fileName')"
                                                       class="btn btn-sm btn-info"
                                                       title="Download Document">
                                                        <i class="ri-file-download-line"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-sm btn-danger btnDeleteExistingDoc" data-id="@doc.Id" title="Delete Document">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
<div class="form-actions">
    <button type="button" id="btnDocumentPrevious" class="@ViewBag.UI.Buttons.Previous.CssClass"><i class="@ViewBag.UI.Buttons.Previous.Icon"></i>@ViewBag.UI.Buttons.Previous.Label</button>
    <button type="button" id="btnSaveDocumentStay" style="display:none;" data-mode="stay" class="@ViewBag.UI.Buttons.Submit.CssClass"><i class="@ViewBag.UI.Buttons.Submit.Icon"></i>Save & Stay On Page</button>
    <button type="button" id="btnSaveDocument" style="display:none;" data-mode="next" class="@ViewBag.UI.Buttons.Submit.CssClass"><i class="@ViewBag.UI.Buttons.Submit.Icon"></i>Save & Next</button>
    <button type="button" id="btnDocumentNext" class="@ViewBag.UI.Buttons.Next.CssClass"><i class="@ViewBag.UI.Buttons.Next.Icon"></i>@ViewBag.UI.Buttons.Next.Label</button>
</div>