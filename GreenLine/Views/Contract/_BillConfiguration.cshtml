                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <div class="form-group">
                            <label class="form-label required-field">
                                Bill Submission Branch
                            </label>
                            @Html.DropDownListFor(m => m.billsub_loccode, new SelectList(ViewBag.ListLocations, "LocCode", "LocName_LocCode"), "", new { @class = "required select2 form-control", placeholder = "Select Bill Submission Location" })
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-group">
                            <label class="form-label required-field">
                                Bill Collection Branch
                            </label>
                            @Html.DropDownListFor(m => m.billcol_loccode, new SelectList(ViewBag.ListLocations, "LocCode", "LocName_LocCode"), "", new { @class = "required select2 form-control", placeholder = "Select Bill Collection Location" })
