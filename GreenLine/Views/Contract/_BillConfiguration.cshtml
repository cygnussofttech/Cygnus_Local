@model GreenLineDataService.Models.CYGNUS_BILL_CONFIGURATION
@using GreenLineDataService.Models
@using GreenLine.Classes

@{
    List<CYGNUS_Customer_Bill_Details> billDetails = ViewBag.billDetails as List<CYGNUS_Customer_Bill_Details> ?? new List<CYGNUS_Customer_Bill_Details>();

    var BillFormat = new List<SelectListItem> {
    new SelectListItem { Text = "Standard", Value = "B1"},
    new SelectListItem { Text = "Custome1", Value = "B2" },
    new SelectListItem { Text = "Custome2", Value = "B3" },
    };

    var ItemDesc = new List<SelectListItem>
{
        new SelectListItem { Text = "Destination", Value = " <<Destination>>"},
        new SelectListItem { Text = "Rate", Value = " <<Rate>>"},
        new SelectListItem { Text = "Source", Value = " <<Source>>"},
        new SelectListItem { Text = "TripDate", Value = " <<TripDate>>"},
        new SelectListItem { Text = "Vehicle", Value = " <<Vehicle>>"},
    };

    var BillingInstanceList = new List<SelectListItem> {
     new SelectListItem { Text = "On Booking - When LR is created", Value = "BKG" },
     new SelectListItem { Text = "On Delivery - When LR status is Delivered", Value = "DEL" },
     new SelectListItem { Text = "On POD Approval - When Freight Audit Team Flags the POD as Clean POD in system ( Sign , Seal , Count, Date  are okay) ", Value = "PA" },
     new SelectListItem { Text = "On POD Scan - When POD is uploaded against the LR", Value = "PS" },
     new SelectListItem { Text = "On POD Process Closure - When Physical POD is received at HO and marked in system against LR as Physical POD Received", Value = "PC" },
 };

    var BillingScheduleList = new List<SelectListItem> {
     new SelectListItem { Text = "Monthly", Value = "1" },
     new SelectListItem { Text = "Weekly", Value = "2" },
     new SelectListItem { Text = "Others", Value = "3" },
 };
}


<div class="row form-modern-ui">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="ri-bill-line align-middle me-1"></i> Customer Bill Information
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle m-0" id="tblBillDetails">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">Action</th>
                                <th class="text-center">GST No.</th>
                                <th class="text-center">GST State </th>
                                <th class="text-start" style="min-width: 180px;">Legal Business Name</th>
                                <th class="text-start" style="min-width: 220px;">Address </th>
                                <th class="text-center">Country </th>
                                <th class="text-center">State </th>
                                <th class="text-center">City </th>
                                <th class="text-center">Area </th>
                                <th class="text-center">Pincode  </th>
                                <th class="text-center">SAP Code </th>
                                <th class="text-center">PANNo </th>
                                <th class="text-center">TANNo </th>
                                <th class="text-center">Mobile No </th>
                                <th class="text-center">Email</th>
                                <th class="text-center">Default</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (billDetails != null && billDetails.Count > 0)
                            {
                                foreach (var item in billDetails)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input chkSelectBillAddress"
                                                   data-gstin="@item.Bill_GSTIN"
                                                   data-gststate="@item.GSTState"
                                                   data-buisnessname="@item.Bill_Legal_Business_Name"
                                                   data-address="@item.Bill_Address"
                                                   data-area="@item.Area"
                                                   data-city="@item.City"
                                                   data-state="@item.State"
                                                   data-country="@item.Country"
                                                   data-pincode="@item.Bill_Pincode"
                                                   data-isdefault="@item.IsDefault"
                                                   style="cursor: pointer; transform: scale(1.2);" />
                                        </td>
                                        <td class="text-center">@item.Bill_GSTIN</td>
                                        <td class="text-center">@item.GSTState</td>
                                        <td class="text-start" style="white-space: normal; word-break: break-word;">@item.Bill_Legal_Business_Name</td>
                                        <td class="text-start" style="white-space: normal; word-break: break-word;">@item.Bill_Address</td>
                                        <td class="text-center">@item.Country</td>
                                        <td class="text-center">@item.State</td>
                                        <td class="text-center">@item.City</td>
                                        <td class="text-center">@item.Area</td>
                                        <td class="text-center">@item.Bill_Pincode</td>
                                        <td class="text-center">@item.Bill_SAP_Code</td>
                                        <td class="text-center">@item.Bill_PAN</td>
                                        <td class="text-center">@item.Bill_TAN</td>
                                        <td class="text-center">@item.Bill_Mobile</td>
                                        <td class="text-center">@item.Bill_Email</td>
                                        <td class="text-center">@(item.IsDefault ? "Yes" : "No")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@using (Html.BeginForm("AddBillConfiguration", "Contract", FormMethod.Post, new
{
    id = "form_BillConfiguration",
    @class = "form-modern-ui",
    enctype = "multipart/form-data"
}))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ContractId)
    @Html.HiddenFor(m => m.CustCode)
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="ri-bill-line align-middle me-1"></i> Billing Configuration
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <div class="d-flex">
                                    <label class="form-label required-field">Bill To (Select From Customer Bill Address)</label>
                                </div>
                                @Html.TextAreaFor(m => m.BillTo, new { @class = "form-control required", placeholder = "Bill Address", @readonly = true })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">
                                    Service HSN
                                </label>
                                @Html.DropDownListFor(m => m.HSN_Code, new SelectList(ViewBag.ServiceHSN, "CodeId", "CodeDesc"), "", new
                                {
                                    @class = "select2 form-control required",
                                    placeholder = "Select Service HSN"
                                })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Bill Format</label>
                                @Html.DropDownListFor(m => m.Bill_Format, new SelectList(BillFormat, "Value", "Text"), "", new
                                    {
                                        @class = "select2 form-control required",
                                        placeholder = "Select Bill Format"
                                    })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Line Items Per Invoice</label>
                                @Html.TextBoxFor(m => m.Max_Trip_Count, new { @class = "form-control", placeholder = "Enter Item Per Invoice", @onkeypress = "javascript:return validDigits(event,this)", Value = (Model.Max_Trip_Count == 0 ? "" : Model.Max_Trip_Count.ToString("G29")) })
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Organization Bank</label>
                                @Html.DropDownListFor(m => m.Bank_Details, new SelectList(ViewBag.bankDetails, "Bank_Account_No", "Bank_Name"), "", new { @class = "required select2 form-control", placeholder = "Select Bank" })
                            </div>
                            @if (ViewBag.bankDetails.Count == 0)
                            {
                                <a href="@Url.Action("OrganizationMaster", "Master", new { CompanyCode = Model.Bill_Org })" target="_blank" class="text-primary small">
                                    <i class="ri-add-circle-line align-middle"></i> No bank details found. Click to add.
                                </a>
                            }
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Invoice Line Item Description</label>
                                @Html.DropDownList("ddlItemDesc", new SelectList(ItemDesc, "Value", "Text"), "", new
                                {
                                    @class = "select2 form-control",
                                    id = "ddlItemDesc",
                                    placeholder = "Select Item Description"
                                })
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6">
                            <div class="form-group">
                                @Html.TextAreaFor(m => m.Item_Description, new { @class = "form-control ", id = "txtItemDesc", rows = 5, style = "resize: vertical; height: 70px !important;", placeholder = "Enter Item Description", @readonly = "readonly" })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label required-field">Document Type</label>
                                @Html.DropDownListFor(m => m.DocumentType, new SelectList(ViewBag.VehicleDocumentType, "Id", "Document_Name"), "", new
                           {
                               @class = "select2 form-control required",
                               placeholder = "Select Document Type"
                           })
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Single Line Item</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Single_Line_Item, "Y", new { @class = "form-check-input" })
                                        <label class="form-check-label">Yes</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Single_Line_Item, "N", new { @class = "form-check-input" })
                                        <label class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Trip Wise</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Trip_Wise, "Y", new { @class = "form-check-input" })
                                        <label class="form-check-label">Yes</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Trip_Wise, "N", new { @class = "form-check-input" })
                                        <label class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="form-group">
                                <label class="form-label">Aggregate Rate Wise</label>
                                <div class="gap-3 d-flex">
                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Rate_Wise, "Y", new { @class = "form-check-input" })
                                        <label class="form-check-label">Yes</label>
                                    </div>

                                    <div class="form-check">
                                        @Html.RadioButtonFor(m => m.Rate_Wise, "N", new { @class = "form-check-input" })
                                        <label class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-12 col-md-12">
                            <div class="form-group">
                                <label class="form-label">Special Notes</label>
                                @*@Html.TextAreaFor(m => m.Special_Notes, new { @class = "form-control", placeholder = "Enter Special Notes", style = "resize: vertical;", id = "txtSpecialNotes" })*@
                                @Html.TextAreaFor(m => m.Special_Notes, new { @class = "form-control ckeditor-classic", placeholder = "Enter Special Notes", style = "resize: vertical;" })
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @*Billing Information*@
    <div class="col-md-12">
        <div class="card m-0">
            <div class="card-header">
                <h5 class="card-title">
                    <i class="ri-settings-3-line align-middle me-1"></i> Billing Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-lg-3 col-md-6">
