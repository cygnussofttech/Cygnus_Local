                                    <label class="form-check-label">Physical</label>
                                </div>

                                <div class="form-check">
                                    @Html.RadioButtonFor(m => m.PodSubmission, "D", new { @class = "form-check-input" })
                                    <label class="form-check-label">Digital</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-group">
                            <label class="form-label required-field">
                                Bill Submission
                            </label>
                            <div class="gap-3 d-flex">
                                <div class="form-check">
                                    @Html.RadioButtonFor(m => m.BillSubmission, "P", new { @class = "form-check-input" })
                                    <label class="form-check-label">Physical</label>
                                </div>

                                <div class="form-check">
                                    @Html.RadioButtonFor(m => m.BillSubmission, "D", new { @class = "form-check-input" })
                                    <label class="form-check-label">Digital</label>
                                </div>
