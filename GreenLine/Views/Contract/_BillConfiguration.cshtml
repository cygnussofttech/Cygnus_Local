                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-group">
                            <label class="form-label required-field">Grace Limit</label>
                            @Html.TextBoxFor(m => m.GraceLimit, new { placeholder = "Enter Grace Limit", @class = "form-control required", @onkeypress = "javascript:return validFloat(event,this.getAttribute('id'))", Value = (Model.GraceLimit == 0 ? "" : Model.GraceLimit.ToString("G29")) })
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="form-group">
                            <label class="form-label required-field">Billing Instance</label>
                            @Html.DropDownListFor(m => m.bill_inst, new SelectList(BillingInstanceList, "Value", "Text"), "", new { @class = "required select2 form-control", placeholder = "Select Billing Instance" })
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6">
